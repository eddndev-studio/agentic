---
interface Props {
    /** "panel" uses bg-wa-bg-panel (top-level cards), "deep" uses bg-wa-bg-deep (nested cards) */
    variant?: "panel" | "deep";
    /** Padding size */
    size?: "sm" | "md" | "lg";
    /** If provided, renders as <a> instead of <div> */
    href?: string;
    /** Decorative background icon name (e.g. "smart_toy", "dashboard") */
    icon?: string;
    /** Additional classes (hover states, animations, etc.) */
    class?: string;
    /** Any other HTML attributes are spread onto the wrapper */
    [key: string]: unknown;
}

const {
    variant = "panel",
    size = "md",
    href,
    icon,
    class: className = "",
    ...rest
} = Astro.props;

const variants: Record<string, string> = {
    panel: "bg-wa-bg-panel border border-wa-border rounded-xl",
    deep: "bg-wa-bg-deep border border-wa-border rounded-lg",
};

const sizes: Record<string, string> = {
    sm: "p-3 sm:p-4",
    md: "p-4 sm:p-6",
    lg: "p-6 sm:p-8",
};

/* Self-hosted SVG paths from Material Symbols (24x24 viewBox) */
const icons: Record<string, string> = {
    smart_toy:
        "M20 9V7c0-1.1-.9-2-2-2h-3c0-1.66-1.34-3-3-3S9 3.34 9 5H6c-1.1 0-2 .9-2 2v2c-1.66 0-3 1.34-3 3s1.34 3 3 3v4c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2v-4c1.66 0 3-1.34 3-3s-1.34-3-3-3zM7.5 11.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5S9.83 13 9 13s-1.5-.67-1.5-1.5zM16 17H8v-2h8v2zm-1-4c-.83 0-1.5-.67-1.5-1.5S14.17 10 15 10s1.5.67 1.5 1.5S15.83 13 15 13z",
    dashboard:
        "M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z",
    dashboard_customize:
        "M3 3h8v8H3zm2 2v4h4V5zm8-2h8v8h-8zm2 2v4h4V5zM3 13h8v8H3zm2 2v4h4v-4zm8 1.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5-1.5-.67-1.5-1.5zm4 0c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5-1.5-.67-1.5-1.5zM16.5 13c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5-1.5-.67-1.5-1.5.67-1.5 1.5-1.5z",
    account_tree:
        "M22 11V3h-7v3H9V3H2v8h7V8h2v10h4v3h7v-8h-7v3h-2V8h2v3z",
    build:
        "M22.7 19l-9.1-9.1c.9-2.3.4-5-1.5-6.9-2-2-5-2.4-7.4-1.3L9 6 6 9 1.6 4.7C.4 7.1.9 10.1 2.9 12.1c1.9 1.9 4.6 2.4 6.9 1.5l9.1 9.1c.4.4 1 .4 1.4 0l2.3-2.3c.5-.4.5-1.1.1-1.4z",
    monitoring:
        "M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z",
    person:
        "M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z",
};

const iconPath = icon ? icons[icon] : null;
const classes = [variants[variant], sizes[size], icon && "relative overflow-hidden", className];

const iconSvg = iconPath ? `<svg class="pointer-events-none absolute -right-2 -bottom-2 w-24 h-24 select-none" viewBox="0 0 24 24" fill="currentColor" style="color: rgba(255,255,255,0.04);" aria-hidden="true"><path d="${iconPath}" /></svg>` : "";
---

{href ? (
    <a href={href} class:list={["block", ...classes]} {...rest}>
        {iconPath && <Fragment set:html={iconSvg} />}
        <slot />
    </a>
) : (
    <div class:list={classes} {...rest}>
        {iconPath && <Fragment set:html={iconSvg} />}
        <slot />
    </div>
)}
