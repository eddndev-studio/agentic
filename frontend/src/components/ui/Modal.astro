---
interface Props {
    /** Alpine.js expression that controls visibility (e.g. "showEditModal") */
    show: string;
    /** Max width class (default: "max-w-md") */
    maxWidth?: string;
    /** Whether clicking the backdrop closes the modal (default: true) */
    dismissible?: boolean;
}

const { show, maxWidth = "max-w-md", dismissible = true } = Astro.props;
---

<div
    x-show={show}
    x-cloak
    class="fixed inset-0 z-50 flex items-center justify-center p-4"
    style="display: none;"
    x-on:keydown.escape.window={dismissible ? `${show} = false` : undefined}
>
    <!-- Backdrop -->
    <div
        class="absolute inset-0 bg-black/70"
        x-on:click={dismissible ? `${show} = false` : undefined}
    ></div>

    <!-- Panel -->
    <div class={`relative bg-wa-bg-panel border border-wa-border p-6 sm:p-8 w-full ${maxWidth} rounded-xl`}>
        <slot />
    </div>
</div>
