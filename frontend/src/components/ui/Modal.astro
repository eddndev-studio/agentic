---
interface Props {
    /** Alpine.js expression that controls visibility (e.g. "showEditModal") */
    show: string;
    /** Max width class (default: "max-w-md") */
    maxWidth?: string;
    /** Whether clicking the backdrop closes the modal (default: true) */
    dismissible?: boolean;
    /** "center" (default) or "sheet" (bottom sheet on mobile, centered on desktop) */
    variant?: "center" | "sheet";
}

const {
    show,
    maxWidth = "max-w-md",
    dismissible = true,
    variant = "center",
} = Astro.props;

const isSheet = variant === "sheet";

const wrapperClass = isSheet
    ? "fixed inset-0 z-60 flex items-end sm:items-center justify-center p-0 sm:p-4"
    : "fixed inset-0 z-60 flex items-center justify-center p-4";

const panelClass = isSheet
    ? `relative bg-wa-bg-panel border-t sm:border border-wa-border p-5 sm:p-6 w-full sm:${maxWidth} rounded-t-2xl sm:rounded-xl mb-16 sm:mb-0`
    : `relative bg-wa-bg-panel border border-wa-border p-6 sm:p-8 w-full ${maxWidth} rounded-xl`;
---

<div
    x-show={show}
    x-cloak
    class={wrapperClass}
    style="display: none;"
    x-on:keydown.escape.window={dismissible ? `${show} = false` : undefined}
>
    <!-- Backdrop -->
    <div
        class="absolute inset-0 bg-black/70"
        x-on:click={dismissible ? `${show} = false` : undefined}
    ></div>

    <!-- Panel -->
    <div class={panelClass}>
        <slot />
    </div>
</div>
