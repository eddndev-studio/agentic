---
import Modal from "../ui/Modal.astro";
import Button from "../ui/Button.astro";
---

<Modal show="showImportModal">
    <h2 class="text-xl font-bold mb-6 tracking-tight">Import Flow</h2>

    <div class="space-y-4">
        <!-- Source Bot -->
        <div>
            <label class="block text-xs font-sans text-wa-text-secondary mb-2">Source Bot</label>
            <select x-model="importData.sourceBotId" x-on:change="loadSourceFlows()"
                class="w-full bg-wa-bg-hover border border-wa-border text-white text-sm p-3 focus:border-wa-green focus:outline-none rounded-lg">
                <option value="">Select a Bot...</option>
                <template x-for="b in sourceBots" :key="b.id">
                    <option :value="b.id" x-text="b.name + ' (' + b.identifier + ')'" class="bg-wa-bg-deep"></option>
                </template>
            </select>
        </div>

        <!-- Source Flow -->
        <div x-show="importData.sourceBotId">
            <label class="block text-xs font-sans text-wa-text-secondary mb-2">Flow to Import</label>
            <select x-model="importData.sourceFlowId"
                class="w-full bg-wa-bg-hover border border-wa-border text-white text-sm p-3 focus:border-wa-green focus:outline-none rounded-lg">
                <option value="">Select a Flow...</option>
                <template x-for="f in sourceFlows" :key="f.id">
                    <option :value="f.id" x-text="f.name" class="bg-wa-bg-deep"></option>
                </template>
            </select>
        </div>

        <div class="pt-4 flex justify-end gap-3">
            <Button variant="secondary" x-on:click="showImportModal = false">Cancel</Button>
            <Button variant="primary" x-on:click="importFlow()"
                x-bind:disabled="!importData.sourceFlowId || loadingImport">
                <span x-show="loadingImport" class="animate-spin text-white">&#x27F3;</span>
                Import
            </Button>
        </div>
    </div>
</Modal>
