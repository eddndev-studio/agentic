---
import Modal from "../ui/Modal.astro";
import Button from "../ui/Button.astro";
---

<Modal show="showQrModal" maxWidth="max-w-sm">
    <div class="text-center">
        <h2 class="text-lg font-bold mb-2 tracking-tight">Escanear QR</h2>
        <p class="text-xs text-wa-text-secondary mb-6">Escanea este codigo con WhatsApp para conectar el bot.</p>

        <div x-show="botId" x-html="qrModalHtml"></div>

        <Button
            variant="secondary"
            class="mt-6"
            x-on:click="showQrModal = false"
        >
            Cerrar
        </Button>
    </div>
</Modal>
