<!-- Public Link Modal -->
<div
    x-show="showLinkModal"
    x-cloak
    class="fixed inset-0 z-50 flex items-center justify-center p-4"
    style="display: none;"
>
    <div
        class="absolute inset-0 bg-black/70"
        @click="showLinkModal = false"
    >
    </div>
    <div class="relative bg-wa-bg-panel border border-wa-border rounded-xl p-6 w-full max-w-md space-y-4">
        <h3 class="text-lg font-bold" x-text="$t('public_link')">Enlace Público</h3>
        <p class="text-xs text-wa-text-secondary" x-text="$t('link_expires_in')"></p>

        <div class="flex gap-2">
            <input
                type="text"
                readonly
                :value="publicLink"
                class="flex-1 bg-wa-bg-hover border border-wa-border text-white p-3 text-sm rounded-lg select-all font-mono text-[11px]"
                @click="$el.select()"
            />
            <button
                @click="copyPublicLink()"
                class="px-4 py-3 bg-wa-green text-white text-sm font-semibold rounded-lg hover:bg-wa-green-hover transition-all whitespace-nowrap"
                x-text="linkCopied ? '✓' : $t('copy_link')"
            >
            </button>
        </div>

        <button
            @click="showLinkModal = false"
            class="w-full px-4 py-2 border border-wa-border text-wa-text-secondary font-sans text-xs hover:bg-wa-bg-hover transition-colors rounded-lg"
        >
            Cerrar
        </button>
    </div>
</div>
