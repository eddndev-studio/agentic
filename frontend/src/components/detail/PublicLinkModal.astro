---
import Modal from "../ui/Modal.astro";
import Button from "../ui/Button.astro";
---

<Modal show="showLinkModal">
    <h3 class="text-lg font-bold" x-text="$t('public_link')">Enlace Publico</h3>
    <p class="text-xs text-wa-text-secondary mt-1 mb-4" x-text="$t('link_expires_in')"></p>

    <div class="flex gap-2">
        <input type="text" readonly x-bind:value="publicLink" x-on:click="$el.select()"
            class="flex-1 bg-wa-bg-hover border border-wa-border text-white p-3 text-sm rounded-lg select-all font-mono text-[11px]" />
        <Button variant="primary" size="lg" x-on:click="copyPublicLink()"
            x-text="linkCopied ? '✓' : $t('copy_link')"></Button>
    </div>

    <Button variant="secondary" class="w-full mt-4" x-on:click="showLinkModal = false">Cerrar</Button>
</Modal>
