---
import SectionHeader from "../ui/SectionHeader.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
---

<SectionHeader backHref="/bots" backTitle="Back to Bots">
    <Badge slot="badge" color="green" size="md" x-text="bot.platform"></Badge>

    <Fragment slot="title">
        <h1 class="text-3xl font-bold tracking-tight" x-text="bot.name"></h1>
    </Fragment>

    <Fragment slot="subtitle">
        <p class="text-xs font-sans text-wa-text-secondary mt-1 truncate">
            <span x-text="bot.identifier"></span>
            <template x-if="bot.ipv6Address">
                <span class="text-wa-green/70 ml-2">
                    &middot; <span x-text="bot.ipv6Address"></span>
                </span>
            </template>
        </p>
    </Fragment>

    <Fragment slot="actions">
        <!-- Connection status indicator -->
        <div x-show="botId" x-html="connectionHeaderHtml"></div>

        <!-- Pause Toggle -->
        <button
            x-on:click="togglePause()"
            class="px-4 py-2 font-sans text-xs transition-colors flex items-center gap-2 rounded-lg border"
            :class="bot.paused
                ? 'border-yellow-500/50 bg-yellow-500/10 text-yellow-400 hover:bg-yellow-500/20'
                : 'border-wa-border text-wa-text-secondary hover:bg-wa-bg-hover'"
        >
            <svg x-show="!bot.paused" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <svg x-show="bot.paused" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span x-text="bot.paused ? 'Paused' : 'Pause'"></span>
        </button>

        <div class="flex gap-3 flex-wrap">
            <a :href="'/bots/monitor?botId=' + botId"
                class="px-4 py-2 border border-wa-green/30 text-wa-green font-sans text-xs hover:bg-wa-green/10 transition-colors flex items-center gap-2 rounded-lg">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
                <span x-text="$t('monitor')">Monitor</span>
            </a>
            <button x-on:click="generatePublicLink()"
                class="px-4 py-2 border border-wa-info/30 text-wa-info font-sans text-xs hover:bg-wa-info/10 transition-colors flex items-center gap-2 rounded-lg">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                </svg>
                <span x-text="$t('public_link')">Enlace Publico</span>
            </button>
            <a :href="'/bots/emulator?id=' + botId"
                class="px-4 py-2 border border-purple-500/30 text-purple-400 font-sans text-xs hover:bg-purple-500/10 transition-colors flex items-center gap-2 rounded-lg">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span>Emular</span>
            </a>
            <a :href="'/editor?botId=' + botId"
                class="inline-flex items-center justify-center font-sans transition-colors rounded-lg px-6 py-2.5 text-xs bg-wa-green text-white hover:bg-wa-green-hover gap-2">
                <span>+</span>
                <span x-text="$t('new_flow')">New Flow</span>
            </a>
            <button x-on:click="openImportModal()"
                class="px-4 py-2 border border-wa-border text-wa-text-secondary font-sans text-xs hover:bg-wa-bg-hover transition-colors rounded-lg flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                <span x-text="$t('import') || 'Import'">Import</span>
            </button>
        </div>
        <div class="flex gap-3 flex-wrap">
            <button x-on:click="cloneBot()"
                class="px-4 py-2 border border-wa-border text-wa-text-secondary font-sans text-xs hover:bg-wa-bg-hover transition-colors rounded-lg" title="Clone Bot">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
            </button>
            <button x-on:click="editBot()"
                class="px-4 py-2 border border-wa-border text-wa-text-secondary font-sans text-xs hover:bg-wa-bg-hover transition-colors rounded-lg" x-bind:title="$t('edit')">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
            </button>
            <Button variant="danger" x-on:click="deleteBot()" x-bind:title="$t('delete')">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
            </Button>
        </div>
    </Fragment>
</SectionHeader>
