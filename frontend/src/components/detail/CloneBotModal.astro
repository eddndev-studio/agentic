---
import Modal from "../ui/Modal.astro";
import Button from "../ui/Button.astro";
---

<Modal show="showCloneModal">
    <h2 class="text-xl font-bold tracking-tight mb-6">Clone Bot</h2>

    <form @submit.prevent="submitCloneBot()" class="space-y-4">
        <div>
            <label class="block text-xs text-wa-text-secondary font-sans mb-2"
                x-text="$t('bot_name') || 'Name'"></label>
            <input type="text" x-model="cloneForm.name" required
                class="w-full bg-wa-bg-hover border border-wa-border p-3 text-sm focus:border-wa-green focus:outline-none text-white rounded-lg" />
        </div>

        <div>
            <label class="block text-xs text-wa-text-secondary font-sans mb-2"
                x-text="$t('bot_identifier') || 'Identifier'"></label>
            <input type="text" x-model="cloneForm.identifier" required placeholder="+1234567890"
                class="w-full bg-wa-bg-hover border border-wa-border p-3 text-sm focus:border-wa-green focus:outline-none text-white rounded-lg" />
        </div>

        <div class="flex gap-4 pt-4">
            <Button variant="secondary" type="button" class="flex-1" x-on:click="showCloneModal = false"
                x-text="$t('cancel') || 'Cancel'">Cancel</Button>
            <Button variant="primary" type="submit" class="flex-1" x-bind:disabled="savingClone"
                x-text="savingClone ? ($t('loading') || 'Cloning...') : 'Clone'">Clone</Button>
        </div>
    </form>
</Modal>
