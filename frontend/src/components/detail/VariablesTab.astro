        <section class="mb-8">
            <h3 class="text-xs text-wa-green tracking-normal mb-6">Variables</h3>
                <!-- Template Selector -->
                <div class="mb-8">
                    <h3 class="text-xs text-wa-green tracking-normal mb-4" x-text="$t('template_assigned')">Template</h3>
                    <div class="flex items-center gap-3">
                        <template x-if="templatesLoaded">
                            <select
                                x-init="$nextTick(() => { $el.value = bot.templateId || '' })"
                                @change="bot.templateId = $event.target.value || null; saveTemplate()"
                                class="flex-1 bg-wa-bg-hover border border-wa-border rounded-lg p-3 text-sm focus:border-wa-green focus:outline-none text-white"
                            >
                                <option value="" x-text="$t('no_template')">None (Custom)</option>
                                <template x-for="tpl in availableTemplates" :key="tpl.id">
                                    <option :value="tpl.id" x-text="tpl.name"></option>
                                </template>
                            </select>
                        </template>
                        <span x-show="!templatesLoaded" class="text-xs text-wa-text-secondary" x-text="$t('loading')"></span>
                        <span x-show="savingTemplate" class="text-xs text-wa-text-secondary" x-text="$t('saving')"></span>
                    </div>
                    <p class="text-[10px] text-wa-text-secondary mt-2" x-show="bot.templateId">
                        AI config, flows, tools y automations se heredan de la plantilla.
                    </p>
                </div>

                <!-- Bot Variables (typed by template definition) -->
                <h3 class="text-xs text-wa-green tracking-normal mb-2" x-text="$t('bot_variables')">Variables</h3>

                <!-- Template-defined variables -->
                <template x-if="templateVarDefs.length > 0">
                    <div>
                        <p class="text-[10px] text-wa-text-secondary mb-4">Configura los valores específicos de este bot para la plantilla.</p>
                        <div class="space-y-4 mb-4">
                            <template x-for="def in templateVarDefs" :key="def.name">
                                <div class="bg-wa-bg-hover/50 p-3 rounded-lg border border-wa-border">
                                    <div class="flex items-center gap-2 mb-2">
                                        <span class="text-xs font-mono text-purple-400" x-text="def.name"></span>
                                        <span class="text-[9px] px-1.5 py-0.5 rounded"
                                            :class="{
                                                'bg-purple-500/10 text-purple-400': def.type === 'label',
                                                'bg-blue-500/10 text-blue-400': def.type === 'text',
                                                'bg-sky-500/10 text-sky-400': def.type === 'image',
                                                'bg-orange-500/10 text-orange-400': def.type === 'video',
                                                'bg-teal-500/10 text-teal-400': def.type === 'audio',
                                                'bg-yellow-500/10 text-yellow-400': def.type === 'document',
                                            }"
                                            x-text="({label:'Etiqueta',text:'Texto',image:'Imagen',video:'Video',audio:'Audio',document:'Documento'})[def.type] || def.type"></span>
                                    </div>
                                    <!-- Text type: textarea for multiline support -->
                                    <template x-if="def.type === 'text'">
                                        <textarea
                                            :value="getVarValue(def.name)"
                                            @input="setVarValue(def.name, $event.target.value)"
                                            placeholder="Valor..."
                                            rows="3"
                                            class="w-full bg-wa-bg-deep/50 border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white resize-y min-h-[2.5rem]"></textarea>
                                    </template>
                                    <!-- Label type: label picker -->
                                    <template x-if="def.type === 'label'">
                                        <div class="flex flex-wrap gap-2">
                                            <template x-for="lbl in botLabels" :key="lbl.id">
                                                <button type="button"
                                                    @click="setVarValue(def.name, getVarValue(def.name) === lbl.name ? '' : lbl.name)"
                                                    class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-xs font-medium transition-all border cursor-pointer select-none"
                                                    :class="getVarValue(def.name) === lbl.name
                                                        ? 'bg-purple-500/15 border-purple-500/40 text-purple-400'
                                                        : 'bg-wa-bg-hover border-wa-border text-wa-text-secondary hover:border-wa-text-secondary'"
                                                >
                                                    <span class="w-2.5 h-2.5 rounded-full shrink-0" :style="'background:' + getLabelColor(lbl.color)"></span>
                                                    <span x-text="lbl.name"></span>
                                                </button>
                                            </template>
                                            <span x-show="botLabels.length === 0" class="text-wa-text-secondary text-xs py-1">No hay etiquetas sincronizadas</span>
                                        </div>
                                    </template>
                                    <!-- Media types: URL input + Pick button + preview -->
                                    <template x-if="['image','video','audio','document'].includes(def.type)">
                                        <div class="space-y-2">
                                            <div class="flex gap-2">
                                                <input type="text"
                                                    :value="getVarValue(def.name)"
                                                    @input="setVarValue(def.name, $event.target.value)"
                                                    placeholder="https://..."
                                                    class="flex-1 bg-wa-bg-deep/50 border border-wa-border rounded-lg p-2.5 text-sm font-mono focus:border-wa-green focus:outline-none text-white" />
                                                <button type="button"
                                                    @click="window.dispatchEvent(new CustomEvent('open-media-picker', { detail: { callback: (url) => setVarValue(def.name, url) } }))"
                                                    class="px-3 py-2 bg-wa-bg-hover border border-wa-border rounded-lg text-xs text-wa-text-secondary hover:border-wa-green hover:text-wa-green transition-colors shrink-0">
                                                    Pick
                                                </button>
                                            </div>
                                            <template x-if="def.type === 'image' && getVarValue(def.name)">
                                                <img :src="getVarValue(def.name)" alt="" class="h-20 object-cover rounded-lg opacity-70 border border-wa-border" />
                                            </template>
                                        </div>
                                    </template>
                                </div>
                            </template>
                        </div>
                    </div>
                </template>

                <!-- No template or no vars defined: free-form editor -->
                <template x-if="templateVarDefs.length === 0">
                    <div>
                        <p class="text-[10px] text-wa-text-secondary mb-4" x-text="$t('bot_variables_desc')"></p>
                        <div class="space-y-3 mb-4">
                            <template x-for="(variable, index) in variablesList" :key="index">
                                <div class="space-y-2 bg-wa-bg-hover/30 p-3 rounded-lg border border-wa-border">
                                    <div class="flex gap-2 items-start">
                                        <input type="text" x-model="variable.key" :placeholder="$t('variable_key')" class="w-36 shrink-0 bg-wa-bg-hover border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white font-mono" />
                                        <select x-model="variable.type"
                                            class="w-28 shrink-0 bg-wa-bg-hover border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white">
                                            <option value="text">Texto</option>
                                            <option value="image">Imagen</option>
                                            <option value="video">Video</option>
                                            <option value="audio">Audio</option>
                                            <option value="document">Documento</option>
                                        </select>
                                        <button @click="variablesList.splice(index, 1)" class="p-2 text-red-400 hover:text-red-300 transition-colors shrink-0">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                                        </button>
                                    </div>
                                    <!-- Text type: textarea -->
                                    <template x-if="!variable.type || variable.type === 'text'">
                                        <textarea x-model="variable.value" :placeholder="$t('variable_value')" rows="3" class="w-full bg-wa-bg-hover border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white resize-y min-h-[2.5rem]"></textarea>
                                    </template>
                                    <!-- Media types: URL input + Pick -->
                                    <template x-if="variable.type && variable.type !== 'text'">
                                        <div class="space-y-2">
                                            <div class="flex gap-2">
                                                <input type="text" x-model="variable.value" placeholder="https://..."
                                                    class="flex-1 bg-wa-bg-hover border border-wa-border rounded-lg p-2.5 text-sm font-mono focus:border-wa-green focus:outline-none text-white" />
                                                <button type="button"
                                                    @click="window.dispatchEvent(new CustomEvent('open-media-picker', { detail: { callback: (url) => { variable.value = url } } }))"
                                                    class="px-3 py-2 bg-wa-bg-hover border border-wa-border rounded-lg text-xs text-wa-text-secondary hover:border-wa-green hover:text-wa-green transition-colors shrink-0">
                                                    Pick
                                                </button>
                                            </div>
                                            <template x-if="variable.type === 'image' && variable.value">
                                                <img :src="variable.value" alt="" class="h-20 object-cover rounded-lg opacity-70 border border-wa-border" />
                                            </template>
                                        </div>
                                    </template>
                                </div>
                            </template>
                        </div>
                        <div x-show="variablesList.length === 0" class="p-6 border border-dashed border-wa-border rounded-lg text-center text-wa-text-secondary text-xs mb-4">
                            <span x-text="$t('no_variables')">No variables defined</span>
                        </div>
                        <button @click="variablesList.push({ key: '', value: '', type: 'text' })" class="px-4 py-2 border border-dashed border-wa-border text-wa-text-secondary text-xs rounded-lg hover:border-wa-green hover:text-wa-green transition-colors mr-3">
                            + <span x-text="$t('add_variable')">Add Variable</span>
                        </button>
                    </div>
                </template>

                <div class="flex items-center gap-3 mt-4">
                    <button
                        @click="saveVariables()"
                        :disabled="savingVariables"
                        class="px-6 py-2 bg-wa-green text-white text-xs rounded-lg hover:bg-wa-green-hover disabled:opacity-50 transition-colors"
                        x-text="savingVariables ? $t('saving') : $t('save_variables')"
                    >
                        Save Variables
                    </button>
                    <span x-show="variablesSaved" x-transition.opacity class="text-xs text-green-400 flex items-center gap-1">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        Guardado
                    </span>
                </div>
        </section>
