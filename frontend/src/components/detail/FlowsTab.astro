        <!-- Tab content: Flujos -->
        <div x-show="activeTab === 'flows'" x-transition:enter>
                    <div class="flex justify-between items-center mb-6">
                        <h3
                            class="text-xs text-wa-green tracking-normal"
                            x-text="$t('flows')"
                        >
                            Flows
                        </h3>
                        <div class="flex items-center gap-3">
                            <input
                                type="text"
                                x-model="flowSearch"
                                placeholder="Buscar flujo..."
                                class="px-3 py-1.5 bg-wa-bg-deep border border-wa-border rounded-lg text-xs text-wa-text outline-none focus:border-wa-green/50 w-48"
                            />
                            <span
                                class="text-xs font-sans text-wa-text-secondary"
                                x-text="filteredFlows.length + ' / ' + flows.length"></span>
                        </div>
                    </div>

                    <!-- Flow Grid -->
                    <template x-if="filteredFlows.length > 0">
                        <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
                            <template x-for="flow in filteredFlows" :key="flow.id">
                                <a :href="'/editor?id=' + flow.id + (templateId ? '&templateId=' + templateId : '')"
                                   class="flex flex-col justify-between p-4 bg-wa-bg-deep border border-wa-border hover:border-wa-green/30 transition-all group rounded-xl min-h-[120px]">
                                    <div>
                                        <div class="flex items-start justify-between gap-2">
                                            <h4 class="text-sm font-bold tracking-tight group-hover:text-wa-green transition-colors leading-tight" x-text="flow.name"></h4>
                                            <button
                                                @click.prevent.stop="deleteFlow(flow.id, flow.name)"
                                                class="p-1 text-wa-text-secondary/40 hover:text-red-400 transition-colors flex-shrink-0 -mt-1 -mr-1"
                                                :title="$t('delete_flow') || 'Delete Flow'"
                                            >
                                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                                </svg>
                                            </button>
                                        </div>
                                        <p x-show="flow.description" class="text-[10px] text-wa-text-secondary mt-1.5 line-clamp-2" x-text="flow.description"></p>
                                    </div>
                                    <div class="flex gap-2 mt-3 flex-wrap">
                                        <template x-for="trigger in flow.triggers.slice(0, 3)" :key="trigger.id">
                                            <span class="text-[10px] font-sans bg-wa-bg-hover px-2 py-0.5 text-wa-text-secondary rounded-md" x-text="trigger.matchType + ': ' + trigger.keyword"></span>
                                        </template>
                                        <span x-show="flow.triggers.length > 3" class="text-[10px] font-sans text-wa-text-secondary" x-text="'+' + (flow.triggers.length - 3) + ' more'"></span>
                                        <span x-show="flow.triggers.length === 0" class="text-[10px] text-wa-text-secondary/50">No triggers</span>
                                    </div>
                                </a>
                            </template>
                        </div>
                    </template>

                    <!-- Empty State -->
                    <template x-if="filteredFlows.length === 0 && flows.length > 0">
                        <div class="text-center py-8 border border-dashed border-wa-border rounded-xl">
                            <p class="text-xs text-wa-text-secondary">Sin resultados para "<span x-text="flowSearch"></span>"</p>
                        </div>
                    </template>
                    <template x-if="flows.length === 0">
                        <div
                            class="text-center py-12 border border-dashed border-wa-border rounded-xl"
                        >
                            <svg
                                class="w-10 h-10 mx-auto mb-4 text-wa-text-secondary"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="1"
                                    d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"
                                ></path>
                            </svg>
                            <p
                                class="text-xs font-sans text-wa-text-secondary mb-4"
                                x-text="$t('no_flows')"
                            >
                                No flows configured
                            </p>
                            <a
                                :href="templateId ? '/editor?templateId=' + templateId : '/editor?botId=' + botId"
                                class="inline-block px-6 py-2 bg-wa-green text-white font-sans text-xs tracking-normal hover:bg-wa-green-hover transition-colors rounded-lg"
                            >
                                + <span x-text="$t('new_flow')"
                                    >Create Flow</span
                                >
                            </a>
                        </div>
                    </template>
        </div>
