---
import Card from "../ui/Card.astro";
---
<div class="flex justify-between items-center mb-6 gap-3 flex-wrap">
    <h3 class="text-xs text-wa-green tracking-normal" x-text="$t('tools')">Herramientas</h3>
    <a :href="'/tool-editor?botId=' + botId"
        class="inline-flex items-center justify-center font-sans transition-colors rounded-lg disabled:opacity-50 px-4 py-2.5 text-xs bg-wa-green text-white hover:bg-wa-green-hover gap-2">
        <span>+</span>
        <span x-text="$t('new_tool')">New Tool</span>
    </a>
</div>

<!-- Built-in Tools -->
<div class="mb-6">
    <h4 class="text-[10px] text-wa-text-secondary tracking-widest uppercase mb-3" x-text="$t('builtin_tools') || 'Built-in Tools'">Built-in Tools</h4>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <template x-for="bt in builtinTools" :key="bt.name">
            <Card variant="deep" size="sm" class="flex flex-col justify-between opacity-80 min-h-[80px] border-wa-border/50">
                <div>
                    <div class="flex items-start justify-between gap-2 mb-1">
                        <span class="font-bold font-mono text-xs text-white leading-tight" x-text="bt.name"></span>
                        <span class="text-[8px] font-sans bg-wa-green/10 text-wa-green px-1.5 py-0.5 rounded shrink-0">BUILTIN</span>
                    </div>
                    <p class="text-[10px] text-wa-text-secondary line-clamp-2" x-text="bt.description"></p>
                </div>
            </Card>
        </template>
    </div>
</div>

<!-- Custom Tools -->
<h4 class="text-[10px] text-wa-text-secondary tracking-widest uppercase mb-3" x-text="$t('custom_tools') || 'Custom Tools'">Custom Tools</h4>
<template x-if="tools.length > 0">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        <template x-for="tool in tools" :key="tool.id">
            <a :href="'/tool-editor?id=' + tool.id"
                class="flex flex-col justify-between p-4 bg-wa-bg-deep border border-wa-border hover:border-wa-green/30 transition-all group rounded-xl min-h-[100px]">
                <div>
                    <div class="flex items-start justify-between gap-2 mb-1">
                        <h4 class="text-sm font-bold font-mono group-hover:text-wa-green transition-colors leading-tight" x-text="tool.name"></h4>
                        <span class="text-[10px] font-sans px-1.5 py-0.5 rounded shrink-0"
                            :class="tool.status === 'ACTIVE' ? 'bg-green-500/10 text-green-400' : 'bg-gray-500/10 text-wa-text-secondary'"
                            x-text="tool.status"></span>
                    </div>
                    <p class="text-[10px] text-wa-text-secondary line-clamp-2" x-text="tool.description"></p>
                </div>
                <div class="mt-3">
                    <span class="text-[10px] font-sans bg-wa-green/10 text-wa-green px-2 py-0.5 rounded" x-text="tool.actionType"></span>
                </div>
            </a>
        </template>
    </div>
</template>

<!-- Convert Flows Section -->
<template x-if="flows.length > 0">
    <div class="mt-8 pt-6 border-t border-wa-border">
        <h4 class="text-xs text-wa-text-secondary tracking-normal mb-4" x-text="$t('convert_to_tool')">Convert Flows to Tools</h4>
        <div class="space-y-2">
            <template x-for="flow in flows" :key="'convert-' + flow.id">
                <Card variant="deep" size="sm" class="flex items-center justify-between gap-3">
                    <span class="text-sm text-wa-text-secondary min-w-0 break-words" x-text="flow.name"></span>
                    <button @click="convertFlowToTool(flow.id)"
                        class="px-3 py-1 text-[10px] font-sans border border-wa-green/30 text-wa-green hover:bg-wa-green/10 transition-colors rounded-lg flex-shrink-0 whitespace-nowrap"
                        x-text="$t('convert_to_tool')">
                    </button>
                </Card>
            </template>
        </div>
    </div>
</template>

<!-- Empty Custom Tools hint -->
<template x-if="tools.length === 0">
    <p class="text-xs text-wa-text-secondary text-center py-4" x-text="$t('no_custom_tools') || 'No custom tools yet. Built-in tools are always active.'"></p>
</template>
