---
interface Props {
    title: string;
    subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<div class="w-full max-w-md p-4 sm:p-8 relative z-10">
    <!-- Header -->
    <div class="mb-10 text-center">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight mb-2">
            Agentic <span class="text-wa-green text-xs tracking-wide align-top">ID</span>
        </h1>
        <p class="text-sm text-wa-text-secondary mt-3">{title}</p>
        {subtitle && <p class="text-xs text-wa-text-secondary/60 mt-1">{subtitle}</p>}
    </div>

    <!-- Card -->
    <div class="p-4 sm:p-8 bg-wa-bg-panel border border-wa-border rounded-xl">
        <slot />
    </div>

    <!-- Footer links -->
    <slot name="footer" />
</div>
