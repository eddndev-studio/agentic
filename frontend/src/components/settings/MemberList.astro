<!-- Member List -->
<div class="space-y-3">
    <template x-for="member in members" :key="member.id">
        <div class="bg-wa-bg-hover border border-wa-border rounded-xl overflow-hidden"
             x-data="{ expanded: false }">
            <!-- Member row -->
            <div class="flex items-center justify-between p-4">
                <div class="flex items-center gap-3 min-w-0">
                    <div class="w-9 h-9 rounded-full bg-wa-green/10 flex items-center justify-center shrink-0">
                        <span class="text-sm font-semibold text-wa-green" x-text="(member.user.fullName || member.user.email)[0].toUpperCase()"></span>
                    </div>
                    <div class="min-w-0">
                        <p class="text-sm font-medium truncate" x-text="member.user.fullName || member.user.email"></p>
                        <p class="text-xs text-wa-text-secondary truncate" x-text="member.user.email"></p>
                    </div>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                    <!-- Role badge -->
                    <span class="text-[10px] font-semibold px-2 py-1 rounded-full"
                        :class="{
                            'bg-amber-500/10 text-amber-400': member.role === 'OWNER',
                            'bg-wa-green/10 text-wa-green': member.role === 'ADMIN',
                            'bg-blue-500/10 text-blue-400': member.role === 'SUPERVISOR',
                            'bg-wa-text-secondary/10 text-wa-text-secondary': member.role === 'WORKER'
                        }"
                        x-text="member.role">
                    </span>

                    <!-- Assign bots button (WORKER/SUPERVISOR only) -->
                    <template x-if="member.role === 'WORKER' || member.role === 'SUPERVISOR'">
                        <button @click="expanded = !expanded; if (expanded) loadMemberBots(member.id)"
                            class="p-1.5 text-wa-text-secondary hover:text-wa-green hover:bg-wa-green/10 rounded transition-colors"
                            title="Asignar bots">
                            <svg class="w-4 h-4 transition-transform" :class="expanded && 'rotate-180'" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                            </svg>
                        </button>
                    </template>

                    <!-- Actions (not for OWNER, not for self) -->
                    <template x-if="member.role !== 'OWNER' && member.userId !== currentUserId">
                        <div class="flex gap-1">
                            <select @change="changeRole(member.id, $event.target.value); $event.target.value = ''"
                                class="bg-transparent border border-wa-border text-xs text-wa-text-secondary rounded px-1 py-1">
                                <option value="" selected disabled>Rol</option>
                                <option value="ADMIN">Admin</option>
                                <option value="SUPERVISOR">Supervisor</option>
                                <option value="WORKER">Worker</option>
                            </select>
                            <button @click="removeMember(member.id)"
                                class="p-1.5 text-red-400 hover:bg-red-500/10 rounded transition-colors"
                                title="Eliminar miembro">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                </svg>
                            </button>
                        </div>
                    </template>
                </div>
            </div>

            <!-- Bot assignment panel (expandable) -->
            <div x-show="expanded" x-collapse class="border-t border-wa-border">
                <div class="p-4">
                    <p class="text-xs text-wa-text-secondary mb-3">Bots asignados a este miembro:</p>

                    <!-- Loading bots -->
                    <div x-show="!orgBots" class="text-xs text-wa-text-secondary animate-pulse">Cargando bots...</div>

                    <!-- Bot checkboxes -->
                    <div x-show="orgBots" class="space-y-2">
                        <template x-for="bot in (orgBots || [])" :key="bot.id">
                            <label class="flex items-center gap-3 p-2.5 rounded-lg cursor-pointer hover:bg-wa-bg-panel transition-colors">
                                <input type="checkbox"
                                    :checked="memberBots[member.id]?.includes(bot.id)"
                                    @change="toggleBot(member.id, bot.id, $event.target.checked)"
                                    class="w-4 h-4 rounded border-wa-border bg-wa-bg-deep text-wa-green focus:ring-wa-green/50 focus:ring-offset-0" />
                                <div class="flex items-center gap-2 min-w-0">
                                    <span class="text-[10px] text-wa-green bg-wa-green/10 px-1.5 py-0.5 rounded" x-text="bot.platform"></span>
                                    <span class="text-sm truncate" x-text="bot.name"></span>
                                    <span class="text-xs text-wa-text-secondary truncate" x-text="bot.identifier"></span>
                                </div>
                            </label>
                        </template>

                        <!-- Empty state -->
                        <p x-show="orgBots?.length === 0" class="text-xs text-wa-text-secondary">No hay bots en esta organizacion.</p>
                    </div>
                </div>
            </div>
        </div>
    </template>
</div>
