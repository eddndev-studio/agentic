<!-- Member List -->
<div class="space-y-3">
    <template x-for="member in members" :key="member.id">
        <div class="flex items-center justify-between p-4 bg-wa-bg-hover border border-wa-border rounded-xl">
            <div class="flex items-center gap-3 min-w-0">
                <div class="w-9 h-9 rounded-full bg-wa-green/10 flex items-center justify-center shrink-0">
                    <span class="text-sm font-semibold text-wa-green" x-text="(member.user.fullName || member.user.email)[0].toUpperCase()"></span>
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-medium truncate" x-text="member.user.fullName || member.user.email"></p>
                    <p class="text-xs text-wa-text-secondary truncate" x-text="member.user.email"></p>
                </div>
            </div>
            <div class="flex items-center gap-2 shrink-0">
                <!-- Role badge -->
                <span class="text-[10px] font-semibold px-2 py-1 rounded-full"
                    :class="{
                        'bg-amber-500/10 text-amber-400': member.role === 'OWNER',
                        'bg-wa-green/10 text-wa-green': member.role === 'ADMIN',
                        'bg-blue-500/10 text-blue-400': member.role === 'SUPERVISOR',
                        'bg-wa-text-secondary/10 text-wa-text-secondary': member.role === 'WORKER'
                    }"
                    x-text="member.role">
                </span>
                <!-- Actions (not for OWNER, not for self) -->
                <template x-if="member.role !== 'OWNER' && member.userId !== currentUserId">
                    <div class="flex gap-1">
                        <select @change="changeRole(member.id, $event.target.value); $event.target.value = ''"
                            class="bg-transparent border border-wa-border text-xs text-wa-text-secondary rounded px-1 py-1">
                            <option value="" selected disabled>Rol</option>
                            <option value="ADMIN">Admin</option>
                            <option value="SUPERVISOR">Supervisor</option>
                            <option value="WORKER">Worker</option>
                        </select>
                        <button @click="removeMember(member.id)"
                            class="p-1.5 text-red-400 hover:bg-red-500/10 rounded transition-colors"
                            title="Eliminar miembro">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                            </svg>
                        </button>
                    </div>
                </template>
            </div>
        </div>
    </template>
</div>
