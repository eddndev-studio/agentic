<div class="flex flex-wrap gap-1.5">
    <button
        @click="addStep('TEXT')"
        class="px-3 py-1.5 bg-wa-bg-hover hover:bg-wa-bg-hover/80 text-[10px] font-sans border border-wa-border rounded-lg hover:border-wa-green/30 transition-colors"
        x-text="$t('add_step_text')">Text</button>
    <button
        @click="addStep('IMAGE')"
        class="px-3 py-1.5 bg-wa-bg-hover hover:bg-wa-bg-hover/80 text-[10px] font-sans border border-wa-border rounded-lg hover:border-wa-green/30 transition-colors"
        x-text="$t('add_step_image')">Image</button>
    <button
        @click="addStep('AUDIO')"
        class="px-3 py-1.5 bg-wa-bg-hover hover:bg-wa-bg-hover/80 text-[10px] font-sans border border-wa-border rounded-lg hover:border-wa-green/30 transition-colors"
        x-text="$t('add_step_audio')">Audio</button>
    <button
        @click="addStep('VIDEO')"
        class="px-3 py-1.5 bg-wa-bg-hover hover:bg-wa-bg-hover/80 text-[10px] font-sans border border-wa-border rounded-lg hover:border-wa-green/30 transition-colors"
        x-text="$t('add_step_video')">Video</button>
    <button
        @click="addStep('CONDITIONAL_TIME')"
        class="px-3 py-1.5 bg-wa-green/20 text-wa-green hover:bg-wa-green/40 text-[10px] font-sans border border-wa-green/30 rounded-lg transition-colors flex items-center gap-1"
        title="Time Condition">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        TIME
    </button>
    <button
        @click="addStep('TOOL')"
        class="px-3 py-1.5 bg-purple-500/20 text-purple-400 hover:bg-purple-500/40 text-[10px] font-sans border border-purple-500/30 rounded-lg transition-colors flex items-center gap-1"
        title="Execute Tool">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        TOOL
    </button>
</div>
