---
import StepToolConfig from './StepToolConfig.astro';
import StepTimeConfig from './StepTimeConfig.astro';
import AutoTextarea from '../ui/AutoTextarea.astro';
---

<!-- Step card (used inside x-for="(step, index) in flow.steps") -->
<div class="step-card bg-wa-bg-deep border border-wa-border rounded-lg p-3 sm:p-4 relative group hover:border-wa-green/50 transition-colors overflow-hidden"
     :data-id="index">

    <!-- Header: drag + type + delete -->
    <div class="flex items-center gap-2 mb-3">
        <div class="flex flex-col shrink-0 -my-1">
            <button @click="moveUp(index)" :disabled="index === 0"
                    class="text-wa-text-secondary hover:text-white disabled:opacity-20 disabled:hover:text-wa-text-secondary transition-colors p-0.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"></path></svg>
            </button>
            <button @click="moveDown(index)" :disabled="index === flow.steps.length - 1"
                    class="text-wa-text-secondary hover:text-white disabled:opacity-20 disabled:hover:text-wa-text-secondary transition-colors p-0.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
            </button>
        </div>
        <span x-text="step.type" class="text-wa-green font-bold text-xs shrink-0"></span>
        <div class="flex-1"></div>
        <button @click="removeStep(index)" class="text-red-500/40 hover:text-red-400 transition-colors p-0.5 shrink-0">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
        </button>
    </div>

    <!-- Controls row: AI Only toggle + Delay + Jitter (always visible, inline) -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-3 pb-3 border-b border-wa-border/50">
        <!-- AI Only toggle (pill style) -->
        <button type="button" @click="step.aiOnly = !step.aiOnly"
                class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium transition-all border select-none"
                :class="step.aiOnly
                    ? 'bg-purple-500/15 border-purple-500/40 text-purple-400'
                    : 'bg-wa-bg-hover border-wa-border text-wa-text-secondary hover:border-wa-text-secondary'">
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
            <span x-text="$t('ai_only')"></span>
        </button>

        <!-- Delay -->
        <label class="flex items-center gap-1.5 text-xs text-wa-text-secondary">
            <svg class="w-3.5 h-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <input type="number" x-model="step.delayMs"
                   class="w-16 bg-wa-bg-hover text-center px-2 py-1 border border-wa-border focus:outline-none focus:border-wa-green text-white text-xs rounded-lg"
                   min="0" />
            <span>ms</span>
        </label>

        <!-- Jitter -->
        <label class="flex items-center gap-1.5 text-xs text-wa-text-secondary">
            <span>&#177;</span>
            <input type="number" x-model="step.jitterPct"
                   class="w-14 bg-wa-bg-hover text-center px-2 py-1 border border-wa-border focus:outline-none focus:border-wa-green text-white text-xs rounded-lg"
                   min="0" max="100" />
            <span>%</span>
        </label>
    </div>

    <!-- Step Content by Type -->
    <div>
        <!-- TEXT -->
        <template x-if="step.type === 'TEXT'">
            <AutoTextarea x-model="step.content" :placeholder="$t('message_content')" />
        </template>

        <!-- MEDIA (IMAGE, AUDIO, VIDEO, DOCUMENT) -->
        <template x-if="['IMAGE', 'AUDIO', 'VIDEO', 'DOCUMENT'].includes(step.type)">
            <div>
                <div class="flex flex-col sm:flex-row gap-2 mb-2">
                    <input type="text" x-model="step.mediaUrl"
                        class="flex-1 min-w-0 bg-wa-bg-deep/50 border border-wa-border p-2 text-xs font-mono rounded-lg"
                        :placeholder="$t('media_url_placeholder')" />
                    <button @click="selectMedia(index)"
                        class="bg-wa-bg-hover px-3 py-2 sm:py-0 text-xs hover:bg-wa-bg-hover/80 shrink-0 rounded-lg transition-colors"
                        x-text="$t('select_media')"></button>
                </div>
                <template x-if="step.type === 'IMAGE' && step.mediaUrl">
                    <img :src="step.mediaUrl" class="h-20 opacity-50 hover:opacity-100 transition-opacity border border-wa-border rounded-lg" />
                </template>
                <template x-if="step.type === 'VIDEO' && step.mediaUrl">
                    <video :src="step.mediaUrl" class="h-20 opacity-50 hover:opacity-100 transition-opacity border border-wa-border rounded-lg" muted preload="metadata"></video>
                </template>
                <template x-if="step.type === 'IMAGE' || step.type === 'VIDEO'">
                    <AutoTextarea x-model="step.content" rows={1} :placeholder="$t('caption_placeholder')" minHeight="36px" class="text-xs mt-1" />
                </template>
            </div>
        </template>

        <!-- TOOL -->
        <template x-if="step.type === 'TOOL'">
            <StepToolConfig />
        </template>

        <!-- CONDITIONAL_TIME -->
        <template x-if="step.type === 'CONDITIONAL_TIME'">
            <StepTimeConfig />
        </template>
    </div>
</div>
