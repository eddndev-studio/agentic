---
---
<div x-show="showNotesPanel" x-transition class="bg-wa-bg-deep border-b border-wa-border px-4 py-2.5 flex-shrink-0" style="display:none;">
    <div class="flex items-center gap-2 mb-1.5">
        <svg class="w-3.5 h-3.5 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        <span class="text-[10px] text-purple-400 uppercase tracking-wider font-medium">Notas</span>
        <button @click="showNotesPanel = false" class="ml-auto text-wa-text-secondary hover:text-white text-sm">&times;</button>
    </div>
    <textarea
        x-model="sessionNotes"
        @blur="saveNotes()"
        rows="2"
        class="w-full bg-wa-bg-hover border border-wa-border text-wa-text-primary text-xs p-2 rounded-lg focus:border-purple-400 focus:outline-none resize-y"
        placeholder="Escribe notas sobre este contacto..."
    ></textarea>
</div>
