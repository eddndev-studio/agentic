---
---
<!-- Reply preview bar -->
<div x-show="replyingTo" class="bg-wa-bg-header px-2 sm:px-4 pt-2 flex items-center gap-2 flex-shrink-0 border-t border-wa-border" style="display:none;">
    <div class="flex-1 rounded-lg px-3 py-2 border-l-4 border-wa-green bg-wa-green/5 min-w-0">
        <span class="text-[10px] font-semibold text-wa-green block" x-text="replyingTo?.fromMe ? 'Tu' : (replyingTo?.sender?.split('@')[0] || 'Mensaje')"></span>
        <span class="text-xs text-wa-text-secondary truncate block" x-text="replyingTo?.content || '[media]'"></span>
    </div>
    <button @click="replyingTo = null" class="text-wa-text-secondary hover:text-red-400 transition-colors p-1 flex-shrink-0">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
    </button>
</div>

<!-- Attachment preview (multi-file) -->
<div x-show="attachments.length > 0 || uploadingFile" class="bg-wa-bg-header px-2 sm:px-4 pt-2 pb-1 flex-shrink-0 border-t border-wa-border" style="display:none;">
    <div class="flex items-center gap-1 mb-1">
        <span class="text-[10px] text-wa-text-secondary" x-text="attachments.length + ' archivo(s)'"></span>
        <template x-if="uploadingFile">
            <div class="w-3 h-3 border-2 border-wa-green/30 border-t-wa-green rounded-full animate-spin ml-1"></div>
        </template>
        <button @click="clearAttachments()" class="ml-auto text-[10px] text-red-400 hover:text-red-300 transition-colors">Quitar todo</button>
    </div>
    <div class="flex gap-2 overflow-x-auto pb-1">
        <template x-for="(att, i) in attachments" :key="i">
            <div class="relative flex-shrink-0 group/att">
                <!-- Image/video thumbnail -->
                <template x-if="att.preview">
                    <img :src="att.preview" class="w-16 h-16 sm:w-20 sm:h-20 object-cover rounded-lg border border-wa-border" />
                </template>
                <!-- Document/audio icon -->
                <template x-if="!att.preview">
                    <div class="w-16 h-16 sm:w-20 sm:h-20 bg-wa-bg-hover rounded-lg border border-wa-border flex flex-col items-center justify-center gap-1">
                        <svg class="w-5 h-5 text-wa-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                        <span class="text-[8px] text-wa-text-secondary truncate max-w-[56px] sm:max-w-[72px] px-1" x-text="att.file.name"></span>
                    </div>
                </template>
                <!-- Remove button -->
                <button @click="removeAttachment(i)"
                    class="absolute -top-1.5 -right-1.5 w-5 h-5 bg-red-500 text-white rounded-full flex items-center justify-center opacity-0 group-hover/att:opacity-100 transition-opacity shadow"
                    style="font-size:10px;">×</button>
                <!-- Media type badge -->
                <span class="absolute bottom-1 left-1 text-[8px] bg-black/60 text-white px-1 rounded" x-text="att.mediaType"></span>
            </div>
        </template>
        <!-- Add more button -->
        <button @click="$refs.fileInput.click()" :disabled="uploadingFile"
            class="w-16 h-16 sm:w-20 sm:h-20 flex-shrink-0 border-2 border-dashed border-wa-border rounded-lg flex items-center justify-center text-wa-text-secondary hover:border-wa-green hover:text-wa-green transition-colors">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
        </button>
    </div>
</div>

<!-- Quick replies dropdown -->
<div x-show="showQuickReplies" x-transition class="bg-wa-bg-deep border-t border-wa-border px-4 py-2 flex-shrink-0 max-h-40 overflow-y-auto" style="display:none;">
    <template x-for="(qr, i) in quickReplies" :key="i">
        <button
            @click="messageInput = qr; showQuickReplies = false; $refs.messageInputEl.focus()"
            class="w-full text-left px-3 py-1.5 text-xs text-wa-text-secondary hover:text-white hover:bg-wa-bg-hover rounded transition-colors truncate"
            x-text="qr"
        ></button>
    </template>
</div>

<!-- Emoji picker -->
<div x-show="showEmojiPicker" x-transition class="bg-wa-bg-deep border-t border-wa-border flex-shrink-0" style="display:none;"
     x-data="{
         search: '',
         activeTab: 'smileys',
         tabs: [
             { id: 'smileys', icon: '😀', emojis: '😀😁😂🤣😊😇🙂🙃😉😌😍🥰😘😗😙😚😋😛😜🤪😝🤑🤗🤭🫢🫣🤫🤔🫡🤐🤨😐😑😶🫥😏😒🙄😬🤥🫠😌😔😪🤤😴😷🤒🤕🤢🤮🤧🥵🥶🥴😵🤯🤠🥳🥸😎🤓🧐😕🫤😟🙁☹️😮😯😲😳🥺🥹😦😧😨😰😥😢😭😱😖😣😞😓😩😫🥱😤😡😠🤬😈👿💀☠️💩🤡👹👺👻👽👾🤖' },
             { id: 'gestures', icon: '👋', emojis: '👋🤚🖐️✋🖖🫱🫲🫳🫴👌🤌🤏✌️🤞🫰🤟🤘🤙👈👉👆🖕👇☝️🫵👍👎✊👊🤛🤜👏🙌🫶👐🤲🤝🙏✍️💅🤳💪🦾🦿🦵🦶👂🦻👃🧠🫀🫁🦷🦴👀👁️👅👄' },
             { id: 'hearts', icon: '❤️', emojis: '❤️🧡💛💚💙💜🖤🤍🤎💔❤️‍🔥❤️‍🩹❣️💕💞💓💗💖💘💝💟🫶' },
             { id: 'animals', icon: '🐶', emojis: '🐶🐱🐭🐹🐰🦊🐻🐼🐻‍❄️🐨🐯🦁🐮🐷🐽🐸🐵🙈🙉🙊🐒🐔🐧🐦🐤🐣🐥🦆🦅🦉🦇🐺🐗🐴🦄🐝🪱🐛🦋🐌🐞🐜🪰🪲🪳🦟🦗🕷️🕸️🦂🐢🐍🦎🦖🦕🐙🦑🦐🦞🦀🪸🐡🐠🐟🐬🐳🐋🦈🦭🐊🐅🐆🦓🦍🦧🦣🐘🦛🦏🐪🐫🦒🦘🦬🐃🐂🐄🐎🐖🐏🐑🦙🐐🦌🐕🐩🦮🐕‍🦺🐈🐈‍⬛🪶🐓🦃🦤🦚🦜🦢🦩🕊️🐇🦝🦨🦡🦫🦦🦥🐁🐀🐿️🦔🐾🐉🐲🌵🎄🌲🌳🌴🪵🌱🌿☘️🍀🎍🪴🎋🍃🍂🍁🪺🪹🍄🐚🪨🌾💐🌷🌹🥀🪻🌺🌸🌼🌻🌞🌝🌛🌜🌚🌕🌖🌗🌘🌑🌒🌓🌔🌙🌎🌍🌏🪐💫⭐🌟✨⚡☄️💥🔥🌪️🌈☀️🌤️⛅🌥️☁️🌦️🌧️⛈️🌩️🌨️❄️☃️⛄🌬️💨💧💦🫧☔☂️🌊🌫️' },
             { id: 'food', icon: '🍕', emojis: '🍇🍈🍉🍊🍋🍌🍍🥭🍎🍏🍐🍑🍒🍓🫐🥝🍅🫒🥥🥑🍆🥔🥕🌽🌶️🫑🥒🥬🥦🧄🧅🍄🥜🫘🌰🍞🥐🥖🫓🥨🥯🥞🧇🧀🍖🍗🥩🥓🍔🍟🍕🌭🥪🌮🌯🫔🥙🧆🥚🍳🥘🍲🫕🥣🥗🍿🧈🧂🥫🍱🍘🍙🍚🍛🍜🍝🍠🍢🍣🍤🍥🥮🍡🥟🥠🥡🦀🦞🦐🦑🦪🍦🍧🍨🍩🍪🎂🍰🧁🥧🍫🍬🍭🍮🍯🍼🥛☕🫖🍵🍶🍾🍷🍸🍹🍺🍻🥂🥃🫗🥤🧋🧃🧉🧊🥢🍽️🍴🥄' },
             { id: 'objects', icon: '⚽', emojis: '⚽🏀🏈⚾🥎🎾🏐🏉🥏🎱🪀🏓🏸🏒🏑🥍🏏🪃🥅⛳🪁🏹🎣🤿🥊🥋🎽🛹🛼🛷⛸️🥌🎿⛷️🏋️🤸🤺⛹️🤾🏌️🏇🧘🏄🏊🤽🚣🧗🚵🚴🏆🥇🥈🥉🏅🎖️🏵️🎗️🎫🎟️🎪🤹🎭🩰🎨🎬🎤🎧🎼🎹🥁🪘🎷🎺🎸🪕🎻🎲♟️🎯🎳🎮🎰🧩💰💴💵💶💷💸💳🧾💹📱📲💻⌨️🖥️🖨️🖱️🖲️💾💿📀🎥🎞️📽️🎬📺📷📸📹📼🔍🔎🕯️💡🔦🏮📔📕📖📗📘📙📚📓📒📃📜📄📰🗞️📑🔖🏷️✉️📧📨📩📤📥📦📫📪📬📭📮🗳️✏️✒️🖋️🖊️🖌️🖍️📝💼📁📂🗂️📅📆🗒️🗓️📇📈📉📊📋📌📍📎🖇️📏📐✂️🗃️🗄️🗑️🔒🔓🔏🔐🔑🗝️🔨🪓⛏️⚒️🛠️🗡️⚔️🔫🪃🛡️🪚🔧🪛🔩⚙️🗜️⚖️🦯🔗⛓️🪝🧰🧲🪜🧪🧫🧬🔬🔭📡💉🩸💊🩹🩻🩺🚪🛗🪞🪟🛏️🛋️🪑🚽🪠🚿🛁🪤🪒🧴🧷🧹🧺🧻🪣🧼🫧🪥🧽🧯🛒🚬⚰️🪦⚱️🗿🪧🪪🏧' },
             { id: 'symbols', icon: '✅', emojis: '✅❌❓❗💯🔴🟠🟡🟢🔵🟣⚫⚪🟤🔺🔻🔸🔹🔶🔷💠🔘🔲🔳⬛⬜◾◽▪️▫️🏁🚩🎌🏴🏳️🏳️‍🌈🏳️‍⚧️' },
         ],
         get filtered() {
             if (!this.search) return this.tabs.find(t => t.id === this.activeTab)?.emojis || '';
             const q = this.search.toLowerCase();
             return this.tabs.map(t => t.emojis).join('');
         },
         get emojiList() {
             return [...this.filtered];
         }
     }">
    <!-- Search + tabs -->
    <div class="px-2 sm:px-3 pt-2 pb-1 flex items-center gap-2">
        <input type="text" x-model="search" placeholder="Buscar emoji..."
            class="flex-1 bg-wa-bg-hover text-wa-text-primary text-xs py-1.5 px-3 rounded-full focus:outline-none placeholder-wa-text-secondary" />
    </div>
    <div x-show="!search" class="flex gap-0.5 px-2 sm:px-3 pb-1 overflow-x-auto">
        <template x-for="tab in tabs" :key="tab.id">
            <button @click="activeTab = tab.id"
                class="px-2 py-1 text-base rounded transition-colors flex-shrink-0"
                :class="activeTab === tab.id ? 'bg-wa-bg-hover' : 'hover:bg-wa-bg-hover/50'"
                x-text="tab.icon"></button>
        </template>
    </div>
    <!-- Grid -->
    <div class="grid grid-cols-7 sm:grid-cols-9 gap-0.5 px-2 sm:px-3 pb-2 max-h-44 overflow-y-auto">
        <template x-for="emoji in emojiList" :key="emoji">
            <button @click="messageInput += emoji; $refs.messageInputEl.focus()"
                class="w-9 h-9 flex items-center justify-center text-xl hover:bg-wa-bg-hover rounded transition-colors"
                x-text="emoji"></button>
        </template>
    </div>
</div>

<!-- Input area -->
<div class="bg-wa-bg-header px-2 sm:px-4 py-2 flex items-center gap-1.5 sm:gap-2 flex-shrink-0">
    <!-- Emoji button -->
    <button
        @click="showEmojiPicker = !showEmojiPicker; showQuickReplies = false"
        class="flex w-9 h-9 sm:w-10 sm:h-10 rounded-full text-wa-text-secondary hover:text-wa-green hover:bg-wa-bg-hover items-center justify-center transition-colors flex-shrink-0"
        :class="showEmojiPicker ? 'text-wa-green' : ''"
    >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </button>
    <!-- Quick replies button -->
    <button
        @click="showQuickReplies = !showQuickReplies; showEmojiPicker = false"
        class="flex w-9 h-9 sm:w-10 sm:h-10 rounded-full text-wa-text-secondary hover:text-wa-green hover:bg-wa-bg-hover items-center justify-center transition-colors flex-shrink-0"
        :class="showQuickReplies ? 'text-wa-green' : ''"
    >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
    </button>
    <!-- Attach button -->
    <button
        @click="$refs.fileInput.click()"
        class="w-9 h-9 sm:w-10 sm:h-10 rounded-full text-wa-text-secondary hover:text-wa-green hover:bg-wa-bg-hover flex items-center justify-center transition-colors flex-shrink-0"
        :disabled="uploadingFile"
    >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.172 7l-6.586 6.586a2 2 0 102.828 2.828l6.414-6.586a4 4 0 00-5.656-5.656l-6.415 6.585a6 6 0 108.486 8.486L20.5 13"/></svg>
    </button>
    <input type="file" x-ref="fileInput" @change="handleFileSelect($event)" class="hidden" accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.zip,.rar" multiple />

    <form @submit.prevent="sendMessage()" class="flex-1 flex items-center gap-1.5 sm:gap-2">
        <input
            type="text"
            x-model="messageInput"
            x-ref="messageInputEl"
            class="flex-1 min-w-0 bg-wa-bg-hover text-wa-text-primary text-sm py-2 sm:py-2.5 px-3 sm:px-4 rounded-full focus:outline-none placeholder-wa-text-secondary"
            :placeholder="attachments.length > 0 ? 'Caption...' : $t('type_message')"
        />
        <button
            type="submit"
            :disabled="(!messageInput.trim() && attachments.length === 0) || sending || uploadingFile"
            class="w-9 h-9 sm:w-10 sm:h-10 rounded-full bg-wa-green text-white flex items-center justify-center hover:bg-wa-green-hover transition-colors disabled:opacity-40 flex-shrink-0"
        >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
            </svg>
        </button>
    </form>
</div>
