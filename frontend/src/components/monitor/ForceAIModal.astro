---
import Modal from "../ui/Modal.astro";
import Button from "../ui/Button.astro";
---

<Modal show="showForceAIModal" variant="sheet">
    <h3 class="text-sm font-bold mb-2" x-text="$t('force_ai')"></h3>
    <p class="text-xs text-wa-text-secondary mb-4" x-text="$t('force_ai_desc')"></p>
    <textarea
        x-model="forceAIContext"
        rows="3"
        class="w-full bg-wa-bg-hover border border-wa-border text-white text-sm p-3 focus:border-wa-green focus:outline-none resize-y mb-4 rounded-lg"
        x-bind:placeholder="$t('force_ai_context')"
    ></textarea>
    <div class="flex justify-end gap-2">
        <Button variant="secondary" x-on:click="showForceAIModal = false" x-text="$t('cancel')"></Button>
        <button x-on:click="forceAI()"
            class="inline-flex items-center justify-center font-sans transition-colors rounded-lg disabled:opacity-50 px-4 py-2.5 text-xs bg-yellow-600 text-white hover:bg-yellow-700"
            x-text="$t('confirm')"></button>
    </div>
</Modal>
