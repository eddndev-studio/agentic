---
---
<!-- Messages area -->
<div
    x-ref="messagesContainer"
    @scroll="onChatScroll()"
    class="flex-1 overflow-y-auto px-3 sm:px-[5%] md:px-[8%] lg:px-[10%] py-3 min-h-0 wa-chat-wallpaper"
>
    <!-- Load more indicator -->
    <div x-show="loadingMore" class="flex justify-center py-3">
        <span class="wa-date-pill">Cargando mensajes...</span>
    </div>
    <div x-show="!loadingMore && !hasMoreMessages && messages.length > 0" class="flex justify-center py-3">
        <span class="wa-date-pill">Inicio del chat</span>
    </div>

    <template x-if="messages.length === 0 && !loadingMore">
        <div class="flex items-center justify-center h-full">
            <p class="text-sm text-wa-text-secondary" x-text="$t('no_messages')"></p>
        </div>
    </template>

    <template x-for="(msg, idx) in messages" :key="msg.id">
        <div>
            <!-- Date separator -->
            <div x-show="showDateSep(messages, idx)" class="flex justify-center my-3">
                <span class="wa-date-pill" x-text="dateLabel(msg.createdAt)"></span>
            </div>

            <!-- Message bubble -->
            <div class="flex mb-[2px] group/msg"
                 :class="[
                     msg.fromMe ? 'justify-end' : 'justify-start',
                     isLastInGroup(messages, idx) ? 'mb-2' : ''
                 ]"
            >
                <!-- Reaction button (visible on hover/tap) -->
                <div class="flex items-end" :class="msg.fromMe ? 'order-first' : 'order-last'">
                    <div class="relative" x-data="{ showReactPicker: false }">
                        <button
                            @click="showReactPicker = !showReactPicker"
                            class="w-7 h-7 rounded-full flex items-center justify-center text-wa-text-secondary hover:text-white hover:bg-wa-bg-hover transition-all mx-0.5 sm:mx-1 sm:opacity-0 sm:group-hover/msg:opacity-100"
                        >
                            <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        </button>
                        <div x-show="showReactPicker" @click.outside="showReactPicker = false"
                            class="absolute bottom-full mb-1 z-50 bg-wa-bg-header border border-wa-border rounded-2xl shadow-lg px-1 py-1 flex flex-wrap gap-0.5 w-max max-w-[200px]"
                            :class="msg.fromMe ? 'right-0' : 'left-0'" style="display:none;">
                            <template x-for="emoji in ['👍','👎','❤️','🔥','😂','😮','😢','😡','🙏','🎉','💯','🤔']" :key="emoji">
                                <button @click="reactToMessage(msg.id, emoji); showReactPicker = false"
                                    class="w-8 h-8 flex items-center justify-center text-lg hover:scale-125 active:scale-110 transition-transform rounded-full hover:bg-wa-bg-hover"
                                    x-text="emoji"></button>
                            </template>
                        </div>
                    </div>
                </div>
                <div
                    class="relative max-w-[88%] sm:max-w-[80%] md:max-w-[70%] lg:max-w-[65%] text-sm break-words shadow-sm overflow-hidden"
                    :class="[
                        msg.fromMe ? 'bg-wa-bubble-out text-white' : 'bg-wa-bubble-in text-white',
                        isLastInGroup(messages, idx)
                            ? (msg.fromMe ? 'rounded-lg rounded-br-none wa-bubble-tail-out' : 'rounded-lg rounded-bl-none wa-bubble-tail-in')
                            : 'rounded-lg',
                        getMediaUrl(msg) && ['IMAGE', 'VIDEO', 'STICKER'].includes(msg.type) ? '' : 'px-2.5 py-1.5'
                    ]"
                >
                    <!-- IMAGE -->
                    <template x-if="msg.type === 'IMAGE' && getMediaUrl(msg)">
                        <a :href="getMediaUrl(msg)" target="_blank" rel="noopener" class="block">
                            <img :src="getMediaUrl(msg)" class="w-full max-h-72 object-cover" loading="lazy" alt=""
                                @error="$el.outerHTML = '<div class=\'flex items-center justify-center h-24 text-wa-text-secondary text-xs\'>Imagen no disponible</div>'" />
                        </a>
                    </template>

                    <!-- VIDEO -->
                    <template x-if="msg.type === 'VIDEO' && getMediaUrl(msg)">
                        <div>
                            <video :src="getMediaUrl(msg)" controls preload="metadata" class="w-full max-h-72"></video>
                        </div>
                    </template>

                    <!-- AUDIO -->
                    <template x-if="msg.type === 'AUDIO' && getMediaUrl(msg)">
                        <div class="px-2.5 pt-2 min-w-[180px] sm:min-w-[240px]">
                            <audio :src="getMediaUrl(msg)" controls preload="metadata" class="w-full h-10"></audio>
                        </div>
                    </template>

                    <!-- DOCUMENT -->
                    <template x-if="msg.type === 'DOCUMENT' && getMediaUrl(msg)">
                        <a :href="getMediaUrl(msg)" target="_blank" rel="noopener" class="flex items-center gap-3 bg-white/5 rounded-lg p-3 mx-1 mt-1 mb-1 hover:bg-white/10 transition-colors">
                            <svg class="w-8 h-8 text-wa-text-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                            </svg>
                            <div class="min-w-0">
                                <span class="text-xs text-blue-300 block truncate">Documento</span>
                                <span class="text-[10px] text-wa-text-secondary">Toca para abrir</span>
                            </div>
                        </a>
                    </template>

                    <!-- STICKER -->
                    <template x-if="msg.type === 'STICKER' && getMediaUrl(msg)">
                        <img :src="getMediaUrl(msg)" class="w-36 h-36 sm:w-40 sm:h-40 object-contain p-1" loading="lazy" alt="Sticker"
                            @error="$el.style.display='none'; $el.nextElementSibling?.style.removeProperty('display')" />
                    </template>
                    <template x-if="msg.type === 'STICKER' && getMediaUrl(msg)">
                        <div class="w-36 h-36 sm:w-40 sm:h-40 flex items-center justify-center text-wa-text-secondary" style="display:none;">
                            <span class="text-xs">Sticker no disponible</span>
                        </div>
                    </template>

                    <!-- PTT (voice note) -->
                    <template x-if="msg.type === 'PTT' && getMediaUrl(msg)">
                        <div class="px-2.5 pt-2 min-w-[180px] sm:min-w-[240px] flex items-center gap-2">
                            <svg class="w-5 h-5 text-wa-green flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 14a3 3 0 003-3V5a3 3 0 00-6 0v6a3 3 0 003 3zm5-3a5 5 0 01-10 0H5a7 7 0 0014 0h-2zM11 19.93V22h2v-2.07A8 8 0 0020 12h-2a6 6 0 01-12 0H4a8 8 0 007 7.93z"/></svg>
                            <audio :src="getMediaUrl(msg)" controls preload="metadata" class="w-full h-10"></audio>
                        </div>
                    </template>

                    <!-- REACTION -->
                    <template x-if="msg.type === 'REACTION'">
                        <div class="flex items-center gap-1.5 px-1">
                            <span class="text-2xl" x-text="msg.content || '❌'"></span>
                            <span class="text-[10px] text-wa-text-secondary" x-text="msg.content ? 'reaccionó' : 'quitó reacción'"></span>
                        </div>
                    </template>

                    <!-- CONTACT -->
                    <template x-if="msg.type === 'CONTACT'">
                        <div class="flex items-center gap-2 bg-white/5 rounded-lg p-3 mx-1 mt-1 mb-1">
                            <svg class="w-8 h-8 text-wa-text-secondary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>
                            <span class="text-xs" x-text="msg.content || 'Contacto'"></span>
                        </div>
                    </template>

                    <!-- LOCATION -->
                    <template x-if="msg.type === 'LOCATION'">
                        <a :href="'https://maps.google.com/?q=' + (msg.metadata?.latitude || 0) + ',' + (msg.metadata?.longitude || 0)" target="_blank" rel="noopener" class="flex items-center gap-2 bg-white/5 rounded-lg p-3 mx-1 mt-1 mb-1 hover:bg-white/10 transition-colors">
                            <svg class="w-8 h-8 text-red-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>
                            <div class="min-w-0">
                                <span class="text-xs text-blue-300 block truncate" x-text="msg.content || 'Ubicación'"></span>
                                <span class="text-[10px] text-wa-text-secondary">Toca para abrir en Maps</span>
                            </div>
                        </a>
                    </template>

                    <!-- POLL -->
                    <template x-if="msg.type === 'POLL'">
                        <div class="bg-white/5 rounded-lg p-3 mx-1 mt-1 mb-1">
                            <div class="flex items-center gap-1.5 mb-2">
                                <svg class="w-4 h-4 text-wa-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zm0-8v2h14V9H7z"/></svg>
                                <span class="text-xs font-medium" x-text="msg.content || 'Encuesta'"></span>
                            </div>
                            <template x-if="msg.metadata?.options">
                                <div class="flex flex-col gap-1">
                                    <template x-for="opt in msg.metadata.options" :key="opt">
                                        <span class="text-[10px] text-wa-text-secondary bg-white/5 rounded px-2 py-1" x-text="opt"></span>
                                    </template>
                                </div>
                            </template>
                        </div>
                    </template>

                    <!-- Media fallback for missing URLs -->
                    <template x-if="!getMediaUrl(msg) && ['IMAGE','VIDEO','AUDIO','DOCUMENT','STICKER','PTT'].includes(msg.type)">
                        <div class="flex items-center gap-2 px-2.5 py-2 text-wa-text-secondary">
                            <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
                            <span class="text-xs italic" x-text="'[' + msg.type.toLowerCase() + ']'"></span>
                        </div>
                    </template>

                    <!-- Text content / caption -->
                    <div :class="getMediaUrl(msg) && ['IMAGE', 'VIDEO', 'STICKER'].includes(msg.type) ? (msg.content ? 'px-2.5 pt-1.5 pb-1.5 border-t border-white/5' : 'px-2.5 py-1') : ''" x-show="msg.type !== 'REACTION' || msg.content">
                        <span x-show="msg.content && msg.content !== '[media]'" x-html="formatMessage(msg.content)" class="whitespace-pre-wrap"></span>
                        <span x-show="!msg.content && !getMediaUrl(msg) && msg.type === 'TEXT'" class="text-wa-text-secondary italic"></span>
                        <span class="inline-flex items-center gap-1 float-right ml-2 mt-1 text-[11px] text-wa-text-secondary align-bottom leading-none translate-y-0.5">
                            <span x-text="shortTime(msg.createdAt)"></span>
                            <template x-if="msg.fromMe">
                                <svg class="w-4 h-4 wa-check-blue" viewBox="0 0 16 15" fill="currentColor">
                                    <path d="M15.01 3.316l-.478-.372a.365.365 0 00-.51.063L8.666 9.88 5.64 6.3a.365.365 0 00-.519-.033l-.438.399a.376.376 0 00-.037.527l3.605 4.19a.515.515 0 00.4.2.514.514 0 00.4-.2l6.024-7.56a.376.376 0 00-.065-.507z"/>
                                    <path d="M12.33 3.316l-.478-.372a.365.365 0 00-.51.063L5.986 9.88 4.96 8.65a.365.365 0 00-.519-.033l-.438.399a.376.376 0 00-.037.527l2.1 2.442a.515.515 0 00.4.2.514.514 0 00.4-.2l6.024-7.56a.376.376 0 00-.065-.507z" opacity=".75"/>
                                </svg>
                            </template>
                        </span>
                    </div>
                </div>

                <!-- Reaction badges (click to react with same emoji) -->
                <div x-show="getReactions(msg).length > 0" class="flex gap-1 mt-0.5 px-1 -mt-1" :class="msg.fromMe ? 'justify-end' : 'justify-start'">
                    <template x-for="r in getReactions(msg)" :key="r.emoji">
                        <button @click="reactToMessage(msg.id, r.emoji)"
                            class="inline-flex items-center gap-0.5 bg-wa-bg-header border border-wa-border rounded-full px-1.5 py-0.5 text-xs shadow-sm hover:border-wa-green/50 hover:bg-wa-bg-hover transition-colors cursor-pointer">
                            <span x-text="r.emoji"></span>
                            <span x-show="r.count > 1" class="text-[10px] text-wa-text-secondary" x-text="r.count"></span>
                        </button>
                    </template>
                </div>
            </div>
        </div>
    </template>
</div>

<!-- Scroll-to-bottom floating button -->
<div class="relative">
    <button
        x-show="showScrollDown"
        x-transition
        @click="scrollToBottom()"
        class="absolute bottom-3 right-3 sm:right-6 z-10 w-10 h-10 rounded-full bg-wa-bg-header border border-wa-border shadow-lg flex items-center justify-center text-wa-text-secondary hover:text-wa-green transition-colors"
        style="display:none;"
    >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </button>
</div>
