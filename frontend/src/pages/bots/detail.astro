---
import Layout from "../../layouts/Layout.astro";
import BotConnection from "../../components/BotConnection.astro";
import ClientList from "../../components/clients/ClientList.astro";
import ClientModal from "../../components/clients/ClientModal.astro";
import BotHeader from "../../components/detail/BotHeader.astro";
import TabBar from "../../components/detail/TabBar.astro";
import FlowsTab from "../../components/detail/FlowsTab.astro";
import VariablesTab from "../../components/detail/VariablesTab.astro";
import NotificationsTab from "../../components/detail/NotificationsTab.astro";
import AIConfigTab from "../../components/detail/AIConfigTab.astro";
import LabelsTab from "../../components/detail/LabelsTab.astro";
import ToolsTab from "../../components/detail/ToolsTab.astro";
import AutomationsTab from "../../components/detail/AutomationsTab.astro";
import LogsTab from "../../components/detail/LogsTab.astro";
import QRModal from "../../components/detail/QRModal.astro";
import ImportFlowModal from "../../components/detail/ImportFlowModal.astro";
import EditBotModal from "../../components/detail/EditBotModal.astro";
import CloneBotModal from "../../components/detail/CloneBotModal.astro";
import PublicLinkModal from "../../components/detail/PublicLinkModal.astro";
import BotDetailSkeleton from "../../components/skeletons/BotDetailSkeleton.astro";
---

<Layout title="Bot Detail">
    <div
        x-data="botDetail"
        x-show="ready"
        class="space-y-8"
        style="display: none;"
    >
        <BotHeader />
        <TabBar />

        <!-- Tab content: Flujos -->
        <div x-show="activeTab === 'flows'" x-transition:enter>
            <FlowsTab />
        </div>

        <!-- Tab content: Variables -->
        <div x-show="activeTab === 'variables'" x-transition:enter>
            <VariablesTab />
        </div>

        <!-- Tab content: Notificaciones -->
        <div x-show="activeTab === 'notifications'" x-transition:enter>
            <NotificationsTab />
        </div>

        <!-- Tab content: Config IA -->
        <div x-show="activeTab === 'config'" x-transition:enter>
            <AIConfigTab />
        </div>

        <!-- Tab content: Etiquetas -->
        <div x-show="activeTab === 'labels'" x-transition:enter>
            <LabelsTab />
        </div>

        <!-- Tab content: Herramientas -->
        <div x-show="activeTab === 'tools'" x-transition:enter>
            <ToolsTab />
        </div>

        <!-- Tab content: Automatizaciones -->
        <div x-show="activeTab === 'automations'" x-transition:enter>
            <AutomationsTab />
        </div>

        <!-- Tab content: Clients -->
        <div x-show="activeTab === 'clients'" x-transition:enter>
            <div class="min-h-[400px]">
                <div class="flex justify-between items-center mb-6 gap-3 flex-wrap">
                    <h3 class="text-xs text-wa-green tracking-normal">Listado de Clientes</h3>
                    <div class="flex gap-2">
                        <ClientModal />
                    </div>
                </div>
                <ClientList />
            </div>
        </div>

        <!-- Tab content: Logs -->
        <div x-show="activeTab === 'logs'" x-transition:enter>
            <LogsTab />
        </div>

        <!-- Modals -->
        <QRModal />
        <ImportFlowModal />
        <EditBotModal />
        <CloneBotModal />
        <PublicLinkModal />
    </div>

    <!-- Loading Skeleton -->
    <div
        x-data="botDetail"
        x-show="!ready && !error"
    >
        <BotDetailSkeleton />
    </div>

    <!-- Error State -->
    <div
        x-data="botDetail"
        x-show="error"
        class="flex items-center justify-center min-h-[60vh]"
    >
        <div class="text-center">
            <h1 class="text-4xl font-bold text-red-500 mb-4">404</h1>
            <p
                class="text-wa-text-secondary font-sans mb-8"
                x-text="error"
            >
            </p>
            <a
                href="/bots"
                class="px-6 py-3 bg-wa-green text-white font-sans text-xs tracking-normal hover:bg-wa-green-hover transition-colors rounded-lg"
            >
                &larr; Back to Bots
            </a>
        </div>
    </div>
</Layout>

<script>
    declare const Alpine: any;
    import { ApiClient } from "../../lib/api";
    import { BotEventSource } from "../../lib/events";

    // Detail module imports
    import { formatDate, formatTimeout, getLabelColor, getLabelName } from "../../lib/detail/format-helpers";
    import { togglePause, deleteBot, editBot, submitEditBot, cloneBot, submitCloneBot, generatePublicLink, copyPublicLink } from "../../lib/detail/bot-methods";
    import { deleteFlow, openImportModal, loadSourceFlows, importFlow, exportFlowsJson, importFlowsJson } from "../../lib/detail/flow-methods";
    import { saveAIConfig, clearConversations, toggleIgnoredLabel, loadNotifSessions, addNotifChannel, removeNotifChannel, toggleChannelEvent, toggleChannelLabel, saveNotifications } from "../../lib/detail/config-methods";
    import { syncLabels, createLabel, updateLabel, deleteLabel, moveLabelUp, moveLabelDown } from "../../lib/detail/label-methods";
    import { getVarValue, setVarValue, saveVariables, saveTemplate } from "../../lib/detail/variable-methods";
    import { loadAutomations, openCreateAutomation, editAutomation, saveAutomation, toggleAutomation, deleteAutomation } from "../../lib/detail/automation-methods";
    import { loadTools, convertFlowToTool, loadLogs, prevPage, nextPage } from "../../lib/detail/log-methods";
    import { generateConnectionHtml, generateConnectionHeaderHtml, generateQrModalHtml } from "../../lib/detail/connection-helpers";

    interface Bot {
        id: string;
        name: string;
        identifier: string;
        platform: "WHATSAPP" | "TELEGRAM" | "INSTAGRAM";
        userId: string;
        ipv6Address?: string;
        [key: string]: any;
    }

    interface Flow {
        id: string;
        name: string;
        description: string;
        triggers: { id: string; keyword: string; matchType: string }[];
    }

    document.addEventListener("alpine:init", () => {
        Alpine.data("botDetail", () => ({
            botId: null as string | null,
            bot: {} as Bot,
            flows: [] as Flow[],
            flowSearch: "",
            get filteredFlows(): Flow[] {
                const q = this.flowSearch.toLowerCase().trim();
                const list = q
                    ? this.flows.filter((f: Flow) =>
                        f.name.toLowerCase().includes(q) ||
                        (f.description || "").toLowerCase().includes(q) ||
                        f.triggers?.some((t: any) => t.keyword?.toLowerCase().includes(q))
                    )
                    : [...this.flows];
                return list.sort((a: Flow, b: Flow) => a.name.localeCompare(b.name));
            },
            ready: false,
            error: null as string | null,
            connectionHtml: "",
            connectionHeaderHtml: "",

            // Import State
            showQrModal: false,
            qrModalHtml: "",
            showImportModal: false,
            loadingImport: false,
            sourceBots: [] as Bot[],
            sourceFlows: [] as Flow[],
            importData: { sourceBotId: "", sourceFlowId: "" },

            // Public Link State
            showLinkModal: false,
            publicLink: "",
            linkCopied: false,

            // Clone Bot State
            showCloneModal: false,
            savingClone: false,
            cloneForm: { name: "", identifier: "" },

            // Edit Bot State
            showEditModal: false,
            savingEdit: false,
            editForm: { name: "", identifier: "" },

            // AI Config State
            aiConfig: {
                aiEnabled: false,
                defaultSessionAi: false,
                aiProvider: "GEMINI",
                aiModel: "gemini-2.5-flash",
                systemPrompt: "",
                temperature: 0.7,
                thinkingLevel: "LOW",
                messageDelay: 0,
                contextMessages: 20,
                autoReadReceipts: true,
                excludeGroups: false,
                ignoredLabels: [] as string[],
            },
            savingAI: false,
            botLabels: [] as any[],
            syncingLabels: false,
            creatingLabel: false,
            newLabelName: '',
            newLabelColor: 0,
            editingLabel: null as { id: string; name: string; color: number } | null,
            savingLabel: false,

            // Notification Config State
            savingNotifications: false,
            notificationChannels: [] as { sessionId: string; events: string[]; labels: string[]; nickname: string; _name: string }[],
            notifSessions: [] as any[],

            // Automations State
            automations: [] as any[],
            showAutomationModal: false,
            editingAutomationId: null as string | null,
            automationForm: {
                name: "",
                event: "INACTIVITY" as string,
                labelName: "",
                timeoutValue: 3,
                timeoutUnit: "days" as string,
                prompt: "",
            },

            // Variables & Template State
            variablesList: [] as { key: string; value: string; type: string }[],
            templateVarDefs: [] as { name: string; type: string }[],
            savingVariables: false,
            variablesSaved: false,
            availableTemplates: [] as any[],
            selectedTemplateId: "" as string,
            templatesLoaded: false,
            savingTemplate: false,

            // Tools State
            builtinTools: [
                { name: "get_current_time", description: "Obtiene la fecha y hora actual en la zona horaria especificada." },
                { name: "clear_conversation", description: "Limpia el historial de conversación de la sesión actual." },
                { name: "get_labels", description: "Obtiene todas las etiquetas disponibles del bot con la cantidad de chats asignados." },
                { name: "assign_label", description: "Asigna una etiqueta existente al chat actual." },
                { name: "remove_label", description: "Remueve una etiqueta del chat actual." },
                { name: "get_sessions_by_label", description: "Busca todos los chats que tienen una etiqueta específica, con sus últimos mensajes." },
                { name: "reply_to_message", description: "Responde citando un mensaje específico del usuario (quote-reply de WhatsApp)." },
                { name: "send_followup_message", description: "Envía un mensaje de seguimiento a otra sesión/chat del bot." },
                { name: "set_notification_channel", description: "Marca la sesión actual como canal de notificaciones del bot." },
                { name: "notify", description: "Envía un mensaje al canal de notificaciones configurado del bot." },
            ],
            tools: [] as any[],

            // Tab State
            activeTab: "flows" as string,
            logsLoaded: false,
            logs: [] as any[],
            loadingLogs: false,
            logsPagination: { total: 0, limit: 50, offset: 0 },
            filters: { status: "ALL", search: "", startDate: "", endDate: "" },

            async init() {
                const params = new URLSearchParams(window.location.search);
                this.botId = params.get("id");

                if (!this.botId) {
                    this.error = "No bot ID provided";
                    return;
                }

                const tabParam = params.get('tab');
                if (tabParam && ['flows', 'config', 'tools', 'automations', 'variables', 'notifications', 'clients', 'logs', 'labels'].includes(tabParam)) {
                    this.activeTab = tabParam;
                }

                try {
                    this.bot = await ApiClient.get(`/bots/${this.botId}`);
                    this.flows = await ApiClient.get(`/flows?botId=${this.botId}`);

                    this.aiConfig = {
                        aiEnabled: this.bot.aiEnabled || false,
                        defaultSessionAi: this.bot.defaultSessionAi || false,
                        aiProvider: this.bot.aiProvider || "GEMINI",
                        aiModel: this.bot.aiModel || "gemini-2.5-flash",
                        systemPrompt: this.bot.systemPrompt || "",
                        temperature: this.bot.temperature ?? 0.7,
                        thinkingLevel: this.bot.thinkingLevel || "LOW",
                        messageDelay: this.bot.messageDelay ?? 0,
                        contextMessages: this.bot.contextMessages ?? 20,
                        autoReadReceipts: this.bot.autoReadReceipts ?? true,
                        excludeGroups: this.bot.excludeGroups || false,
                        ignoredLabels: this.bot.ignoredLabels || [],
                    };

                    const rawChannels = Array.isArray(this.bot.notificationChannels) ? this.bot.notificationChannels : [];
                    this.notificationChannels = rawChannels.map((ch: any) => ({
                        sessionId: ch.sessionId,
                        events: ch.events || [],
                        labels: ch.labels || [],
                        nickname: ch.nickname || '',
                        _name: '',
                    }));

                    try {
                        this.botLabels = await ApiClient.get(`/sessions/labels?botId=${this.botId}`);
                    } catch (e) {
                        console.error("Failed to load labels", e);
                    }

                    if (this.notificationChannels.length > 0) {
                        try {
                            const sessData = await ApiClient.get(`/sessions?botId=${this.botId}`);
                            const sessions = Array.isArray(sessData.data || sessData) ? (sessData.data || sessData) : [];
                            for (const ch of this.notificationChannels) {
                                const s = sessions.find((sess: any) => sess.id === ch.sessionId);
                                ch._name = s?.name || s?.identifier || "Sesión desconocida";
                            }
                        } catch (e) {
                            for (const ch of this.notificationChannels) ch._name = "Error al cargar";
                        }
                    }

                    const rawVars = this.bot.botVariables || {};
                    this.variablesList = Object.entries(rawVars).map(([key, value]: [string, any]) => ({
                        key,
                        value: typeof value === 'string' ? value : value?.value ?? '',
                        type: typeof value === 'object' && value?.type === 'media' ? (value.mediaType || 'text') : 'text',
                    }));

                    try {
                        this.availableTemplates = await ApiClient.get("/templates");
                    } catch (e) {
                        console.error("Failed to load templates", e);
                    } finally {
                        this.selectedTemplateId = this.bot.templateId || "";
                        this.templatesLoaded = true;
                    }

                    if (this.bot.templateId) {
                        try {
                            const tpl = await ApiClient.get(`/templates/${this.bot.templateId}`);
                            this.templateVarDefs = Array.isArray(tpl.variables) ? tpl.variables : [];
                        } catch (e) {
                            console.error("Failed to load template var defs", e);
                        }
                    }

                    loadTools(this);
                    loadAutomations(this);

                    if (this.activeTab === 'logs') {
                        loadLogs(this);
                        this.logsLoaded = true;
                    }

                    this.connectionHtml = generateConnectionHtml(this);
                    this.connectionHeaderHtml = generateConnectionHeaderHtml(this);
                    this.qrModalHtml = generateQrModalHtml(this);

                    this.ready = true;

                    this.$nextTick(() => {
                        for (const sel of ['[x-html="connectionHtml"]', '[x-html="connectionHeaderHtml"]', '[x-html="qrModalHtml"]']) {
                            const el = document.querySelector(sel);
                            if (el) Alpine.initTree(el);
                        }
                    });
                } catch (e: unknown) {
                    const error = e as Error;
                    this.error = error.message || "Bot not found";
                }
            },

            updateTabUrl() {
                const url = new URL(window.location.href);
                url.searchParams.set('tab', this.activeTab);
                window.history.replaceState({}, '', url.toString());
            },

            // --- Delegator methods ---
            // Bot
            async togglePause() { await togglePause(this); },
            async deleteBot() { await deleteBot(this); },
            editBot() { editBot(this); },
            async submitEditBot() { await submitEditBot(this); },
            cloneBot() { cloneBot(this); },
            async submitCloneBot() { await submitCloneBot(this); },
            async generatePublicLink() { await generatePublicLink(this); },
            async copyPublicLink() { await copyPublicLink(this); },

            // Flows
            async deleteFlow(flowId: string, flowName: string) { await deleteFlow(this, flowId, flowName); },
            async openImportModal() { await openImportModal(this); },
            async loadSourceFlows() { await loadSourceFlows(this); },
            async importFlow() { await importFlow(this); },
            async exportFlowsJson() { await exportFlowsJson(this); },
            async importFlowsJson(event: Event) { await importFlowsJson(this, event); },

            // AI Config & Notifications
            async saveAIConfig() { await saveAIConfig(this); },
            async clearConversations() { await clearConversations(this); },
            toggleIgnoredLabel(labelId: string) { toggleIgnoredLabel(this, labelId); },
            async loadNotifSessions() { await loadNotifSessions(this); },
            addNotifChannel(sessionId: string) { addNotifChannel(this, sessionId); },
            removeNotifChannel(index: number) { removeNotifChannel(this, index); },
            toggleChannelEvent(channelIdx: number, eventType: string) { toggleChannelEvent(this, channelIdx, eventType); },
            toggleChannelLabel(channelIdx: number, labelId: string) { toggleChannelLabel(this, channelIdx, labelId); },
            async saveNotifications() { await saveNotifications(this); },

            // Labels
            async syncLabels() { await syncLabels(this); },
            async createLabel() { await createLabel(this); },
            async updateLabel() { await updateLabel(this); },
            async deleteLabel(labelId: string, labelName: string) { await deleteLabel(this, labelId, labelName); },
            async moveLabelUp(labelId: string) { await moveLabelUp(this, labelId); },
            async moveLabelDown(labelId: string) { await moveLabelDown(this, labelId); },

            // Variables & Templates
            getVarValue(name: string): string { return getVarValue(this, name); },
            setVarValue(name: string, value: string) { setVarValue(this, name, value); },
            async saveVariables() { await saveVariables(this); },
            async saveTemplate() { await saveTemplate(this); },

            // Tools & Logs
            async loadTools() { await loadTools(this); },
            async convertFlowToTool(flowId: string) { await convertFlowToTool(this, flowId); },
            async loadLogs() { await loadLogs(this); },
            prevPage() { prevPage(this); },
            nextPage() { nextPage(this); },

            // Automations
            async loadAutomations() { await loadAutomations(this); },
            openCreateAutomation() { openCreateAutomation(this); },
            editAutomation(auto: any) { editAutomation(this, auto); },
            async saveAutomation() { await saveAutomation(this); },
            async toggleAutomation(autoId: string, enabled: boolean) { await toggleAutomation(this, autoId, enabled); },
            async deleteAutomation(autoId: string) { await deleteAutomation(this, autoId); },

            // Format helpers
            formatDate(dateStr: string) { return formatDate(dateStr); },
            formatTimeout(ms: number) { return formatTimeout(ms); },
            getLabelColor(colorIndex: number) { return getLabelColor(colorIndex); },
            getLabelName(labelId: string) { return getLabelName(this.botLabels, labelId); },
        }));

        // Dynamic registration of bot connection component
        const params = new URLSearchParams(window.location.search);
        const botId = params.get("id");
        if (botId) {
            const safeId = botId.replace(/-/g, "_");
            Alpine.data(`botConnection_${safeId}`, () => ({
                connected: false,
                loading: false,
                qr: null as string | null,
                sseClient: null as BotEventSource | null,

                init() {
                    this.checkStatus();

                    this.sseClient = new BotEventSource(botId!);
                    this.sseClient
                        .on('bot:qr', (data: any) => {
                            this.qr = data.qr;
                            this.connected = false;
                        })
                        .on('bot:connected', () => {
                            this.connected = true;
                            this.qr = null;
                        })
                        .on('bot:disconnected', () => {
                            this.connected = false;
                            this.qr = null;
                        });
                    this.sseClient.connect();
                },

                destroy() {
                    if (this.sseClient) this.sseClient.close();
                },

                async checkStatus() {
                    try {
                        const status = await ApiClient.get(`/bots/${botId}/status`);
                        this.connected = status.connected;
                        if (status.hasQr && !this.connected) {
                            const qrData = await ApiClient.get(`/bots/${botId}/qr`);
                            this.qr = qrData.qr;
                        } else {
                            this.qr = null;
                        }
                    } catch (e) {
                        // Silent fail for status check
                    }
                },

                async connect() {
                    this.loading = true;
                    try {
                        await ApiClient.post(`/bots/${botId}/connect`, {});
                        await this.checkStatus();
                    } catch (e: unknown) {
                        const error = e as Error;
                        window.__toast.error(error.message || "Failed to start connection");
                    } finally {
                        this.loading = false;
                    }
                },

                async disconnect() {
                    if (
                        !confirm(
                            this.$t("disconnect_confirm") ||
                                "¿Desconectar este bot de WhatsApp?",
                        )
                    )
                        return;

                    this.loading = true;
                    try {
                        await ApiClient.post(`/bots/${botId}/disconnect`, {});
                        this.connected = false;
                        this.qr = null;
                    } catch (e: unknown) {
                        const error = e as Error;
                        window.__toast.error(error.message || "Failed to disconnect");
                    } finally {
                        this.loading = false;
                    }
                },
            }));
        }
    });
</script>
