---
import Layout from "../../layouts/Layout.astro";
import SessionList from "../../components/monitor/SessionList.astro";
import ChatHeader from "../../components/monitor/ChatHeader.astro";
import NotesPanel from "../../components/monitor/NotesPanel.astro";
import MessageList from "../../components/monitor/MessageList.astro";
import ChatInput from "../../components/monitor/ChatInput.astro";
import ForceAIModal from "../../components/monitor/ForceAIModal.astro";
import RunFlowModal from "../../components/monitor/RunFlowModal.astro";
import RunToolModal from "../../components/monitor/RunToolModal.astro";
import DebugPanel from "../../components/monitor/DebugPanel.astro";
---

<Layout title="Monitor" fullWidth>
    <div
        x-data="botMonitor"
        @keydown.escape.window="if (showEmojiPicker) { showEmojiPicker = false } else if (showNotesPanel) { showNotesPanel = false } else if (showQuickReplies) { showQuickReplies = false } else if (selectedSession) { selectedSession = null }"
        @keydown.ctrl.f.prevent.window="$refs.searchInput?.focus()"
        class="h-full flex overflow-hidden md:rounded-lg"
    >
        <SessionList />

        <!-- Right: Chat panel -->
        <div
            class="flex-1 flex-col min-h-0 min-w-0"
            :class="selectedSession ? 'flex' : 'hidden md:flex'"
        >
            <!-- No session selected (empty state) -->
            <template x-if="!selectedSession">
                <div class="flex-1 flex items-center justify-center wa-chat-wallpaper">
                    <div class="text-center">
                        <div class="w-16 h-16 rounded-full bg-wa-bg-hover/50 flex items-center justify-center mx-auto mb-4">
                            <svg class="w-8 h-8 text-wa-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                            </svg>
                        </div>
                        <p class="text-sm text-wa-text-secondary">Selecciona un chat para comenzar</p>
                    </div>
                </div>
            </template>

            <!-- Session selected -->
            <template x-if="selectedSession">
                <div class="flex flex-col h-full min-h-0">
                    <ChatHeader />
                    <NotesPanel />
                    <MessageList />
                    <ChatInput />
                </div>
            </template>
        </div>

        <ForceAIModal />
        <RunFlowModal />
        <RunToolModal />
        <DebugPanel />
    </div>
</Layout>

<script>
    declare const Alpine: any;
    import { ApiClient } from "../../lib/api";
    import { BotEventSource } from "../../lib/events";
    import {
        avatarInitials, avatarColor, dateLabel, showDateSep, isLastInGroup,
        shortTime, relativeTime, formatTime, formatMessage, detectMediaType,
        getMediaUrl, labelColor,
    } from "../../lib/monitor/format-helpers";
    import { loadSessions, loadMoreSessions, onSessionsScroll, selectSession } from "../../lib/monitor/session-methods";
    import {
        loadMessages, loadMoreMessages, onChatScroll, scrollToBottom,
        sendMessage, handleFileSelect, clearAttachment, playNotifSound,
        reactToMessage, poll, buildReactionsMap,
    } from "../../lib/monitor/message-methods";
    import {
        loadDebugContext, saveNotes, toggleAI, forceAI,
        openFlowModal, executeFlow, openToolModal, executeTool,
        loadLabels, assignLabel, removeLabel, availableLabels,
    } from "../../lib/monitor/action-methods";
    import { setupSSE } from "../../lib/monitor/sse-handlers";

    document.addEventListener("alpine:init", () => {
        Alpine.data("botMonitor", () => ({
            // ── State ────────────────────────────────────────────────────
            botId: null as string | null,
            botName: "",
            sessions: [] as any[],
            selectedSession: null as any,
            messages: [] as any[],
            messageInput: "",
            searchQuery: "",
            filterLabelId: "",
            sending: false,
            unreadCounts: {} as Record<string, number>,
            typingIndicator: {} as Record<string, ReturnType<typeof setTimeout> | null>,
            typingSessions: {} as Record<string, boolean>,
            showScrollDown: false,
            showNotesPanel: false,
            sessionNotes: '',
            attachedFile: null as File | null,
            attachedUrl: '' as string,
            attachedMediaType: '' as string,
            uploadingFile: false,
            showQuickReplies: false,
            showEmojiPicker: false,
            replyingTo: null as any,
            quickReplies: [
                'Hola, gracias por tu mensaje. En un momento te atiendo.',
                'Gracias por tu compra, en breve te envio los detalles.',
                'Claro, dejame verificar y te confirmo.',
                'Listo, tu pedido ha sido procesado.',
                'Disculpa la demora, estamos trabajando en ello.',
            ],
            showForceAIModal: false,
            showFlowModal: false,
            showToolModal: false,
            showDebugPanel: false,
            debugData: null as any,
            loadingDebug: false,
            forceAIContext: "",
            selectedFlowId: "",
            selectedToolName: "",
            toolArgsJson: "{}",
            flows: [] as any[],
            tools: [] as any[],
            botLabels: [] as any[],
            loadingMore: false,
            hasMoreMessages: true,
            messageLimit: 80,
            sessionLimit: 50,
            sessionOffset: 0,
            hasMoreSessions: false,
            loadingMoreSessions: false,
            sessionsLoaded: false,
            totalSessions: 0,
            sseClient: null as BotEventSource | null,
            pollInterval: null as ReturnType<typeof setInterval> | null,
            lastMessageCount: 0,
            timeTick: 0,
            timeTickInterval: null as ReturnType<typeof setInterval> | null,

            // ── Lifecycle ────────────────────────────────────────────────
            async init() {
                const params = new URLSearchParams(window.location.search);
                this.botId = params.get("botId") || params.get("id");
                if (!this.botId) return;
                try { const bot = await ApiClient.get(`/bots/${this.botId}`); this.botName = bot.name; } catch {}
                await loadSessions(this);
                await loadLabels(this);
                this.sseClient = setupSSE(this);
                this.pollInterval = setInterval(() => poll(this), 60000);
                this.timeTickInterval = setInterval(() => { this.timeTick++; }, 30000);
            },
            destroy() {
                if (this.sseClient) this.sseClient.close();
                if (this.pollInterval) clearInterval(this.pollInterval);
                if (this.timeTickInterval) clearInterval(this.timeTickInterval);
            },
            goBack() {
                const role = JSON.parse(localStorage.getItem('user') || '{}').role;
                if (role === 'WORKER') {
                    window.location.href = '/worker';
                } else {
                    window.location.href = this.botId ? `/bots/detail?id=${this.botId}` : '/bots';
                }
            },

            // ── Delegators (one-liners to imported functions) ────────────
            avatarInitials: (name: string) => avatarInitials(name),
            avatarColor: (name: string) => avatarColor(name),
            dateLabel: (d: string) => dateLabel(d),
            showDateSep: (msgs: any[], i: number) => showDateSep(msgs, i),
            isLastInGroup: (msgs: any[], i: number) => isLastInGroup(msgs, i),
            shortTime: (d: string) => shortTime(d),
            relativeTime(d: string) { return relativeTime(d, this.timeTick); },
            formatTime: (d: string) => formatTime(d),
            formatMessage: (t: string) => formatMessage(t),
            getMediaUrl: (msg: any) => getMediaUrl(msg),
            labelColor: (c: number) => labelColor(c),
            detectMediaType: (f: File) => detectMediaType(f),

            async loadSessions() { await loadSessions(this); },
            async loadMoreSessions() { await loadMoreSessions(this); },
            onSessionsScroll(e: Event) { onSessionsScroll(this, e); },
            async selectSession(s: any) { await selectSession(this, s); },

            async loadMessages(merge = false) { await loadMessages(this, merge); },
            async loadMoreMessages() { await loadMoreMessages(this); },
            onChatScroll() { onChatScroll(this); },
            scrollToBottom() { scrollToBottom(this); },
            async sendMessage() { await sendMessage(this); },
            async handleFileSelect(e: Event) { await handleFileSelect(this, e); },
            clearAttachment() { clearAttachment(this); },
            playNotifSound() { playNotifSound(); },
            async reactToMessage(id: string, emoji: string) { await reactToMessage(this, id, emoji); },
            async poll() { await poll(this); },

            async loadDebugContext() { await loadDebugContext(this); },
            async saveNotes() { await saveNotes(this); },
            async toggleAI() { await toggleAI(this); },
            async forceAI() { await forceAI(this); },
            async openFlowModal() { await openFlowModal(this); },
            async executeFlow() { await executeFlow(this); },
            async openToolModal() { await openToolModal(this); },
            async executeTool() { await executeTool(this); },
            async loadLabels() { await loadLabels(this); },
            async assignLabel(id: string) { await assignLabel(this, id); },
            async removeLabel(id: string) { await removeLabel(this, id); },
            availableLabels() { return availableLabels(this); },
            get reactionsMap() { return buildReactionsMap(this.messages); },
            getReactions(msg: any) {
                if (!msg.externalId) return [];
                const emojis = this.reactionsMap[msg.externalId];
                if (!emojis || emojis.length === 0) return [];
                // Group: { emoji: '👍', count: 2 }
                const counts: Record<string, number> = {};
                for (const e of emojis) counts[e] = (counts[e] || 0) + 1;
                return Object.entries(counts).map(([emoji, count]) => ({ emoji, count }));
            },
        }));
    });
</script>
