---
import Layout from "../../layouts/Layout.astro";
import FinanceNav from "../../components/FinanceNav.astro";
---

<Layout title="Finance - Ingresos">
    <FinanceNav currentPath="/finance/income" />
    <main class="space-y-6" x-data="financeIncome">

        <!-- Loading -->
        <div x-show="loading" class="flex items-center justify-center py-24">
            <div class="animate-spin w-8 h-8 border-2 border-wa-green border-t-transparent rounded-full"></div>
        </div>

        <div x-show="!loading" style="display:none;">

            <!-- Header row -->
            <div class="flex flex-wrap items-center justify-between gap-4 mb-4">
                <div class="flex items-center gap-4">
                    <h2 class="text-lg font-bold" x-text="$t('fin_income_title')">Ingresos</h2>
                    <select
                        x-model="selectedPeriodId"
                        @change="loadIncomes()"
                        class="bg-wa-bg-panel border border-wa-border rounded-lg px-3 py-2 text-sm text-white focus:outline-none focus:border-wa-green"
                    >
                        <option value="">-- Periodo --</option>
                        <template x-for="p in periods" :key="p.id">
                            <option :value="p.id" x-text="p.type + ': ' + p.startDate?.split('T')[0] + ' → ' + p.endDate?.split('T')[0]"></option>
                        </template>
                    </select>
                </div>
                <button
                    @click="openModal()"
                    class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors flex items-center gap-2"
                    :disabled="!selectedPeriodId"
                    :class="!selectedPeriodId && 'opacity-50 cursor-not-allowed'"
                >
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    <span x-text="$t('fin_add_income')">Agregar Ingreso</span>
                </button>
            </div>

            <!-- No period selected -->
            <div x-show="!selectedPeriodId" class="text-center py-16 text-wa-text-secondary text-sm" style="display:none;">
                <p x-text="$t('fin_select_period')">Selecciona un periodo</p>
            </div>

            <!-- Empty state -->
            <div x-show="selectedPeriodId && incomes.length === 0 && !loadingIncomes" class="text-center py-16 text-wa-text-secondary text-sm" style="display:none;">
                <svg class="w-12 h-12 mx-auto mb-4 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <p x-text="$t('fin_no_incomes')">No hay ingresos registrados</p>
            </div>

            <!-- Loading incomes -->
            <div x-show="loadingIncomes" class="flex items-center gap-3 text-wa-text-secondary text-sm py-12 justify-center" style="display:none;">
                <div class="animate-spin w-5 h-5 border-2 border-wa-green border-t-transparent rounded-full"></div>
            </div>

            <!-- Incomes table -->
            <div x-show="selectedPeriodId && incomes.length > 0 && !loadingIncomes" class="border border-wa-border rounded-xl overflow-hidden" style="display:none;">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-wa-bg-hover text-wa-text-secondary text-xs">
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_date')">Fecha</th>
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_worker')">Trabajador</th>
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_bank_account')">Cuenta</th>
                                <th class="text-right px-4 py-3 font-medium" x-text="$t('fin_amount')">Monto</th>
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_notes')">Notas</th>
                                <th class="px-4 py-3 font-medium w-24"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="inc in incomes" :key="inc.id">
                                <tr class="border-t border-wa-border hover:bg-wa-bg-hover/50 transition-colors">
                                    <td class="px-4 py-3 text-wa-text-secondary" x-text="inc.date?.split('T')[0]"></td>
                                    <td class="px-4 py-3 font-medium text-white" x-text="inc.worker?.name || '—'"></td>
                                    <td class="px-4 py-3 text-wa-text-secondary text-xs" x-text="inc.bankAccount?.name || '—'"></td>
                                    <td class="px-4 py-3 text-right text-emerald-400 font-medium" x-text="'$' + Number(inc.amount).toFixed(2)"></td>
                                    <td class="px-4 py-3 text-wa-text-secondary text-xs max-w-[200px] truncate" x-text="inc.notes || '—'"></td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-2 justify-end">
                                            <button @click="openModal(inc)" class="p-1.5 text-wa-text-secondary hover:text-wa-green transition-colors" title="Editar">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                </svg>
                                            </button>
                                            <button @click="deleteIncome(inc)" class="p-1.5 text-wa-text-secondary hover:text-red-400 transition-colors" title="Eliminar">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
                <!-- Total row -->
                <div class="border-t border-wa-border bg-wa-bg-hover px-4 py-3 flex justify-between items-center">
                    <span class="text-xs text-wa-text-secondary" x-text="incomes.length + ' registros'"></span>
                    <span class="text-sm font-bold text-emerald-400" x-text="'Total: $' + incomes.reduce((s, i) => s + Number(i.amount), 0).toFixed(2)"></span>
                </div>
            </div>
        </div>

        <!-- Create/Edit Modal -->
        <div
            x-show="showModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            @keydown.escape.window="showModal = false"
            style="display:none;"
        >
            <div
                class="bg-wa-bg-panel border border-wa-border rounded-xl w-full max-w-md mx-4 p-6"
                @click.outside="showModal = false"
            >
                <h3 class="text-lg font-bold mb-4" x-text="editing ? $t('fin_edit_income') : $t('fin_add_income')">Ingreso</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_worker')">Trabajador</label>
                        <select
                            x-model="form.workerId"
                            class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white"
                        >
                            <option value="">-- Seleccionar --</option>
                            <template x-for="w in activeWorkers" :key="w.id">
                                <option :value="w.id" x-text="w.name"></option>
                            </template>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_bank_account')">Cuenta Bancaria</label>
                        <select
                            x-model="form.bankAccountId"
                            class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white"
                        >
                            <option value="">-- Seleccionar --</option>
                            <template x-for="b in bankAccounts" :key="b.id">
                                <option :value="b.id" x-text="b.name + ' (' + b.bankName + ')'"></option>
                            </template>
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_amount')">Monto</label>
                            <input
                                type="number"
                                step="0.01"
                                x-model.number="form.amount"
                                class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white"
                                placeholder="0.00"
                            />
                        </div>
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_date')">Fecha</label>
                            <input
                                type="date"
                                x-model="form.date"
                                class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white"
                            />
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_notes')">Notas</label>
                        <input
                            type="text"
                            x-model="form.notes"
                            class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white"
                            placeholder="Opcional"
                        />
                    </div>
                </div>

                <div class="flex justify-end gap-3 mt-6">
                    <button
                        @click="showModal = false"
                        class="px-4 py-2 border border-wa-border text-sm text-wa-text-secondary rounded-lg hover:bg-wa-bg-hover transition-colors"
                        x-text="$t('fin_cancel')"
                    >Cancelar</button>
                    <button
                        @click="saveIncome()"
                        class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors"
                        :disabled="saving"
                        x-text="saving ? '...' : $t('fin_save')"
                    >Guardar</button>
                </div>
            </div>
        </div>

    </main>
</Layout>

<script>
    document.addEventListener("alpine:init", () => {
        const Alpine = (window as any).Alpine;
        const ApiClient = (window as any).ApiClient;

        Alpine.data("financeIncome", () => ({
            loading: true,
            loadingIncomes: false,
            periods: [] as any[],
            selectedPeriodId: "",
            incomes: [] as any[],
            activeWorkers: [] as any[],
            bankAccounts: [] as any[],
            showModal: false,
            editing: null as any,
            saving: false,
            form: { workerId: "", bankAccountId: "", amount: 0, date: "", notes: "" },

            async init() {
                try {
                    const [periods, workers, banks] = await Promise.all([
                        ApiClient.get("/finance/periods"),
                        ApiClient.get("/finance/workers?active=true"),
                        ApiClient.get("/finance/bank-accounts"),
                    ]);
                    this.periods = periods;
                    this.activeWorkers = workers;
                    this.bankAccounts = banks;

                    const open = this.periods.find((p: any) => p.status === "OPEN");
                    if (open) {
                        this.selectedPeriodId = open.id;
                        await this.loadIncomes();
                    }
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.loading = false;
                }
            },

            async loadIncomes() {
                if (!this.selectedPeriodId) { this.incomes = []; return; }
                this.loadingIncomes = true;
                try {
                    this.incomes = await ApiClient.get(`/finance/incomes?periodId=${this.selectedPeriodId}`);
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.loadingIncomes = false;
                }
            },

            openModal(income?: any) {
                if (income) {
                    this.editing = income;
                    this.form = {
                        workerId: income.workerId || "",
                        bankAccountId: income.bankAccountId || "",
                        amount: income.amount,
                        date: income.date?.split("T")[0] || "",
                        notes: income.notes || "",
                    };
                } else {
                    this.editing = null;
                    this.form = {
                        workerId: "",
                        bankAccountId: "",
                        amount: 0,
                        date: new Date().toISOString().split("T")[0],
                        notes: "",
                    };
                }
                this.showModal = true;
            },

            async saveIncome() {
                if (!this.form.workerId || !this.form.amount) return;
                this.saving = true;
                try {
                    const payload = { ...this.form, periodId: this.selectedPeriodId };
                    if (this.editing) {
                        await ApiClient.put(`/finance/incomes/${this.editing.id}`, payload);
                        (window as any).__toast.success("Ingreso actualizado");
                    } else {
                        await ApiClient.post("/finance/incomes", payload);
                        (window as any).__toast.success("Ingreso registrado");
                    }
                    this.showModal = false;
                    await this.loadIncomes();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.saving = false;
                }
            },

            async deleteIncome(income: any) {
                if (!confirm("Eliminar este ingreso?")) return;
                try {
                    await ApiClient.delete(`/finance/incomes/${income.id}`);
                    (window as any).__toast.success("Ingreso eliminado");
                    await this.loadIncomes();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                }
            },
        }));
    });
</script>
