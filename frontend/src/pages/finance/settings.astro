---
import Layout from "../../layouts/Layout.astro";
import FinanceNav from "../../components/FinanceNav.astro";
---

<Layout title="Finance - Config">
    <FinanceNav currentPath="/finance/settings" />
    <main class="space-y-6" x-data="financeSettings">

        <!-- Loading -->
        <div x-show="loading" class="flex items-center justify-center py-24">
            <div class="animate-spin w-8 h-8 border-2 border-wa-green border-t-transparent rounded-full"></div>
        </div>

        <div x-show="!loading" style="display:none;">

            <!-- ========================================================== -->
            <!-- SECTION 1: Bank Accounts                                   -->
            <!-- ========================================================== -->
            <section class="bg-wa-bg-panel border border-wa-border rounded-xl p-5">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-sm font-bold" x-text="$t('fin_bank_accounts')">Cuentas Bancarias</h3>
                    <button
                        @click="openBankModal()"
                        class="px-3 py-1.5 bg-wa-green hover:bg-wa-green-hover text-white text-xs font-medium rounded-lg transition-colors flex items-center gap-1.5"
                    >
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        <span x-text="$t('fin_add')">Agregar</span>
                    </button>
                </div>

                <!-- Empty -->
                <div x-show="bankAccounts.length === 0" class="text-center py-8 text-wa-text-secondary text-sm" style="display:none;">
                    <p x-text="$t('fin_no_bank_accounts')">No hay cuentas bancarias</p>
                </div>

                <!-- Table -->
                <div x-show="bankAccounts.length > 0" class="border border-wa-border rounded-xl overflow-hidden" style="display:none;">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-wa-bg-hover text-wa-text-secondary text-xs">
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_name')">Nombre</th>
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_bank_name')">Banco</th>
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_identifier')">Identificador</th>
                                <th class="px-4 py-3 font-medium w-24"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="b in bankAccounts" :key="b.id">
                                <tr class="border-t border-wa-border hover:bg-wa-bg-hover/50 transition-colors">
                                    <td class="px-4 py-3 font-medium text-white" x-text="b.name"></td>
                                    <td class="px-4 py-3 text-wa-text-secondary" x-text="b.bankName"></td>
                                    <td class="px-4 py-3 text-wa-text-secondary text-xs font-mono" x-text="b.identifier || '—'"></td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-2 justify-end">
                                            <button @click="openBankModal(b)" class="p-1.5 text-wa-text-secondary hover:text-wa-green transition-colors">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                </svg>
                                            </button>
                                            <button @click="deleteBank(b)" class="p-1.5 text-wa-text-secondary hover:text-red-400 transition-colors">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- ========================================================== -->
            <!-- SECTION 2: Periods                                         -->
            <!-- ========================================================== -->
            <section class="bg-wa-bg-panel border border-wa-border rounded-xl p-5">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-sm font-bold" x-text="$t('fin_periods')">Periodos</h3>
                    <button
                        @click="openPeriodModal()"
                        class="px-3 py-1.5 bg-wa-green hover:bg-wa-green-hover text-white text-xs font-medium rounded-lg transition-colors flex items-center gap-1.5"
                    >
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        <span x-text="$t('fin_add')">Agregar</span>
                    </button>
                </div>

                <!-- Empty -->
                <div x-show="periods.length === 0" class="text-center py-8 text-wa-text-secondary text-sm" style="display:none;">
                    <p x-text="$t('fin_no_periods')">No hay periodos</p>
                </div>

                <!-- Table -->
                <div x-show="periods.length > 0" class="border border-wa-border rounded-xl overflow-hidden" style="display:none;">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-wa-bg-hover text-wa-text-secondary text-xs">
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_type')">Tipo</th>
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_start_date')">Inicio</th>
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_end_date')">Fin</th>
                                <th class="text-center px-4 py-3 font-medium" x-text="$t('fin_status')">Estado</th>
                                <th class="px-4 py-3 font-medium w-32"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="p in periods" :key="p.id">
                                <tr class="border-t border-wa-border hover:bg-wa-bg-hover/50 transition-colors">
                                    <td class="px-4 py-3 font-medium text-white" x-text="p.type"></td>
                                    <td class="px-4 py-3 text-wa-text-secondary" x-text="p.startDate?.split('T')[0]"></td>
                                    <td class="px-4 py-3 text-wa-text-secondary" x-text="p.endDate?.split('T')[0]"></td>
                                    <td class="px-4 py-3 text-center">
                                        <span
                                            class="px-2 py-0.5 rounded-full text-[10px] font-medium"
                                            :class="p.status === 'OPEN' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-wa-bg-hover text-wa-text-secondary'"
                                            x-text="p.status"
                                        ></span>
                                    </td>
                                    <td class="px-4 py-3">
                                        <button
                                            x-show="p.status === 'OPEN'"
                                            @click="closePeriod(p)"
                                            class="px-3 py-1 text-xs border border-yellow-500/30 text-yellow-400 rounded-lg hover:bg-yellow-500/10 transition-colors"
                                            x-text="$t('fin_close_period')"
                                        >Cerrar</button>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- ========================================================== -->
            <!-- SECTION 3: Expenses                                        -->
            <!-- ========================================================== -->
            <section class="bg-wa-bg-panel border border-wa-border rounded-xl p-5">
                <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
                    <div class="flex items-center gap-3">
                        <h3 class="text-sm font-bold" x-text="$t('fin_expenses')">Gastos Fijos</h3>
                        <select
                            x-model="expensePeriodId"
                            @change="loadExpenses()"
                            class="bg-wa-bg-deep border border-wa-border rounded-lg px-2 py-1.5 text-xs text-white focus:outline-none focus:border-wa-green"
                        >
                            <option value="">-- Periodo --</option>
                            <template x-for="p in periods" :key="p.id">
                                <option :value="p.id" x-text="p.type + ': ' + p.startDate?.split('T')[0] + ' → ' + p.endDate?.split('T')[0]"></option>
                            </template>
                        </select>
                    </div>
                    <button
                        @click="openExpenseModal()"
                        class="px-3 py-1.5 bg-wa-green hover:bg-wa-green-hover text-white text-xs font-medium rounded-lg transition-colors flex items-center gap-1.5"
                        :disabled="!expensePeriodId"
                        :class="!expensePeriodId && 'opacity-50 cursor-not-allowed'"
                    >
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        <span x-text="$t('fin_add')">Agregar</span>
                    </button>
                </div>

                <!-- No period -->
                <div x-show="!expensePeriodId" class="text-center py-6 text-wa-text-secondary text-xs" style="display:none;">
                    <p>Selecciona un periodo</p>
                </div>

                <!-- Loading expenses -->
                <div x-show="loadingExpenses" class="flex items-center gap-2 text-wa-text-secondary text-sm py-6 justify-center" style="display:none;">
                    <div class="animate-spin w-4 h-4 border-2 border-wa-green border-t-transparent rounded-full"></div>
                </div>

                <!-- Empty -->
                <div x-show="expensePeriodId && !loadingExpenses && expenses.length === 0" class="text-center py-6 text-wa-text-secondary text-xs" style="display:none;">
                    <p x-text="$t('fin_no_expenses')">No hay gastos</p>
                </div>

                <!-- Table -->
                <div x-show="expensePeriodId && !loadingExpenses && expenses.length > 0" class="border border-wa-border rounded-xl overflow-hidden" style="display:none;">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-wa-bg-hover text-wa-text-secondary text-xs">
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_description')">Descripcion</th>
                                <th class="text-right px-4 py-3 font-medium" x-text="$t('fin_amount')">Monto</th>
                                <th class="text-left px-4 py-3 font-medium" x-text="$t('fin_date')">Fecha</th>
                                <th class="px-4 py-3 font-medium w-24"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <template x-for="exp in expenses" :key="exp.id">
                                <tr class="border-t border-wa-border hover:bg-wa-bg-hover/50 transition-colors">
                                    <td class="px-4 py-3 font-medium text-white" x-text="exp.description"></td>
                                    <td class="px-4 py-3 text-right text-orange-400 font-medium" x-text="'$' + Number(exp.amount).toFixed(2)"></td>
                                    <td class="px-4 py-3 text-wa-text-secondary" x-text="exp.date?.split('T')[0]"></td>
                                    <td class="px-4 py-3">
                                        <div class="flex items-center gap-2 justify-end">
                                            <button @click="openExpenseModal(exp)" class="p-1.5 text-wa-text-secondary hover:text-wa-green transition-colors">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                                </svg>
                                            </button>
                                            <button @click="deleteExpense(exp)" class="p-1.5 text-wa-text-secondary hover:text-red-400 transition-colors">
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            </template>
                        </tbody>
                    </table>
                    <!-- Total -->
                    <div class="border-t border-wa-border bg-wa-bg-hover px-4 py-3 flex justify-between items-center">
                        <span class="text-xs text-wa-text-secondary" x-text="expenses.length + ' gastos'"></span>
                        <span class="text-sm font-bold text-orange-400" x-text="'Total: $' + expenses.reduce((s, e) => s + Number(e.amount), 0).toFixed(2)"></span>
                    </div>
                </div>
            </section>

        </div>

        <!-- ============================================================== -->
        <!-- Bank Account Modal                                             -->
        <!-- ============================================================== -->
        <div
            x-show="showBankModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            @keydown.escape.window="showBankModal = false"
            style="display:none;"
        >
            <div class="bg-wa-bg-panel border border-wa-border rounded-xl w-full max-w-md mx-4 p-6" @click.outside="showBankModal = false">
                <h3 class="text-lg font-bold mb-4" x-text="editingBank ? $t('fin_edit_bank') : $t('fin_add_bank')">Cuenta Bancaria</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_name')">Nombre</label>
                        <input type="text" x-model="bankForm.name" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="ej: Cuenta Personal" />
                    </div>
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_bank_name')">Banco</label>
                        <input type="text" x-model="bankForm.bankName" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="ej: Banesco" />
                    </div>
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_identifier')">Identificador</label>
                        <input type="text" x-model="bankForm.identifier" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="Nro cuenta, email, etc" />
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button @click="showBankModal = false" class="px-4 py-2 border border-wa-border text-sm text-wa-text-secondary rounded-lg hover:bg-wa-bg-hover transition-colors" x-text="$t('fin_cancel')">Cancelar</button>
                    <button @click="saveBank()" class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors" :disabled="savingBank" x-text="savingBank ? '...' : $t('fin_save')">Guardar</button>
                </div>
            </div>
        </div>

        <!-- ============================================================== -->
        <!-- Period Modal                                                   -->
        <!-- ============================================================== -->
        <div
            x-show="showPeriodModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            @keydown.escape.window="showPeriodModal = false"
            style="display:none;"
        >
            <div class="bg-wa-bg-panel border border-wa-border rounded-xl w-full max-w-md mx-4 p-6" @click.outside="showPeriodModal = false">
                <h3 class="text-lg font-bold mb-4" x-text="$t('fin_new_period')">Nuevo Periodo</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_type')">Tipo</label>
                        <select x-model="periodForm.type" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white">
                            <option value="WEEKLY">WEEKLY</option>
                            <option value="MONTHLY">MONTHLY</option>
                        </select>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_start_date')">Inicio</label>
                            <input type="date" x-model="periodForm.startDate" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" />
                        </div>
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_end_date')">Fin</label>
                            <input type="date" x-model="periodForm.endDate" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" />
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button @click="showPeriodModal = false" class="px-4 py-2 border border-wa-border text-sm text-wa-text-secondary rounded-lg hover:bg-wa-bg-hover transition-colors" x-text="$t('fin_cancel')">Cancelar</button>
                    <button @click="savePeriod()" class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors" :disabled="savingPeriod" x-text="savingPeriod ? '...' : $t('fin_save')">Guardar</button>
                </div>
            </div>
        </div>

        <!-- ============================================================== -->
        <!-- Expense Modal                                                  -->
        <!-- ============================================================== -->
        <div
            x-show="showExpenseModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150"
            x-transition:leave-start="opacity-100"
            x-transition:leave-end="opacity-0"
            @keydown.escape.window="showExpenseModal = false"
            style="display:none;"
        >
            <div class="bg-wa-bg-panel border border-wa-border rounded-xl w-full max-w-md mx-4 p-6" @click.outside="showExpenseModal = false">
                <h3 class="text-lg font-bold mb-4" x-text="editingExpense ? $t('fin_edit_expense') : $t('fin_add_expense')">Gasto</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_description')">Descripcion</label>
                        <input type="text" x-model="expenseForm.description" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="ej: Hosting VPS" />
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_amount')">Monto</label>
                            <input type="number" step="0.01" x-model.number="expenseForm.amount" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="0.00" />
                        </div>
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_date')">Fecha</label>
                            <input type="date" x-model="expenseForm.date" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" />
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button @click="showExpenseModal = false" class="px-4 py-2 border border-wa-border text-sm text-wa-text-secondary rounded-lg hover:bg-wa-bg-hover transition-colors" x-text="$t('fin_cancel')">Cancelar</button>
                    <button @click="saveExpense()" class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors" :disabled="savingExpense" x-text="savingExpense ? '...' : $t('fin_save')">Guardar</button>
                </div>
            </div>
        </div>

    </main>
</Layout>

<script>
    document.addEventListener("alpine:init", () => {
        const Alpine = (window as any).Alpine;
        const ApiClient = (window as any).ApiClient;

        Alpine.data("financeSettings", () => ({
            loading: true,

            // Bank Accounts
            bankAccounts: [] as any[],
            showBankModal: false,
            editingBank: null as any,
            savingBank: false,
            bankForm: { name: "", bankName: "", identifier: "" },

            // Periods
            periods: [] as any[],
            showPeriodModal: false,
            savingPeriod: false,
            periodForm: { type: "WEEKLY", startDate: "", endDate: "" },

            // Expenses
            expenses: [] as any[],
            expensePeriodId: "",
            loadingExpenses: false,
            showExpenseModal: false,
            editingExpense: null as any,
            savingExpense: false,
            expenseForm: { description: "", amount: 0, date: "" },

            async init() {
                try {
                    const [banks, periods] = await Promise.all([
                        ApiClient.get("/finance/bank-accounts"),
                        ApiClient.get("/finance/periods"),
                    ]);
                    this.bankAccounts = banks;
                    this.periods = periods;
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.loading = false;
                }
            },

            // ── Bank Accounts ───────────────────────────────────
            openBankModal(bank?: any) {
                if (bank) {
                    this.editingBank = bank;
                    this.bankForm = { name: bank.name, bankName: bank.bankName, identifier: bank.identifier || "" };
                } else {
                    this.editingBank = null;
                    this.bankForm = { name: "", bankName: "", identifier: "" };
                }
                this.showBankModal = true;
            },

            async saveBank() {
                if (!this.bankForm.name.trim() || !this.bankForm.bankName.trim()) return;
                this.savingBank = true;
                try {
                    if (this.editingBank) {
                        await ApiClient.put(`/finance/bank-accounts/${this.editingBank.id}`, this.bankForm);
                        (window as any).__toast.success("Cuenta actualizada");
                    } else {
                        await ApiClient.post("/finance/bank-accounts", this.bankForm);
                        (window as any).__toast.success("Cuenta creada");
                    }
                    this.showBankModal = false;
                    this.bankAccounts = await ApiClient.get("/finance/bank-accounts");
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingBank = false;
                }
            },

            async deleteBank(bank: any) {
                if (!confirm(`Eliminar cuenta "${bank.name}"?`)) return;
                try {
                    await ApiClient.delete(`/finance/bank-accounts/${bank.id}`);
                    (window as any).__toast.success("Cuenta eliminada");
                    this.bankAccounts = await ApiClient.get("/finance/bank-accounts");
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                }
            },

            // ── Periods ─────────────────────────────────────────
            openPeriodModal() {
                const today = new Date();
                const fmt = (d: Date) => d.toISOString().split("T")[0];
                this.periodForm = { type: "WEEKLY", startDate: fmt(today), endDate: "" };
                this.showPeriodModal = true;
            },

            async savePeriod() {
                if (!this.periodForm.startDate || !this.periodForm.endDate) return;
                this.savingPeriod = true;
                try {
                    await ApiClient.post("/finance/periods", this.periodForm);
                    (window as any).__toast.success("Periodo creado");
                    this.showPeriodModal = false;
                    this.periods = await ApiClient.get("/finance/periods");
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingPeriod = false;
                }
            },

            async closePeriod(period: any) {
                if (!confirm(`Cerrar periodo ${period.type} ${period.startDate?.split("T")[0]}?`)) return;
                try {
                    await ApiClient.post(`/finance/periods/${period.id}/close`, {});
                    (window as any).__toast.success("Periodo cerrado");
                    this.periods = await ApiClient.get("/finance/periods");
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                }
            },

            // ── Expenses ────────────────────────────────────────
            async loadExpenses() {
                if (!this.expensePeriodId) { this.expenses = []; return; }
                this.loadingExpenses = true;
                try {
                    this.expenses = await ApiClient.get(`/finance/expenses?periodId=${this.expensePeriodId}`);
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.loadingExpenses = false;
                }
            },

            openExpenseModal(expense?: any) {
                if (expense) {
                    this.editingExpense = expense;
                    this.expenseForm = {
                        description: expense.description,
                        amount: expense.amount,
                        date: expense.date?.split("T")[0] || "",
                    };
                } else {
                    this.editingExpense = null;
                    this.expenseForm = {
                        description: "",
                        amount: 0,
                        date: new Date().toISOString().split("T")[0],
                    };
                }
                this.showExpenseModal = true;
            },

            async saveExpense() {
                if (!this.expenseForm.description.trim() || !this.expenseForm.amount) return;
                this.savingExpense = true;
                try {
                    const payload = { ...this.expenseForm, periodId: this.expensePeriodId };
                    if (this.editingExpense) {
                        await ApiClient.put(`/finance/expenses/${this.editingExpense.id}`, payload);
                        (window as any).__toast.success("Gasto actualizado");
                    } else {
                        await ApiClient.post("/finance/expenses", payload);
                        (window as any).__toast.success("Gasto registrado");
                    }
                    this.showExpenseModal = false;
                    await this.loadExpenses();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingExpense = false;
                }
            },

            async deleteExpense(expense: any) {
                if (!confirm("Eliminar este gasto?")) return;
                try {
                    await ApiClient.delete(`/finance/expenses/${expense.id}`);
                    (window as any).__toast.success("Gasto eliminado");
                    await this.loadExpenses();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                }
            },
        }));
    });
</script>
