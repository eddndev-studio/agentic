                                <select x-model="boostForm.country" class="w-full bg-wa-bg-panel border border-wa-border rounded p-1.5 text-xs text-white focus:outline-none">
                                    <option value="MX">Mexico</option><option value="US">USA</option><option value="CO">Colombia</option>
                                    <option value="AR">Argentina</option><option value="ES">Espana</option>
                                </select>
