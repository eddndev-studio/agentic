                </div>

                <!-- No posts -->
                <div x-show="boostPageId && !loadingPosts && pagePosts.length === 0" class="text-center py-8 text-wa-text-secondary text-sm" style="display:none;">
                    <p x-text="$t('fin_fb_no_posts')">No se encontraron publicaciones</p>
