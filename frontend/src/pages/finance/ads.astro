                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_daily_budget')">Presupuesto Diario</label>
                            <input type="number" step="0.01" x-model.number="adSetForm.dailyBudget" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="0.00" />
                        </div>
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_optimization_goal')">Optimizacion</label>
                            <select x-model="adSetForm.optimizationGoal" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white">
                                <option value="REACH">Alcance</option>
                                <option value="LINK_CLICKS">Clicks en Enlace</option>
                                <option value="IMPRESSIONS">Impresiones</option>
                                <option value="CONVERSATIONS">Conversaciones</option>
                                <option value="LANDING_PAGE_VIEWS">Vistas de Pagina</option>
                            </select>
                        </div>
                    </div>

                    <!-- Schedule -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_start_time')">Inicio</label>
                            <input type="datetime-local" x-model="adSetForm.startTime" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" />
                        </div>
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_end_time')">Fin</label>
                            <input type="datetime-local" x-model="adSetForm.endTime" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" />
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button @click="showAdSetModal = false" class="px-4 py-2 border border-wa-border text-sm text-wa-text-secondary rounded-lg hover:bg-wa-bg-hover transition-colors" x-text="$t('fin_cancel')">Cancelar</button>
                    <button @click="saveAdSet()" class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors" :disabled="savingAdSet" x-text="savingAdSet ? $t('fin_fb_creating') : $t('fin_save')">Guardar</button>
                </div>
            </div>
        </div>

        <!-- ============================================================== -->
        <!-- Ad Creation Modal                                              -->
        <!-- ============================================================== -->
        <div
            x-show="showAdModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
            @keydown.escape.window="showAdModal = false"
            style="display:none;"
        >
            <div class="bg-wa-bg-panel border border-wa-border rounded-xl w-full max-w-lg mx-4 p-6 max-h-[90vh] overflow-y-auto" @click.outside="showAdModal = false">
                <h3 class="text-lg font-bold mb-4" x-text="$t('fin_fb_new_ad')">Nuevo Anuncio</h3>
                <div class="space-y-4">
                    <!-- Name -->
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1">Nombre</label>
                        <input type="text" x-model="adForm.name" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="Nombre del anuncio" />
                    </div>
                    <!-- Page -->
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_page')">Pagina</label>
                        <select x-model="adForm.pageId" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white">
                            <option value="">-- Seleccionar --</option>
                            <template x-for="page in fbPages" :key="page.id">
                                <option :value="page.id" x-text="page.name"></option>
                            </template>
                        </select>
                    </div>
                    <!-- Link URL -->
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_link_url')">URL</label>
                        <input type="url" x-model="adForm.link" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="https://..." />
                    </div>
                    <!-- Message -->
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_message_text')">Texto</label>
                        <textarea x-model="adForm.message" rows="3" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white resize-none" placeholder="Texto del anuncio..."></textarea>
                    </div>
                    <!-- Headline + CTA -->
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_headline')">Titulo</label>
                            <input type="text" x-model="adForm.headline" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="Titulo del anuncio" />
                        </div>
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_cta')">CTA</label>
                            <select x-model="adForm.cta" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white">
                                <option value="LEARN_MORE">Mas Info</option>
                                <option value="SEND_MESSAGE">Enviar Mensaje</option>
                                <option value="SHOP_NOW">Comprar</option>
                                <option value="SIGN_UP">Registrarse</option>
                                <option value="CONTACT_US">Contactar</option>
                                <option value="BOOK_TRAVEL">Reservar</option>
                                <option value="GET_QUOTE">Cotizar</option>
                                <option value="WHATSAPP_MESSAGE">WhatsApp</option>
                            </select>
                        </div>
                    </div>
                    <!-- Image URL (optional) -->
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1">Imagen URL (opcional)</label>
                        <input type="url" x-model="adForm.imageUrl" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="https://..." />
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button @click="showAdModal = false" class="px-4 py-2 border border-wa-border text-sm text-wa-text-secondary rounded-lg hover:bg-wa-bg-hover transition-colors" x-text="$t('fin_cancel')">Cancelar</button>
                    <button @click="saveAd()" class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors" :disabled="savingAd" x-text="savingAd ? $t('fin_fb_creating') : $t('fin_save')">Guardar</button>
                </div>
            </div>
        </div>

    </main>
</Layout>

<script>
    import { ApiClient } from "../../lib/api";
    const FB_APP_ID = (import.meta as any).env?.PUBLIC_FB_APP_ID || "1184660606783733";

    document.addEventListener("alpine:init", () => {
        const Alpine = (window as any).Alpine;

        Alpine.data("financeAds", () => ({
            loading: true,
            fbReady: false,
            connection: null as any,
            syncing: false,

            // Ad accounts
            adAccounts: [] as any[],
            activeWorkers: [] as any[],
            loadingAdAccounts: false,

            // Campaign browser
            selectedAdAccountId: "",
            datePreset: "last_7d" as "last_7d" | "last_30d" | "custom",
            customFrom: "",
            customTo: "",
            showCustomRange: false,
            campaigns: [] as any[],
            loadingCampaigns: false,
            workerSpend: [] as any[],

            // Expandable state
            expandedCampaigns: {} as Record<string, boolean>,
            adSets: {} as Record<string, any[]>,
            loadingAdSets: {} as Record<string, boolean>,
            expandedAdSets: {} as Record<string, boolean>,
            ads: {} as Record<string, any[]>,
            loadingAds: {} as Record<string, boolean>,

            // Status toggle
            togglingStatus: {} as Record<string, boolean>,

            // Budget edit
            showBudgetModal: false,
            budgetTarget: null as any,
            budgetForm: { dailyBudget: 0, lifetimeBudget: 0 },
            savingBudget: false,

            // Campaign creation
            showCampaignModal: false,
            campaignForm: {
                name: "", objective: "OUTCOME_ENGAGEMENT", status: "PAUSED",
                specialAdCategory: "NONE", buyingType: "AUCTION",
                dailyBudget: 0, startTime: "", endTime: "",
            },
            savingCampaign: false,

            // AdSet creation
            showAdSetModal: false,
            adSetTargetCampaignId: "",
            adSetForm: {
                name: "", countries: [] as string[], ageMin: 18, ageMax: 65,
                gender: 0, interests: [] as any[], dailyBudget: 0,
                optimizationGoal: "REACH", startTime: "", endTime: "",
            },
            savingAdSet: false,
            interestQuery: "",
            interestResults: [] as any[],

            // Boost posts
            boostPageId: "",
            pagePosts: [] as any[],
            loadingPosts: false,
            showBoostModal: false,
            boostPost: null as any,
            boostForm: { adAccountId: "", dailyBudget: 5, duration: 7, country: "MX", ageMin: 18, ageMax: 65, gender: 0 },
            boosting: false,

            // Ad creation
            showAdModal: false,
            adTargetAdSetId: "",
            adForm: {
                name: "", pageId: "", link: "", message: "",
                headline: "", cta: "LEARN_MORE", imageUrl: "",
            },
            savingAd: false,
            fbPages: [] as any[],

            async init() {
                try {
                    const [conn, workers] = await Promise.all([
                        ApiClient.get("/finance/facebook/connection").catch(() => null),
                        ApiClient.get("/finance/workers?active=true"),
                    ]);
                    this.connection = conn?.connected ? conn : null;
                    this.activeWorkers = workers;

                    if (this.connection) {
                        await this.loadAdAccounts();
                        this.loadFbPages(); // non-blocking
                    }

                    // Init Facebook SDK in background
                    this.initFbSdk().then(() => { this.fbReady = true; }).catch(() => { this.fbReady = true; });
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.loading = false;
                }
            },

            // ── Facebook SDK ────────────────────────────────────
            initFbSdk(): Promise<void> {
                return new Promise((resolve, reject) => {
                    if ((window as any).FB) {
                        (window as any).FB.init({ appId: FB_APP_ID, cookie: true, xfbml: false, version: "v21.0" });
                        resolve();
                        return;
                    }

                    const timeout = setTimeout(() => reject(new Error("Facebook SDK timeout")), 15000);

                    (window as any).fbAsyncInit = function () {
                        clearTimeout(timeout);
                        (window as any).FB.init({ appId: FB_APP_ID, cookie: true, xfbml: false, version: "v21.0" });
                        resolve();
                    };

                    if (document.querySelector('script[src*="connect.facebook.net"]')) return;

                    const script = document.createElement("script");
                    script.src = "https://connect.facebook.net/en_US/sdk.js";
                    script.async = true;
                    script.onerror = () => { clearTimeout(timeout); reject(new Error("FB SDK load error")); };
                    document.head.appendChild(script);
                });
            },

            fbLogin() {
                const FB = (window as any).FB;
                if (!FB) return;
                const self = this;
                FB.login(
                    (response: any) => {
                        if (response.authResponse) {
                            const { accessToken, userID } = response.authResponse;
                            (async () => {
                                let userName = "";
                                try {
                                    const res = await fetch(`https://graph.facebook.com/v21.0/me?fields=name&access_token=${accessToken}`);
                                    const data = await res.json();
                                    userName = data.name || "";
                                } catch {}

                                try {
                                    self.connection = await ApiClient.post("/finance/facebook/connect", {
                                        shortLivedToken: accessToken,
                                        fbUserId: userID,
                                        fbUserName: userName,
                                    });
                                    (window as any).__toast.success("Facebook conectado");
                                    await self.loadAdAccounts();
                                } catch (e: any) {
                                    (window as any).__toast.error(e.message);
                                }
                            })();
                        }
                    },
                    { scope: "ads_read,ads_management" }
                );
            },

            async disconnectFacebook() {
                if (!confirm("Desconectar Facebook?")) return;
                try {
                    await ApiClient.post("/finance/facebook/disconnect", {});
                    this.connection = null;
                    this.adAccounts = [];
                    this.campaigns = [];
                    this.workerSpend = [];
                    (window as any).__toast.success("Facebook desconectado");
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                }
            },

            async syncFacebook() {
                this.syncing = true;
                try {
                    const result = await ApiClient.post("/finance/facebook/sync", {});
                    this.connection = { ...this.connection, ...result };
                    (window as any).__toast.success("Sincronizacion completada");
                    await this.loadAdAccounts();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.syncing = false;
                }
            },

            // ── Ad Accounts ─────────────────────────────────────
            async loadAdAccounts() {
                this.loadingAdAccounts = true;
                try {
                    this.adAccounts = await ApiClient.get("/finance/facebook/ad-accounts");
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.loadingAdAccounts = false;
                }
            },

            async assignWorker(adAccountId: string, workerId: string) {
                try {
                    if (workerId) {
                        await ApiClient.put(`/finance/facebook/ad-accounts/${adAccountId}/assign`, { workerId });
                        (window as any).__toast.success("Worker asignado");
                    } else {
                        await ApiClient.put(`/finance/facebook/ad-accounts/${adAccountId}/unassign`, {});
                        (window as any).__toast.success("Worker desasignado");
                    }
                    await this.loadAdAccounts();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                }
            },

            async unassignWorker(adAccountId: string) {
                try {
                    await ApiClient.put(`/finance/facebook/ad-accounts/${adAccountId}/unassign`, {});
                    (window as any).__toast.success("Worker desasignado");
                    await this.loadAdAccounts();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                }
            },

            // ── Campaign Browser ────────────────────────────────
            setDatePreset(preset: "last_7d" | "last_30d") {
                this.datePreset = preset;
                this.showCustomRange = false;
                this.loadCampaigns();
            },

            buildDateRange(): { since: string; until: string } {
                const today = new Date();
                const fmt = (d: Date) => d.toISOString().split("T")[0];
                if (this.datePreset === "custom" && this.customFrom && this.customTo) {
                    return { since: this.customFrom, until: this.customTo };
                }
                const days = this.datePreset === "last_30d" ? 30 : 7;
                const since = new Date(today);
                since.setDate(since.getDate() - days);
                return { since: fmt(since), until: fmt(today) };
            },

            async loadCampaigns() {
                if (!this.selectedAdAccountId) return;
                this.loadingCampaigns = true;
                this.campaigns = [];
                this.expandedCampaigns = {};
                this.adSets = {};
                this.ads = {};
                this.workerSpend = [];

                const { since, until } = this.buildDateRange();
                try {
                    const [campaigns, insights, spend] = await Promise.all([
                        ApiClient.get(`/finance/facebook/campaigns?adAccountId=${this.selectedAdAccountId}`),
                        ApiClient.get(`/finance/facebook/insights?adAccountId=${this.selectedAdAccountId}&since=${since}&until=${until}&level=CAMPAIGN`).catch(() => []),
                        ApiClient.get(`/finance/facebook/worker-spend?since=${since}&until=${until}`).catch(() => []),
                    ]);

                    // Merge insights into campaigns
                    const insightMap: Record<string, any> = {};
                    (insights || []).forEach((i: any) => { insightMap[i.campaignId || i.id] = i; });

                    this.campaigns = (campaigns || []).map((c: any) => {
                        const ins = insightMap[c.id] || {};
                        return { ...c, spend: ins.spend || 0, impressions: ins.impressions || 0, clicks: ins.clicks || 0 };
                    });

                    this.workerSpend = spend || [];
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.loadingCampaigns = false;
                }
            },

            async toggleCampaign(campaign: any) {
                if (this.expandedCampaigns[campaign.id]) {
                    this.expandedCampaigns[campaign.id] = false;
                    return;
                }
                this.expandedCampaigns[campaign.id] = true;

                if (this.adSets[campaign.id]) return; // already loaded
                this.loadingAdSets[campaign.id] = true;
                try {
                    this.adSets[campaign.id] = await ApiClient.get(`/finance/facebook/campaigns/${campaign.id}/adsets`);
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                    this.adSets[campaign.id] = [];
                } finally {
                    this.loadingAdSets[campaign.id] = false;
                }
            },

            async toggleAdSet(adset: any) {
                if (this.expandedAdSets[adset.id]) {
                    this.expandedAdSets[adset.id] = false;
                    return;
                }
                this.expandedAdSets[adset.id] = true;

                if (this.ads[adset.id]) return;
                this.loadingAds[adset.id] = true;
                try {
                    this.ads[adset.id] = await ApiClient.get(`/finance/facebook/adsets/${adset.id}/ads`);
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                    this.ads[adset.id] = [];
                } finally {
                    this.loadingAds[adset.id] = false;
                }
            },

            // ── Status Toggle ──────────────────────────────────
            async toggleStatus(type: string, item: any) {
                const newStatus = item.status === "ACTIVE" ? "PAUSED" : "ACTIVE";
                const oldStatus = item.status;
                this.togglingStatus[item.id] = true;
                item.status = newStatus; // optimistic
                try {
                    await ApiClient.post(`/finance/facebook/${type}/${item.id}/status`, { status: newStatus });
                    (window as any).__toast.success("Estado actualizado");
                } catch (e: any) {
                    item.status = oldStatus; // revert
                    (window as any).__toast.error(e.message);
                } finally {
                    this.togglingStatus[item.id] = false;
                }
            },

            // ── Budget Edit ────────────────────────────────────
            openBudgetModal(type: string, item: any) {
                this.budgetTarget = { type, id: item.id, name: item.name, dailyBudget: item.dailyBudget || 0, lifetimeBudget: item.lifetimeBudget || 0 };
                this.budgetForm = { dailyBudget: item.dailyBudget || 0, lifetimeBudget: item.lifetimeBudget || 0 };
                this.showBudgetModal = true;
            },

            async saveBudget() {
                if (!this.budgetTarget) return;
                this.savingBudget = true;
                try {
                    await ApiClient.put(`/finance/facebook/${this.budgetTarget.type}/${this.budgetTarget.id}/budget`, this.budgetForm);
                    (window as any).__toast.success("Presupuesto actualizado");
                    this.showBudgetModal = false;
                    await this.loadCampaigns();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingBudget = false;
                }
            },

            // ── Campaign Creation ──────────────────────────────
            openCampaignModal() {
                this.campaignForm = {
                    name: "", objective: "OUTCOME_ENGAGEMENT", status: "PAUSED",
                    specialAdCategory: "NONE", buyingType: "AUCTION",
                    dailyBudget: 0, startTime: "", endTime: "",
                };
                this.showCampaignModal = true;
            },

            async saveCampaign() {
                if (!this.campaignForm.name.trim()) return;
                this.savingCampaign = true;
                try {
                    await ApiClient.post("/finance/facebook/campaigns/create", {
                        adAccountId: this.selectedAdAccountId,
                        name: this.campaignForm.name,
                        objective: this.campaignForm.objective,
                        status: this.campaignForm.status,
                        specialAdCategories: [this.campaignForm.specialAdCategory],
                        buyingType: this.campaignForm.buyingType,
                        dailyBudget: this.campaignForm.dailyBudget || undefined,
                        startTime: this.campaignForm.startTime || undefined,
                        endTime: this.campaignForm.endTime || undefined,
                    });
                    (window as any).__toast.success("Campana creada");
                    this.showCampaignModal = false;
                    await this.loadCampaigns();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingCampaign = false;
                }
            },
            // ── Boost Posts ─────────────────────────────────
            async loadFbPages() {
                try {
                    this.fbPages = await ApiClient.get("/finance/facebook/pages");
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                }
            },

            async loadPagePosts() {
                if (!this.boostPageId) { this.pagePosts = []; return; }
                this.loadingPosts = true;
                try {
                    this.pagePosts = await ApiClient.get(`/finance/facebook/pages/${this.boostPageId}/posts`);
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.loadingPosts = false;
                }
            },

            openBoostModal(post: any) {
                this.boostPost = post;
                this.boostForm = {
                    adAccountId: this.adAccounts[0]?.id || "",
                    dailyBudget: 5, duration: 7,
                    country: "MX", ageMin: 18, ageMax: 65, gender: 0,
                };
                this.showBoostModal = true;
                // Load pages if needed
                if (this.fbPages.length === 0) this.loadFbPages();
            },

            async submitBoost() {
                if (!this.boostForm.adAccountId || !this.boostForm.dailyBudget || !this.boostForm.duration) return;
                this.boosting = true;
                try {
                    await ApiClient.post("/finance/facebook/boost", {
                        adAccountId: this.boostForm.adAccountId,
                        postId: this.boostPost.id,
                        pageId: this.boostPageId,
                        dailyBudget: this.boostForm.dailyBudget,
                        duration: this.boostForm.duration,
                        targeting: {
                            countries: [this.boostForm.country],
                            ageMin: this.boostForm.ageMin,
                            ageMax: this.boostForm.ageMax,
                            gender: this.boostForm.gender,
                        },
                    });
                    (window as any).__toast.success("Publicacion promovida exitosamente");
                    this.showBoostModal = false;
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.boosting = false;
                }
            },

            // ── AdSet Creation ──────────────────────────────
            openAdSetModal(campaignId: string) {
                this.adSetTargetCampaignId = campaignId;
                this.adSetForm = {
                    name: "", countries: ["MX"], ageMin: 18, ageMax: 65,
                    gender: 0, interests: [], dailyBudget: 0,
                    optimizationGoal: "REACH", startTime: "", endTime: "",
                };
                this.interestQuery = "";
                this.interestResults = [];
                this.showAdSetModal = true;
            },

            async searchInterests() {
                if (this.interestQuery.length < 2) { this.interestResults = []; return; }
                try {
                    this.interestResults = await ApiClient.get(`/finance/facebook/interests?q=${encodeURIComponent(this.interestQuery)}`);
                } catch { this.interestResults = []; }
            },

            addInterest(interest: any) {
                if (!this.adSetForm.interests.find((i: any) => i.id === interest.id)) {
                    this.adSetForm.interests.push(interest);
                }
                this.interestQuery = "";
                this.interestResults = [];
            },

            async saveAdSet() {
                if (!this.adSetForm.name.trim() || this.adSetForm.countries.length === 0) return;
                this.savingAdSet = true;
                try {
                    const targeting: any = {
                        geo_locations: { countries: this.adSetForm.countries },
                        age_min: this.adSetForm.ageMin,
                        age_max: this.adSetForm.ageMax,
                    };
                    if (this.adSetForm.gender > 0) targeting.genders = [this.adSetForm.gender];
                    if (this.adSetForm.interests.length > 0) {
                        targeting.flexible_spec = [{ interests: this.adSetForm.interests.map((i: any) => ({ id: i.id, name: i.name })) }];
                    }

                    await ApiClient.post("/finance/facebook/adsets/create", {
                        campaignId: this.adSetTargetCampaignId,
                        name: this.adSetForm.name,
                        status: "PAUSED",
                        targeting,
                        dailyBudget: this.adSetForm.dailyBudget || undefined,
                        optimizationGoal: this.adSetForm.optimizationGoal,
                        billingEvent: "IMPRESSIONS",
                        startTime: this.adSetForm.startTime || undefined,
                        endTime: this.adSetForm.endTime || undefined,
                    });
                    (window as any).__toast.success("Conjunto de anuncios creado");
                    this.showAdSetModal = false;
                    // Refresh adsets for this campaign
                    this.adSets[this.adSetTargetCampaignId] = await ApiClient.get(`/finance/facebook/campaigns/${this.adSetTargetCampaignId}/adsets`);
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingAdSet = false;
                }
            },

            // ── Ad Creation ────────────────────────────────────
            openAdModal(adSetId: string) {
                this.adTargetAdSetId = adSetId;
                this.adForm = { name: "", pageId: "", link: "", message: "", headline: "", cta: "LEARN_MORE", imageUrl: "" };
                this.showAdModal = true;
                // Load pages if not loaded
                if (this.fbPages.length === 0) {
                    ApiClient.get("/finance/facebook/pages").then((pages: any) => { this.fbPages = pages; }).catch(() => {});
                }
            },

            async saveAd() {
                if (!this.adForm.name.trim() || !this.adForm.pageId || !this.adForm.link) return;
                this.savingAd = true;
                try {
                    const linkData: any = {
                        link: this.adForm.link,
                        message: this.adForm.message,
                    };
                    if (this.adForm.headline) linkData.name = this.adForm.headline;
                    if (this.adForm.cta) linkData.call_to_action = { type: this.adForm.cta, value: { link: this.adForm.link } };

                    await ApiClient.post("/finance/facebook/ads/create", {
                        adSetId: this.adTargetAdSetId,
                        name: this.adForm.name,
                        status: "PAUSED",
                        creative: {
                            objectStorySpec: {
                                page_id: this.adForm.pageId,
                                link_data: linkData,
                            },
                        },
                    });
                    (window as any).__toast.success("Anuncio creado");
                    this.showAdModal = false;
                    // Refresh ads for this adset
                    this.ads[this.adTargetAdSetId] = await ApiClient.get(`/finance/facebook/adsets/${this.adTargetAdSetId}/ads`);
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingAd = false;
                }
            },
        }));
    });
</script>
