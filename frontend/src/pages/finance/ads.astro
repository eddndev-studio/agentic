            <!-- ========================================================== -->
            <!-- SECTION 4: Boost Posts                                     -->
            <!-- ========================================================== -->
            <section class="bg-wa-bg-panel border border-wa-border rounded-xl p-5" x-show="connection" style="display:none;">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-sm font-bold" x-text="$t('fin_fb_boost_posts')">Promover Publicaciones</h3>
                    <div class="flex items-center gap-2">
                        <select x-model="boostPageId" @change="loadPagePosts()" class="bg-wa-bg-deep border border-wa-border rounded-lg px-2 py-1.5 text-xs text-white focus:outline-none focus:border-wa-green">
                            <option value="">-- Pagina --</option>
                            <template x-for="page in fbPages" :key="page.id">
                                <option :value="page.id" x-text="page.name"></option>
                            </template>
                        </select>
                        <button x-show="!boostPageId && fbPages.length === 0" @click="loadFbPages()" class="px-3 py-1.5 bg-wa-bg-deep border border-wa-border text-xs text-wa-text-secondary rounded-lg hover:text-white transition-colors" style="display:none;" x-text="$t('fin_fb_load_posts')">Cargar</button>
                    </div>
                </div>

