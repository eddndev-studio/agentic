---
import Layout from "../../layouts/Layout.astro";
import FinanceNav from "../../components/FinanceNav.astro";
---

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<Layout title="Finance - Detalle Campaña">
    <FinanceNav currentPath="/finance/campaign-detail" />
    <main class="space-y-6" x-data="campaignDetail">

        <!-- Loading -->
        <div x-show="loading" class="flex items-center justify-center py-24">
            <div class="animate-spin w-8 h-8 border-2 border-wa-green border-t-transparent rounded-full"></div>
        </div>

        <div x-show="!loading && campaign" class="space-y-6" style="display:none;">

            <!-- Back link -->
            <a href="/finance/campaigns" class="inline-flex items-center gap-1 text-xs text-wa-text-secondary hover:text-wa-green transition-colors mb-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
                <span x-text="$t('fin_campaign_back')">Volver a campanas</span>
            </a>

            <!-- Campaign Header -->
            <div class="bg-wa-bg-panel border border-wa-border rounded-xl p-5">
                <div class="flex flex-wrap items-start justify-between gap-4">
                    <div>
                        <div class="flex items-center gap-2 mb-2">
                            <h1 class="text-xl font-bold text-white" x-text="campaign.name"></h1>
                            <button @click="openNameModal()" class="p-1 text-wa-text-secondary hover:text-wa-green transition-colors" title="Editar nombre">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                            </button>
                        </div>
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="px-2 py-0.5 rounded text-[10px] font-medium bg-wa-bg-hover text-wa-text-secondary"
                                x-text="campaign.objective?.replace('OUTCOME_', '') || '—'"></span>
                            <span class="px-2 py-0.5 rounded text-[10px] font-medium bg-wa-bg-hover text-wa-text-secondary"
                                x-text="campaign.buyingType || 'AUCTION'"></span>
                            <span x-show="campaign.dailyBudget" class="text-xs text-wa-text-secondary"
                                x-text="'$' + Number(campaign.dailyBudget || 0).toFixed(0) + '/dia'"></span>
                            <button @click="openBudgetModal()" class="p-1 text-wa-text-secondary hover:text-wa-green transition-colors" title="Editar presupuesto">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                            </button>
                        </div>
                    </div>
                    <!-- Status toggle -->
                    <button @click="toggleCampaignStatus()"
                        class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-xs font-medium transition-colors"
                        :class="campaign.status === 'ACTIVE' ? 'bg-emerald-500/10 text-emerald-400 hover:bg-emerald-500/20' : 'bg-yellow-500/10 text-yellow-400 hover:bg-yellow-500/20'"
                        :disabled="togglingStatus">
                        <span class="w-2 h-2 rounded-full" :class="campaign.status === 'ACTIVE' ? 'bg-emerald-400' : 'bg-yellow-400'"></span>
                        <span x-text="campaign.status"></span>
                    </button>
                </div>

                <!-- Metrics -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-4 pt-4 border-t border-wa-border/50">
                    <div>
                        <div class="text-[10px] text-wa-text-secondary uppercase">Gasto</div>
                        <div class="text-lg font-medium text-white" x-text="'$' + Number(campaign.spend || 0).toFixed(2)"></div>
                    </div>
                    <div>
                        <div class="text-[10px] text-wa-text-secondary uppercase">Impressions</div>
                        <div class="text-lg font-medium text-white" x-text="Number(campaign.impressions || 0).toLocaleString()"></div>
                    </div>
                    <div>
                        <div class="text-[10px] text-wa-text-secondary uppercase">Clicks</div>
                        <div class="text-lg font-medium text-white" x-text="Number(campaign.clicks || 0).toLocaleString()"></div>
                    </div>
                    <div>
                        <div class="text-[10px] text-wa-text-secondary uppercase">Reach</div>
                        <div class="text-lg font-medium text-white" x-text="Number(campaign.reach || 0).toLocaleString()"></div>
                    </div>
                </div>
            </div>

            <!-- ========================================================== -->
            <!-- Ad Sets                                                    -->
            <!-- ========================================================== -->
            <div class="flex items-center justify-between">
                <h2 class="text-sm font-bold text-white" x-text="$t('fin_campaign_adsets') + ' (' + adSets.length + ')'">Conjuntos de Anuncios</h2>
                <button @click="showAdSetModal = true"
                    class="px-3 py-1.5 bg-wa-green hover:bg-wa-green-hover text-white text-xs font-medium rounded-lg transition-colors flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                    <span x-text="$t('fin_campaign_new_adset')">Nuevo Conjunto</span>
                </button>
            </div>

            <!-- Loading adsets -->
            <div x-show="loadingAdSets" class="flex items-center justify-center py-8" style="display:none;">
                <div class="animate-spin w-5 h-5 border-2 border-wa-green border-t-transparent rounded-full"></div>
            </div>

            <!-- Empty -->
            <div x-show="!loadingAdSets && adSets.length === 0" class="text-center py-10 text-wa-text-secondary text-sm bg-wa-bg-panel border border-wa-border rounded-xl" style="display:none;">
                <p x-text="$t('fin_campaign_no_adsets')">Sin conjuntos de anuncios</p>
            </div>

            <!-- AdSet Cards -->
            <template x-for="adset in adSets" :key="adset.id">
                <div class="bg-wa-bg-panel border border-wa-border rounded-xl overflow-hidden">
                    <!-- AdSet header -->
                    <div class="p-4">
                        <div class="flex items-start justify-between mb-2">
                            <div>
                                <h3 class="text-sm font-medium text-white" x-text="adset.name"></h3>
                                <div class="flex flex-wrap items-center gap-2 mt-1 text-[10px] text-wa-text-secondary">
                                    <span x-text="adset.optimizationGoal || 'REACH'"></span>
                                    <span>&middot;</span>
                                    <span x-text="adset.billingEvent || 'IMPRESSIONS'"></span>
                                    <span x-show="adset.dailyBudget" x-text="'$' + Number(adset.dailyBudget || 0).toFixed(0) + '/dia'"></span>
                                </div>
                            </div>
                            <div class="flex items-center gap-2">
                                <button @click="toggleAdSetStatus(adset)"
                                    class="flex items-center gap-1 px-2 py-0.5 rounded-full text-[9px] font-medium transition-colors"
                                    :class="adset.status === 'ACTIVE' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-yellow-500/10 text-yellow-400'"
                                    :disabled="togglingAdSetStatus[adset.id]">
                                    <span class="w-1.5 h-1.5 rounded-full" :class="adset.status === 'ACTIVE' ? 'bg-emerald-400' : 'bg-yellow-400'"></span>
                                    <span x-text="adset.status"></span>
                                </button>
                            </div>
                        </div>

                        <!-- Targeting summary -->
                        <div x-show="adset.targeting" class="text-[10px] text-wa-text-secondary bg-wa-bg-deep rounded-lg px-3 py-2 mt-2" style="display:none;">
                            <span x-text="formatTargeting(adset.targeting)"></span>
                        </div>
                    </div>

                    <!-- Ads within this adset -->
                    <div class="border-t border-wa-border/50">
                        <div class="flex items-center justify-between px-4 py-2 bg-wa-bg-deep/30">
                            <span class="text-[10px] text-wa-text-secondary uppercase tracking-wider">Anuncios</span>
                            <button @click="openAdModal(adset.id)" class="text-[10px] text-wa-green hover:text-wa-green-hover transition-colors flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                                <span x-text="$t('fin_campaign_new_ad')">Nuevo Anuncio</span>
                            </button>
                        </div>

                        <!-- Ad list -->
                        <template x-for="ad in (ads[adset.id] || [])" :key="ad.id">
                            <div class="flex items-center px-4 py-2.5 border-t border-wa-border/30 hover:bg-wa-bg-hover/30 transition-colors">
                                <div class="flex-1 min-w-0">
                                    <span class="text-xs text-white" x-text="ad.name"></span>
                                </div>
                                <button @click="toggleAdStatus(ad)"
                                    class="flex items-center gap-1 px-2 py-0.5 rounded-full text-[9px] font-medium transition-colors"
                                    :class="ad.status === 'ACTIVE' ? 'bg-emerald-500/10 text-emerald-400' : 'bg-yellow-500/10 text-yellow-400'"
                                    :disabled="togglingAdStatus[ad.id]">
                                    <span class="w-1.5 h-1.5 rounded-full" :class="ad.status === 'ACTIVE' ? 'bg-emerald-400' : 'bg-yellow-400'"></span>
                                    <span x-text="ad.status"></span>
                                </button>
                            </div>
                        </template>

                        <div x-show="!ads[adset.id] || ads[adset.id].length === 0" class="px-4 py-3 text-[10px] text-wa-text-secondary" style="display:none;">
                            <span x-text="$t('fin_campaign_no_ads')">Sin anuncios</span>
                        </div>
                    </div>
                </div>
            </template>
        </div>

        <!-- ============================================================== -->
        <!-- Campaign Name Edit Modal                                       -->
        <!-- ============================================================== -->
        <div x-show="showNameModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
            @keydown.escape.window="showNameModal = false" style="display:none;">
            <div class="bg-wa-bg-panel border border-wa-border rounded-xl w-full max-w-sm mx-4 p-6" @click.outside="showNameModal = false">
                <h3 class="text-lg font-bold mb-4">Editar Nombre</h3>
                <div>
                    <label class="block text-xs text-wa-text-secondary mb-1">Nombre de la campaña</label>
                    <input type="text" x-model="nameForm.name"
                        @keydown.enter.prevent="saveName()"
                        class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white"
                        placeholder="Nombre de la campaña" />
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button @click="showNameModal = false" class="px-4 py-2 border border-wa-border text-sm text-wa-text-secondary rounded-lg hover:bg-wa-bg-hover transition-colors">Cancelar</button>
                    <button @click="saveName()" class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors" :disabled="savingName || !nameForm.name.trim()" x-text="savingName ? '...' : 'Guardar'">Guardar</button>
                </div>
            </div>
        </div>

        <!-- ============================================================== -->
        <!-- Budget Edit Modal                                              -->
        <!-- ============================================================== -->
        <div x-show="showBudgetModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
            @keydown.escape.window="showBudgetModal = false" style="display:none;">
            <div class="bg-wa-bg-panel border border-wa-border rounded-xl w-full max-w-sm mx-4 p-6" @click.outside="showBudgetModal = false">
                <h3 class="text-lg font-bold mb-4" x-text="$t('fin_fb_edit_budget')">Editar Presupuesto</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_daily_budget')">Presupuesto Diario</label>
                        <input type="number" step="0.01" x-model.number="budgetForm.dailyBudget" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="0.00" />
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button @click="showBudgetModal = false" class="px-4 py-2 border border-wa-border text-sm text-wa-text-secondary rounded-lg hover:bg-wa-bg-hover transition-colors">Cancelar</button>
                    <button @click="saveBudget()" class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors" :disabled="savingBudget" x-text="savingBudget ? '...' : $t('fin_save')">Guardar</button>
                </div>
            </div>
        </div>

        <!-- ============================================================== -->
        <!-- AdSet Creation Modal                                           -->
        <!-- ============================================================== -->
        <div x-show="showAdSetModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
            @keydown.escape.window="showAdSetModal = false" style="display:none;">
            <div class="bg-wa-bg-panel border border-wa-border rounded-xl w-full max-w-2xl mx-4 p-6 max-h-[90vh] overflow-y-auto" @click.outside="showAdSetModal = false">
                <h3 class="text-lg font-bold mb-4" x-text="$t('fin_campaign_new_adset')">Nuevo Conjunto de Anuncios</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1">Nombre</label>
                        <input type="text" x-model="adSetForm.name" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="Nombre del conjunto" />
                    </div>
                    <div class="bg-wa-bg-deep border border-wa-border rounded-lg p-4 space-y-3">
                        <h4 class="text-xs font-bold text-wa-text-secondary uppercase tracking-wider" x-text="$t('fin_fb_targeting')">Segmentacion</h4>
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_location')">Ubicaciones</label>
                            <input type="text" x-model="locationQuery" @input.debounce.300ms="searchLocations()"
                                class="w-full bg-wa-bg-panel border border-wa-border rounded-lg p-2 text-sm focus:border-wa-green focus:outline-none text-white"
                                placeholder="Buscar ciudad, region o pais..." />
                            <div x-show="locationResults.length > 0" class="mt-1 bg-wa-bg-panel border border-wa-border rounded-lg max-h-40 overflow-y-auto" style="display:none;">
                                <template x-for="loc in locationResults" :key="loc.key + loc.type">
                                    <button @click="addLocation(loc)" class="w-full text-left px-3 py-2 text-xs text-white hover:bg-wa-bg-hover transition-colors flex justify-between items-center border-b border-wa-border/30 last:border-0">
                                        <div>
                                            <span x-text="loc.name" class="font-medium"></span>
                                            <span x-show="loc.region && loc.type === 'city'" class="text-wa-text-secondary" x-text="', ' + loc.region"></span>
                                            <span x-show="loc.countryName" class="text-wa-text-secondary" x-text="' — ' + loc.countryName"></span>
                                        </div>
                                        <span class="px-1.5 py-0.5 rounded text-[9px] bg-wa-bg-hover text-wa-text-secondary shrink-0 ml-2"
                                            x-text="loc.type === 'city' ? 'Ciudad' : loc.type === 'region' ? 'Region' : 'Pais'"></span>
                                    </button>
                                </template>
                            </div>
                            <div class="space-y-1.5 mt-2">
                                <template x-for="(loc, idx) in adSetForm.locations" :key="loc.key + loc.type">
                                    <div class="flex items-center gap-2 bg-wa-bg-panel/50 rounded-lg px-2 py-1.5">
                                        <span class="w-2 h-2 rounded-full shrink-0" :class="loc.type === 'city' ? 'bg-blue-400' : loc.type === 'region' ? 'bg-purple-400' : 'bg-wa-green'"></span>
                                        <span class="text-xs text-white flex-1 truncate" x-text="loc.name + (loc.type === 'city' && loc.region ? ', ' + loc.region : '')"></span>
                                        <template x-if="loc.type === 'city'">
                                            <div class="flex items-center gap-1 shrink-0">
                                                <input type="number" min="1" max="80" :value="loc.radius || 40" @change="loc.radius = Number($event.target.value); updateMap()"
                                                    class="w-14 bg-wa-bg-deep border border-wa-border rounded p-1 text-[10px] text-white text-center" />
                                                <span class="text-[10px] text-wa-text-secondary">km</span>
                                            </div>
                                        </template>
                                        <button @click="adSetForm.locations.splice(idx, 1); updateMap()" class="text-wa-text-secondary hover:text-red-400 text-xs shrink-0">&times;</button>
                                    </div>
                                </template>
                            </div>
                            <div x-show="adSetForm.locations.length > 0" class="mt-3 rounded-lg overflow-hidden border border-wa-border" style="display:none;">
                                <div id="targeting-map" style="height: 200px; width: 100%; background: #1a1a2e;"></div>
                            </div>
                        </div>
                        <div class="grid grid-cols-3 gap-3">
                            <div>
                                <label class="block text-xs text-wa-text-secondary mb-1">Edad Min</label>
                                <input type="number" x-model.number="adSetForm.ageMin" min="18" max="65" class="w-full bg-wa-bg-panel border border-wa-border rounded-lg p-2 text-sm focus:border-wa-green focus:outline-none text-white" />
                            </div>
                            <div>
                                <label class="block text-xs text-wa-text-secondary mb-1">Edad Max</label>
                                <input type="number" x-model.number="adSetForm.ageMax" min="18" max="65" class="w-full bg-wa-bg-panel border border-wa-border rounded-lg p-2 text-sm focus:border-wa-green focus:outline-none text-white" />
                            </div>
                            <div>
                                <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_gender')">Genero</label>
                                <select x-model.number="adSetForm.gender" class="w-full bg-wa-bg-panel border border-wa-border rounded-lg p-2 text-sm focus:border-wa-green focus:outline-none text-white">
                                    <option value="0">Todos</option><option value="1">Hombre</option><option value="2">Mujer</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_interests')">Intereses</label>
                            <input type="text" x-model="interestQuery" @input.debounce.300ms="searchInterests()" class="w-full bg-wa-bg-panel border border-wa-border rounded-lg p-2 text-sm focus:border-wa-green focus:outline-none text-white" :placeholder="$t('fin_fb_search_interests')" />
                            <div x-show="interestResults.length > 0" class="mt-1 bg-wa-bg-panel border border-wa-border rounded-lg max-h-32 overflow-y-auto" style="display:none;">
                                <template x-for="interest in interestResults" :key="interest.id">
                                    <button @click="addInterest(interest)" class="w-full text-left px-3 py-1.5 text-xs text-white hover:bg-wa-bg-hover transition-colors flex justify-between">
                                        <span x-text="interest.name"></span>
                                        <span class="text-wa-text-secondary" x-text="interest.audienceSize ? Number(interest.audienceSize).toLocaleString() : ''"></span>
                                    </button>
                                </template>
                            </div>
                            <div class="flex flex-wrap gap-1 mt-2">
                                <template x-for="(interest, idx) in adSetForm.interests" :key="interest.id">
                                    <span class="px-2 py-0.5 bg-purple-500/10 text-purple-400 text-xs rounded-full flex items-center gap-1">
                                        <span x-text="interest.name"></span>
                                        <button @click="adSetForm.interests.splice(idx, 1)" class="hover:text-red-400">&times;</button>
                                    </span>
                                </template>
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_daily_budget')">Presupuesto Diario</label>
                            <input type="number" step="0.01" x-model.number="adSetForm.dailyBudget" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="0.00" />
                        </div>
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_optimization_goal')">Optimizacion</label>
                            <select x-model="adSetForm.optimizationGoal" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white">
                                <option value="REACH">Alcance</option><option value="LINK_CLICKS">Clicks</option>
                                <option value="IMPRESSIONS">Impresiones</option><option value="CONVERSATIONS">Conversaciones</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button @click="showAdSetModal = false" class="px-4 py-2 border border-wa-border text-sm text-wa-text-secondary rounded-lg hover:bg-wa-bg-hover transition-colors">Cancelar</button>
                    <button @click="saveAdSet()" class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors" :disabled="savingAdSet" x-text="savingAdSet ? $t('fin_fb_creating') : $t('fin_save')">Guardar</button>
                </div>
            </div>
        </div>

        <!-- ============================================================== -->
        <!-- Ad Creation Modal                                              -->
        <!-- ============================================================== -->
        <div x-show="showAdModal"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm"
            x-transition:enter="transition ease-out duration-200" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
            x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
            @keydown.escape.window="showAdModal = false" style="display:none;">
            <div class="bg-wa-bg-panel border border-wa-border rounded-xl w-full max-w-lg mx-4 p-6 max-h-[90vh] overflow-y-auto" @click.outside="showAdModal = false">
                <h3 class="text-lg font-bold mb-4" x-text="$t('fin_campaign_new_ad')">Nuevo Anuncio</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1">Nombre</label>
                        <input type="text" x-model="adForm.name" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="Nombre del anuncio" />
                    </div>
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_page')">Pagina</label>
                        <select x-model="adForm.pageId" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white">
                            <option value="">-- Seleccionar --</option>
                            <template x-for="page in fbPages" :key="page.id">
                                <option :value="page.id" x-text="page.name"></option>
                            </template>
                        </select>
                    </div>
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_link_url')">URL</label>
                        <input type="url" x-model="adForm.link" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="https://..." />
                    </div>
                    <div>
                        <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_message_text')">Texto</label>
                        <textarea x-model="adForm.message" rows="3" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white resize-none" placeholder="Texto del anuncio..."></textarea>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_headline')">Titulo</label>
                            <input type="text" x-model="adForm.headline" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="Titulo" />
                        </div>
                        <div>
                            <label class="block text-xs text-wa-text-secondary mb-1" x-text="$t('fin_fb_cta')">CTA</label>
                            <select x-model="adForm.cta" class="w-full bg-wa-bg-deep border border-wa-border rounded-lg p-2.5 text-sm focus:border-wa-green focus:outline-none text-white">
                                <option value="LEARN_MORE">Mas Info</option><option value="SEND_MESSAGE">Enviar Mensaje</option>
                                <option value="SHOP_NOW">Comprar</option><option value="SIGN_UP">Registrarse</option>
                                <option value="CONTACT_US">Contactar</option><option value="WHATSAPP_MESSAGE">WhatsApp</option>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="flex justify-end gap-3 mt-6">
                    <button @click="showAdModal = false" class="px-4 py-2 border border-wa-border text-sm text-wa-text-secondary rounded-lg hover:bg-wa-bg-hover transition-colors">Cancelar</button>
                    <button @click="saveAd()" class="px-4 py-2 bg-wa-green hover:bg-wa-green-hover text-white text-sm font-medium rounded-lg transition-colors" :disabled="savingAd" x-text="savingAd ? $t('fin_fb_creating') : $t('fin_save')">Guardar</button>
                </div>
            </div>
        </div>

    </main>
</Layout>

<script>
    import { ApiClient } from "../../lib/api";

    document.addEventListener("alpine:init", () => {
        const Alpine = (window as any).Alpine;

        Alpine.data("campaignDetail", () => ({
            loading: true,
            campaignId: null as string | null,
            adAccountId: null as string | null,
            campaign: null as any,
            adSets: [] as any[],
            ads: {} as Record<string, any[]>,
            loadingAdSets: false,
            togglingStatus: false,
            togglingAdSetStatus: {} as Record<string, boolean>,
            togglingAdStatus: {} as Record<string, boolean>,

            // Campaign name
            showNameModal: false,
            nameForm: { name: "" },
            savingName: false,

            // Budget
            showBudgetModal: false,
            budgetForm: { dailyBudget: 0 },
            savingBudget: false,

            // AdSet creation
            showAdSetModal: false,
            adSetForm: { name: "", locations: [] as any[], ageMin: 18, ageMax: 65, gender: 0, interests: [] as any[], dailyBudget: 0, optimizationGoal: "REACH" },
            savingAdSet: false,
            locationQuery: "",
            locationResults: [] as any[],
            interestQuery: "",
            interestResults: [] as any[],
            _map: null as any,
            _mapMarkers: [] as any[],

            // Ad creation
            showAdModal: false,
            adTargetAdSetId: "",
            adForm: { name: "", pageId: "", link: "", message: "", headline: "", cta: "LEARN_MORE" },
            savingAd: false,
            fbPages: [] as any[],

            async init() {
                const params = new URLSearchParams(window.location.search);
                this.campaignId = params.get("id");
                this.adAccountId = params.get("adAccountId");

                if (!this.campaignId) { window.location.href = "/finance/campaigns"; return; }

                try {
                    // Load campaign + insights
                    const [campaigns, insights] = await Promise.all([
                        ApiClient.get(`/finance/facebook/campaigns?adAccountId=${this.adAccountId}`),
                        ApiClient.get(`/finance/facebook/insights?adAccountId=${this.adAccountId}&level=CAMPAIGN`).catch(() => []),
                    ]);

                    const camp = (campaigns || []).find((c: any) => c.id === this.campaignId);
                    if (!camp) { window.location.href = "/finance/campaigns"; return; }

                    const ins = (insights || []).find((i: any) => i.campaignId === this.campaignId) || {};
                    this.campaign = { ...camp, spend: ins.spend || 0, impressions: ins.impressions || 0, clicks: ins.clicks || 0, reach: ins.reach || 0 };

                    // Load adsets + ads eagerly
                    await this.loadAdSets();

                    // Load FB pages in background
                    ApiClient.get("/finance/facebook/pages").then((p: any) => { this.fbPages = p; }).catch(() => {});
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.loading = false;
                }
            },

            async loadAdSets() {
                this.loadingAdSets = true;
                try {
                    this.adSets = await ApiClient.get(`/finance/facebook/campaigns/${this.campaignId}/adsets`);
                    // Load ads for each adset
                    for (const adset of this.adSets) {
                        this.ads[adset.id] = await ApiClient.get(`/finance/facebook/adsets/${adset.id}/ads`).catch(() => []);
                    }
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.loadingAdSets = false;
                }
            },

            formatTargeting(targeting: any): string {
                if (!targeting) return "";
                const parts: string[] = [];
                const geo = targeting.geo_locations || {};
                if (geo.countries?.length) parts.push(geo.countries.join(", "));
                if (geo.cities?.length) parts.push(geo.cities.map((c: any) => c.name || c.key).join(", "));
                if (geo.regions?.length) parts.push(geo.regions.map((r: any) => r.name || r.key).join(", "));
                if (targeting.age_min || targeting.age_max) parts.push(`${targeting.age_min || 18}-${targeting.age_max || 65}`);
                if (targeting.genders?.length) parts.push(targeting.genders.includes(1) ? "Hombres" : targeting.genders.includes(2) ? "Mujeres" : "Todos");
                if (targeting.flexible_spec?.[0]?.interests?.length) {
                    parts.push("Intereses: " + targeting.flexible_spec[0].interests.map((i: any) => i.name).join(", "));
                }
                return parts.join(" | ") || "Sin segmentación";
            },

            // Status toggles
            async toggleCampaignStatus() {
                const newStatus = this.campaign.status === "ACTIVE" ? "PAUSED" : "ACTIVE";
                const old = this.campaign.status;
                this.togglingStatus = true;
                this.campaign.status = newStatus;
                try {
                    await ApiClient.post(`/finance/facebook/campaigns/${this.campaignId}/status`, { status: newStatus });
                    (window as any).__toast.success("Estado actualizado");
                } catch (e: any) {
                    this.campaign.status = old;
                    (window as any).__toast.error(e.message);
                } finally {
                    this.togglingStatus = false;
                }
            },

            async toggleAdSetStatus(adset: any) {
                const newStatus = adset.status === "ACTIVE" ? "PAUSED" : "ACTIVE";
                const old = adset.status;
                this.togglingAdSetStatus[adset.id] = true;
                adset.status = newStatus;
                try {
                    await ApiClient.post(`/finance/facebook/adsets/${adset.id}/status`, { status: newStatus });
                } catch (e: any) {
                    adset.status = old;
                    (window as any).__toast.error(e.message);
                } finally {
                    this.togglingAdSetStatus[adset.id] = false;
                }
            },

            async toggleAdStatus(ad: any) {
                const newStatus = ad.status === "ACTIVE" ? "PAUSED" : "ACTIVE";
                const old = ad.status;
                this.togglingAdStatus[ad.id] = true;
                ad.status = newStatus;
                try {
                    await ApiClient.post(`/finance/facebook/ads/${ad.id}/status`, { status: newStatus });
                } catch (e: any) {
                    ad.status = old;
                    (window as any).__toast.error(e.message);
                } finally {
                    this.togglingAdStatus[ad.id] = false;
                }
            },

            // Campaign name
            openNameModal() {
                this.nameForm = { name: this.campaign.name || "" };
                this.showNameModal = true;
            },

            async saveName() {
                if (!this.nameForm.name.trim()) return;
                this.savingName = true;
                try {
                    await ApiClient.put(`/finance/facebook/campaigns/${this.campaignId}/name`, this.nameForm);
                    this.campaign.name = this.nameForm.name.trim();
                    (window as any).__toast.success("Nombre actualizado");
                    this.showNameModal = false;
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingName = false;
                }
            },

            // Budget
            openBudgetModal() {
                this.budgetForm = { dailyBudget: this.campaign.dailyBudget || 0 };
                this.showBudgetModal = true;
            },

            async saveBudget() {
                this.savingBudget = true;
                try {
                    await ApiClient.put(`/finance/facebook/campaigns/${this.campaignId}/budget`, this.budgetForm);
                    this.campaign.dailyBudget = this.budgetForm.dailyBudget;
                    (window as any).__toast.success("Presupuesto actualizado");
                    this.showBudgetModal = false;
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingBudget = false;
                }
            },

            // Location search
            async searchLocations() {
                if (this.locationQuery.length < 2) { this.locationResults = []; return; }
                try { this.locationResults = await ApiClient.get(`/finance/facebook/locations?q=${encodeURIComponent(this.locationQuery)}`); } catch { this.locationResults = []; }
            },

            addLocation(loc: any) {
                if (!this.adSetForm.locations.find((l: any) => l.key === loc.key && l.type === loc.type)) {
                    loc.radius = loc.type === "city" ? 40 : 0;
                    this.adSetForm.locations.push(loc);
                    this.geocodeAndMap(loc);
                }
                this.locationQuery = "";
                this.locationResults = [];
            },

            geocodeAndMap(loc: any) {
                const q = loc.name + (loc.region ? ", " + loc.region : "") + (loc.countryName ? ", " + loc.countryName : "");
                fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(q)}&limit=1`)
                    .then(r => r.json()).then(results => {
                        if (results[0]) { loc.lat = parseFloat(results[0].lat); loc.lng = parseFloat(results[0].lon); this.updateMap(); }
                    }).catch(() => {});
            },

            updateMap() {
                const L = (window as any).L;
                if (!L) return;
                const locs = this.adSetForm.locations.filter((l: any) => l.lat && l.lng);
                if (locs.length === 0) return;
                if (!this._map) {
                    const el = document.getElementById("targeting-map");
                    if (!el) return;
                    this._map = L.map(el, { zoomControl: true, attributionControl: false });
                    L.tileLayer("https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png", { maxZoom: 18 }).addTo(this._map);
                }
                this._mapMarkers.forEach((m: any) => m.remove());
                this._mapMarkers = [];
                const bounds: any[] = [];
                for (const loc of locs) {
                    const color = loc.type === "city" ? "#60a5fa" : loc.type === "region" ? "#a78bfa" : "#25D366";
                    if (loc.radius > 0) {
                        const circle = L.circle([loc.lat, loc.lng], { radius: loc.radius * 1000, color, fillColor: color, fillOpacity: 0.12, weight: 1.5 }).addTo(this._map);
                        this._mapMarkers.push(circle);
                    }
                    const marker = L.circleMarker([loc.lat, loc.lng], { radius: 5, color, fillColor: color, fillOpacity: 1, weight: 2 }).bindTooltip(loc.name).addTo(this._map);
                    this._mapMarkers.push(marker);
                    bounds.push([loc.lat, loc.lng]);
                }
                if (bounds.length === 1) this._map.setView(bounds[0], 10);
                else if (bounds.length > 1) this._map.fitBounds(bounds, { padding: [30, 30] });
            },

            // Interests
            async searchInterests() {
                if (this.interestQuery.length < 2) { this.interestResults = []; return; }
                try { this.interestResults = await ApiClient.get(`/finance/facebook/interests?q=${encodeURIComponent(this.interestQuery)}`); } catch { this.interestResults = []; }
            },

            addInterest(interest: any) {
                if (!this.adSetForm.interests.find((i: any) => i.id === interest.id)) this.adSetForm.interests.push(interest);
                this.interestQuery = "";
                this.interestResults = [];
            },

            // Save AdSet
            async saveAdSet() {
                if (!this.adSetForm.name.trim() || this.adSetForm.locations.length === 0) return;
                this.savingAdSet = true;
                try {
                    const geoLocations: any = {};
                    const countries = this.adSetForm.locations.filter((l: any) => l.type === "country");
                    const regions = this.adSetForm.locations.filter((l: any) => l.type === "region");
                    const cities = this.adSetForm.locations.filter((l: any) => l.type === "city");
                    if (countries.length) geoLocations.countries = countries.map((c: any) => c.key);
                    if (regions.length) geoLocations.regions = regions.map((r: any) => ({ key: r.key }));
                    if (cities.length) geoLocations.cities = cities.map((c: any) => ({ key: c.key, radius: c.radius || 40, distance_unit: "kilometer" }));

                    const targeting: any = { geo_locations: geoLocations, age_min: this.adSetForm.ageMin, age_max: this.adSetForm.ageMax };
                    if (this.adSetForm.gender > 0) targeting.genders = [this.adSetForm.gender];
                    if (this.adSetForm.interests.length > 0) targeting.flexible_spec = [{ interests: this.adSetForm.interests.map((i: any) => ({ id: i.id, name: i.name })) }];

                    await ApiClient.post("/finance/facebook/adsets/create", {
                        campaignId: this.campaignId, name: this.adSetForm.name, status: "PAUSED",
                        targeting, dailyBudget: this.adSetForm.dailyBudget || undefined,
                        optimizationGoal: this.adSetForm.optimizationGoal, billingEvent: "IMPRESSIONS",
                    });
                    (window as any).__toast.success("Conjunto de anuncios creado");
                    this.showAdSetModal = false;
                    if (this._map) { this._map.remove(); this._map = null; }
                    this._mapMarkers = [];
                    await this.loadAdSets();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingAdSet = false;
                }
            },

            // Ad creation
            openAdModal(adSetId: string) {
                this.adTargetAdSetId = adSetId;
                this.adForm = { name: "", pageId: "", link: "", message: "", headline: "", cta: "LEARN_MORE" };
                this.showAdModal = true;
            },

            async saveAd() {
                if (!this.adForm.name.trim() || !this.adForm.pageId || !this.adForm.link) return;
                this.savingAd = true;
                try {
                    const linkData: any = { link: this.adForm.link, message: this.adForm.message };
                    if (this.adForm.headline) linkData.name = this.adForm.headline;
                    if (this.adForm.cta) linkData.call_to_action = { type: this.adForm.cta, value: { link: this.adForm.link } };

                    await ApiClient.post("/finance/facebook/ads/create", {
                        adSetId: this.adTargetAdSetId, name: this.adForm.name, status: "PAUSED",
                        creative: { objectStorySpec: { page_id: this.adForm.pageId, link_data: linkData } },
                    });
                    (window as any).__toast.success("Anuncio creado");
                    this.showAdModal = false;
                    await this.loadAdSets();
                } catch (e: any) {
                    (window as any).__toast.error(e.message);
                } finally {
                    this.savingAd = false;
                }
            },
        }));
    });
</script>
