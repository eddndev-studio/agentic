---
import Layout from "../../layouts/Layout.astro";
import SectionHeader from "../../components/ui/SectionHeader.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import Modal from "../../components/ui/Modal.astro";
import Card from "../../components/ui/Card.astro";
import EmptyState from "../../components/ui/EmptyState.astro";
import FlowsTab from "../../components/detail/FlowsTab.astro";
import VariablesTab from "../../components/detail/VariablesTab.astro";
import AIConfigTab from "../../components/detail/AIConfigTab.astro";
import ToolsTab from "../../components/detail/ToolsTab.astro";
import AutomationsTab from "../../components/detail/AutomationsTab.astro";
import TemplateDetailSkeleton from "../../components/skeletons/TemplateDetailSkeleton.astro";
---

<Layout title="Template Detail">
	<div x-data="templateDetail" x-show="ready" class="space-y-8" style="display: none;">

		<!-- Header -->
		<SectionHeader backHref="/templates" backTitle="Back to Templates">
			<Badge slot="badge" color="blue" size="md">TEMPLATE</Badge>
			<h1 slot="title" class="text-3xl font-bold tracking-tight" x-text="template.name"></h1>
			<p slot="subtitle" class="text-xs text-wa-text-secondary mt-1" x-text="template.description || '—'"></p>
			<Fragment slot="actions">
				<a :href="'/editor?templateId=' + templateId"
					class="inline-flex items-center justify-center font-sans transition-colors rounded-lg px-6 py-2.5 text-xs bg-wa-green text-white hover:bg-wa-green-hover gap-2">
					<span>+</span>
					<span x-text="$t('new_flow')">Nuevo Flujo</span>
				</a>
				<Button variant="danger" x-on:click="deleteTemplate()" x-text="$t('delete_template')">Eliminar</Button>
			</Fragment>
		</SectionHeader>

		<!-- Tab bar -->
		<div class="flex gap-1 border-b border-wa-border mb-6 overflow-x-auto">
			<template x-for="tab in [
				{ key: 'flows', label: 'Flujos' },
				{ key: 'config', label: 'Config IA' },
				{ key: 'tools', label: 'Herramientas' },
				{ key: 'automations', label: 'Automatizaciones' },
				{ key: 'variables', label: 'Variables' },
				{ key: 'bots', label: 'Bots' },
			]" :key="tab.key">
				<button x-on:click="activeTab = tab.key; updateTabUrl()"
					class="px-4 py-2.5 text-xs font-sans transition-colors rounded-t-lg whitespace-nowrap"
					:class="activeTab === tab.key ? 'text-wa-green border-b-2 border-wa-green bg-wa-green/5' : 'text-wa-text-secondary hover:text-white'"
					x-text="tab.label">
				</button>
			</template>
		</div>

		<!-- Flows tab (shared component) -->
		<div x-show="activeTab === 'flows'" x-transition:enter>
			<FlowsTab />
		</div>

		<!-- Config IA tab (shared component) -->
		<div x-show="activeTab === 'config'" x-transition:enter>
			<AIConfigTab />
		</div>

		<!-- Tools tab (shared component) -->
		<div x-show="activeTab === 'tools'" x-transition:enter>
			<ToolsTab />
		</div>

		<!-- Automations tab (shared component) -->
		<div x-show="activeTab === 'automations'" x-transition:enter>
			<AutomationsTab />
		</div>

		<!-- Variables tab -->
		<div x-show="activeTab === 'variables'" x-transition:enter>
			<VariablesTab />
		</div>

		<!-- Bots tab -->
		<div x-show="activeTab === 'bots'" x-transition:enter>
			<div class="flex justify-between items-center mb-6">
				<h3 class="text-xs text-wa-green tracking-normal" x-text="$t('template_bots_count')">Bots using this template</h3>
				<Button variant="primary" x-on:click="showCreateBotModal = true" class="flex items-center gap-2">
					<span>+</span>
					<span x-text="$t('create_bot')">Create Bot</span>
				</Button>
			</div>
			<div class="space-y-3">
				<template x-for="bot in template.bots || []" :key="bot.id">
					<a :href="'/bots/detail?id=' + bot.id"
						class="flex items-center justify-between p-4 bg-wa-bg-hover rounded-lg hover:border-wa-green/30 border border-transparent transition-all group">
						<div>
							<h4 class="text-sm font-medium group-hover:text-wa-green transition-colors" x-text="bot.name"></h4>
							<p class="text-[10px] text-wa-text-secondary mt-1" x-text="bot.identifier"></p>
						</div>
						<svg class="w-4 h-4 text-wa-text-secondary group-hover:text-wa-green" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
						</svg>
					</a>
				</template>
				<EmptyState x-show="!template.bots || template.bots.length === 0">
					No hay bots usando esta plantilla.
				</EmptyState>
			</div>
		</div>
	</div>

	<!-- Create Bot from Template Modal -->
	<div x-data="templateDetail">
		<Modal show="showCreateBotModal">
			<h2 class="text-xl font-bold tracking-tight mb-2" x-text="$t('create_bot')">Create Bot</h2>
			<p class="text-xs text-wa-text-secondary mb-6">
				Se creara con la plantilla <span class="text-purple-400" x-text="template.name"></span>
			</p>
			<form @submit.prevent="createBotFromTemplate()" class="space-y-4">
				<div>
					<label class="block text-xs text-wa-text-secondary mb-2" x-text="$t('bot_name')"></label>
					<input type="text" x-model="newBotForm.name" required placeholder="Mi Bot"
						class="w-full bg-wa-bg-hover border border-wa-border rounded-lg p-3 text-sm focus:border-wa-green focus:outline-none text-white" />
				</div>
				<div>
					<label class="block text-xs text-wa-text-secondary mb-2" x-text="$t('bot_identifier')"></label>
					<input type="text" x-model="newBotForm.identifier" required placeholder="+1234567890"
						class="w-full bg-wa-bg-hover border border-wa-border rounded-lg p-3 text-sm focus:border-wa-green focus:outline-none text-white" />
				</div>
				<div class="flex gap-4 pt-4">
					<Button variant="secondary" size="lg" type="button" class="flex-1" x-on:click="showCreateBotModal = false" x-text="$t('cancel')">Cancel</Button>
					<Button variant="primary" size="lg" type="submit" class="flex-1" x-bind:disabled="creatingBot" x-text="creatingBot ? $t('loading') : $t('create_bot')">Create</Button>
				</div>
			</form>
		</Modal>
	</div>

	<!-- Loading Skeleton -->
	<div x-data="templateDetail" x-show="!ready && !error">
		<TemplateDetailSkeleton />
	</div>

	<!-- Error State -->
	<div x-data="templateDetail" x-show="!ready && error" class="p-12 text-center text-red-400" x-text="error" style="display: none;"></div>
</Layout>

<script>
	declare const Alpine: any;
	import { ApiClient } from "../../lib/api";

	document.addEventListener("alpine:init", () => {
		Alpine.data("templateDetail", () => ({
			activeTab: "flows" as string,
			templateId: null as string | null,
			botId: null as string | null, // Alias — shared components read botId or templateId
			template: {} as any,
			bot: {} as any, // Alias for shared components that read `bot`

			// Shared tab state (used by FlowsTab, ToolsTab, AIConfigTab, AutomationsTab, VariablesTab)
			flows: [] as any[],
			tools: [] as any[],
			automations: [] as any[],
			builtinTools: [] as any[],
			botLabels: [] as any[],
			flowSearch: "",
			get filteredFlows(): any[] {
				const q = this.flowSearch.toLowerCase().trim();
				const list = q
					? this.flows.filter((f: any) =>
						f.name.toLowerCase().includes(q) ||
						(f.description || "").toLowerCase().includes(q) ||
						f.triggers?.some((t: any) => t.keyword?.toLowerCase().includes(q))
					)
					: [...this.flows];
				return list.sort((a: any, b: any) => a.name.localeCompare(b.name));
			},

			ready: false,
			error: null as string | null,
			savingAI: false,
			templateVars: [] as { name: string; type: string }[],
			savingVars: false,
			showVarModal: false,
			editingVarIndex: -1,
			editingVar: { name: "", type: "text" } as { name: string; type: string },
			showCreateBotModal: false,
			creatingBot: false,
			newBotForm: { name: "", identifier: "" },

			// Variables tab
			variables: [] as any[],
			showVariableModal: false,
			editingVariable: null as any,

			async init() {
				const params = new URLSearchParams(window.location.search);
				this.templateId = params.get("id");

				const tabParam = params.get('tab');
				if (tabParam && ['flows', 'config', 'tools', 'automations', 'variables', 'bots'].includes(tabParam)) {
					this.activeTab = tabParam;
				}

				if (!this.templateId) {
					this.error = "No template ID provided";
					return;
				}

				try {
					this.template = await ApiClient.get(`/templates/${this.templateId}`);
					this.bot = this.template; // Alias for shared components
					this.flows = this.template.flows || [];
					this.tools = this.template.tools || [];
					this.automations = this.template.automations || [];
					this.templateVars = Array.isArray(this.template.variables) ? [...this.template.variables] : [];
					this.variables = this.templateVars;
					this.ready = true;
				} catch (e: any) {
					this.error = e.message || "Template not found";
				}
			},

			async saveAIConfig() {
				this.savingAI = true;
				try {
					const config: any = {};
					const el = this.$el?.closest?.('[x-data]');
					// Read from AI config form elements in the AIConfigTab
					// The shared component writes to the parent scope
					await ApiClient.put(`/templates/${this.templateId}`, this.bot);
					this.template = await ApiClient.get(`/templates/${this.templateId}`);
					this.bot = this.template;
					window.__toast.success("Config IA guardada");
				} catch (e: any) {
					window.__toast.error("Error: " + (e.message || "Unknown"));
				} finally {
					this.savingAI = false;
				}
			},

			async saveTemplateVars() {
				this.savingVars = true;
				try {
					const cleaned = this.templateVars
						.filter((v: any) => v.name.trim())
						.map((v: any) => ({ name: v.name.trim().toUpperCase(), type: v.type }));
					await ApiClient.put(`/templates/${this.templateId}`, { variables: cleaned });
					this.template = await ApiClient.get(`/templates/${this.templateId}`);
					this.templateVars = [...(this.template.variables || [])];
					this.variables = this.templateVars;
					window.__toast.success("Variables guardadas");
				} catch (e: any) {
					window.__toast.error("Error: " + (e.message || "Unknown"));
				} finally {
					this.savingVars = false;
				}
			},

			async createBotFromTemplate() {
				if (!this.newBotForm.name || !this.newBotForm.identifier) return;
				this.creatingBot = true;
				try {
					const bot = await ApiClient.post("/bots", {
						name: this.newBotForm.name,
						identifier: this.newBotForm.identifier,
						platform: "WHATSAPP",
					});
					await ApiClient.put(`/bots/${bot.id}`, {
						templateId: this.templateId,
						aiEnabled: true,
					});
					window.location.href = `/bots/detail?id=${bot.id}`;
				} catch (e: any) {
					window.__toast.error("Error: " + (e.message || "Unknown"));
				} finally {
					this.creatingBot = false;
				}
			},

			async exportFlowsJson() {
				try {
					const data = await ApiClient.get(`/flows/export?templateId=${this.templateId}`);
					const blob = new Blob([JSON.stringify(data, null, 2)], { type: "application/json" });
					const url = URL.createObjectURL(blob);
					const a = document.createElement("a");
					a.href = url;
					a.download = `flows-${this.template.name || this.templateId}.json`;
					a.click();
					URL.revokeObjectURL(url);
					window.__toast.success(`${data.flows.length} flujo(s) exportado(s)`);
				} catch (e: any) {
					window.__toast.error("Export failed: " + (e.message || "Unknown error"));
				}
			},

			async importFlowsJson(event: Event) {
				const input = event.target as HTMLInputElement;
				const file = input.files?.[0];
				if (!file) return;
				try {
					const text = await file.text();
					const data = JSON.parse(text);
					const flows = data.flows || data;
					if (!Array.isArray(flows) || flows.length === 0) {
						window.__toast.error("El archivo no contiene flujos válidos");
						return;
					}
					if (!confirm(`Importar ${flows.length} flujo(s)?`)) return;
					const result = await ApiClient.post("/flows/import-json", {
						templateId: this.templateId,
						flows,
					});
					this.template = await ApiClient.get(`/templates/${this.templateId}`);
					this.flows = this.template.flows || [];
					window.__toast.success(`${result.imported} flujo(s) importado(s)`);
				} catch (e: any) {
					window.__toast.error("Import failed: " + (e.message || "Unknown error"));
				} finally {
					input.value = "";
				}
			},

			async deleteFlow(flowId: string, flowName: string) {
				// @ts-ignore
				if (!confirm(this.$t('delete_flow_confirm') || `Delete flow "${flowName}"?`)) return;
				try {
					await ApiClient.delete(`/flows/${flowId}`);
					this.template = await ApiClient.get(`/templates/${this.templateId}`);
					this.flows = this.template.flows || [];
					window.__toast.success("Flujo eliminado");
				} catch (e: any) {
					window.__toast.error("Failed to delete flow: " + (e.message || "Unknown error"));
				}
			},

			async deleteTemplate() {
				if (!confirm("Are you sure?")) return;
				try {
					await ApiClient.delete(`/templates/${this.templateId}`);
					window.location.href = "/templates";
				} catch (e: any) {
					window.__toast.error("Error: " + (e.message || "Unknown"));
				}
			},

			get labelVarDefs(): { name: string; type: string }[] {
				return this.templateVars.filter((v: any) => v.type === 'label');
			},

			toggleIgnoredLabelVar(varName: string) {
				const labels = this.bot.ignoredLabels || [];
				const idx = labels.indexOf(varName);
				if (idx >= 0) {
					labels.splice(idx, 1);
				} else {
					labels.push(varName);
				}
				this.bot.ignoredLabels = [...labels];
			},

			updateTabUrl() {
				const url = new URL(window.location.href);
				url.searchParams.set('tab', this.activeTab);
				history.replaceState(null, '', url.toString());
			},
		}));
	});
</script>
