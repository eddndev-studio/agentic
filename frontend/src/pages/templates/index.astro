---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/ui/Card.astro";
import Button from "../../components/ui/Button.astro";
import Modal from "../../components/ui/Modal.astro";
---

<Layout title="Templates">
	<main class="space-y-8" x-data="templateList">
		<!-- Header -->
		<header class="flex flex-wrap justify-between items-center gap-4 border-b border-wa-border pb-6">
			<div>
				<h1 class="text-3xl font-bold tracking-tight" x-text="$t('template_list')">Templates</h1>
				<p class="text-xs text-wa-text-secondary mt-1">
					<span x-text="templates.length">0</span> <span x-text="$t('templates')">templates</span>
				</p>
			</div>
			<Button variant="primary" size="lg" x-on:click="$dispatch('open-create-template')" class="flex items-center gap-2">
				<span>+</span>
				<span x-text="$t('create_template')">Create Template</span>
			</Button>
		</header>

		<!-- Loading -->
		<div x-show="loading" class="grid grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
			<template x-for="i in 3">
				<Card size="lg" class="animate-pulse h-40">
					<div class="w-16 h-4 bg-wa-bg-hover mb-4 rounded"></div>
					<div class="w-3/4 h-6 bg-wa-bg-hover mb-2 rounded"></div>
					<div class="w-1/2 h-4 bg-wa-bg-hover rounded"></div>
				</Card>
			</template>
		</div>

		<!-- Template Grid -->
		<div x-show="!loading" x-cloak class="grid grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6" style="display: none;">
			<template x-for="tpl in templates" :key="tpl.id">
				<a
					:href="`/templates/detail?id=${tpl.id}`"
					class="block bg-wa-bg-panel border border-wa-border rounded-xl p-4 sm:p-6 relative group overflow-hidden hover:border-wa-green/30 transition-all duration-300"
				>
					<!-- Background Icon -->
					<span class="material-symbols-outlined pointer-events-none absolute -right-3 -bottom-3 text-[96px] text-white/[0.03] select-none" aria-hidden="true">dashboard_customize</span>

					<div class="flex justify-between items-start mb-3 sm:mb-4">
						<span class="text-[10px] text-purple-400 bg-purple-500/10 px-2 py-0.5 rounded-md">TEMPLATE</span>
						<svg class="w-4 h-4 text-wa-text-secondary group-hover:text-wa-green transition-colors hidden sm:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
						</svg>
					</div>

					<h3 class="text-sm sm:text-lg font-bold tracking-tight mb-1 group-hover:text-wa-green transition-colors" x-text="tpl.name"></h3>
					<p class="text-[10px] sm:text-xs text-wa-text-secondary truncate mb-4" x-text="tpl.description || '—'"></p>

					<!-- Stats -->
					<div class="pt-4 border-t border-wa-border flex items-center gap-4 text-[10px] text-wa-text-secondary">
						<span>
							<span x-text="tpl._count?.bots ?? 0"></span> bots
						</span>
						<span>
							<span x-text="tpl._count?.flows ?? 0"></span> flows
						</span>
						<span>
							<span x-text="tpl._count?.tools ?? 0"></span> tools
						</span>
					</div>
				</a>
			</template>

			<!-- Empty State -->
			<div
				x-show="templates.length === 0"
				class="col-span-full p-12 border border-dashed border-wa-border rounded-xl text-center text-wa-text-secondary bg-wa-bg-panel/20"
			>
				<svg class="w-12 h-12 mx-auto mb-4 text-wa-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
				</svg>
				<p class="text-sm mb-4" x-text="$t('no_templates')">No templates created</p>
				<Button variant="primary" size="lg" x-on:click="$dispatch('open-create-template')">
					+ <span x-text="$t('create_template')">Create Template</span>
				</Button>
			</div>
		</div>
	</main>

	<!-- Create Template Modal -->
	<div x-data="createTemplateModal" @open-create-template.window="open()">
		<Modal show="visible">
			<h2 class="text-xl font-bold tracking-tight mb-6" x-text="$t('create_template')">Create Template</h2>
			<form @submit.prevent="submit()" class="space-y-4">
				<div>
					<label class="block text-xs text-wa-text-secondary mb-2" x-text="$t('template_name')"></label>
					<input type="text" x-model="form.name" required placeholder="Mi Plantilla"
						class="w-full bg-wa-bg-hover border border-wa-border rounded-lg p-3 text-sm focus:border-wa-green focus:outline-none text-white" />
				</div>
				<div>
					<label class="block text-xs text-wa-text-secondary mb-2" x-text="$t('template_description')"></label>
					<textarea x-model="form.description" rows="2" placeholder="Descripcion opcional..."
						class="w-full bg-wa-bg-hover border border-wa-border rounded-lg p-3 text-sm focus:border-wa-green focus:outline-none text-white resize-none"></textarea>
				</div>
				<div class="flex gap-4 pt-4">
					<Button variant="secondary" size="lg" type="button" class="flex-1" x-on:click="close()" x-text="$t('cancel')">Cancel</Button>
					<Button variant="primary" size="lg" type="submit" class="flex-1" x-bind:disabled="loading" x-text="loading ? $t('loading') : $t('create_template')">Create</Button>
				</div>
			</form>
		</Modal>
	</div>
</Layout>

<script>
	declare const Alpine: any;
	import { ApiClient } from "../../lib/api";

	document.addEventListener("alpine:init", () => {
		Alpine.data("templateList", () => ({
			templates: [] as any[],
			loading: true,

			init() {
				this.fetchTemplates();
			},

			async fetchTemplates() {
				try {
					this.templates = await ApiClient.get("/templates");
				} catch (e: unknown) {
					console.error("Failed to fetch templates:", e);
				} finally {
					this.loading = false;
				}
			},
		}));

		Alpine.data("createTemplateModal", () => ({
			visible: false,
			loading: false,
			form: { name: "", description: "" },

			open() {
				this.visible = true;
				this.form = { name: "", description: "" };
			},

			close() {
				this.visible = false;
			},

			async submit() {
				if (!this.form.name) return;
				this.loading = true;
				try {
					await ApiClient.post("/templates", this.form);
					window.location.reload();
				} catch (e: unknown) {
					window.__toast.error((e as Error).message || "Failed to create template");
				} finally {
					this.loading = false;
				}
			},
		}));
	});
</script>
