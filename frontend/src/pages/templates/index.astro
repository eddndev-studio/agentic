---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Templates">
	<main class="space-y-8" x-data="templateList">
		<!-- Header -->
		<header class="flex flex-wrap justify-between items-center gap-4 border-b border-wa-border pb-6">
			<div>
				<h1 class="text-3xl font-bold tracking-tight" x-text="$t('template_list')">Templates</h1>
				<p class="text-xs text-wa-text-secondary mt-1">
					<span x-text="templates.length">0</span> <span x-text="$t('templates')">templates</span>
				</p>
			</div>
			<button
				@click="$dispatch('open-create-template')"
				class="px-6 py-2 bg-wa-green text-white text-sm font-medium rounded-lg hover:bg-wa-green-hover transition-colors flex items-center gap-2"
			>
				<span>+</span>
				<span x-text="$t('create_template')">Create Template</span>
			</button>
		</header>

		<!-- Loading -->
		<div x-show="loading" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
			<template x-for="i in 3">
				<div class="bg-wa-bg-panel border border-wa-border rounded-xl p-6 animate-pulse h-40">
					<div class="w-16 h-4 bg-wa-bg-hover mb-4 rounded"></div>
					<div class="w-3/4 h-6 bg-wa-bg-hover mb-2 rounded"></div>
					<div class="w-1/2 h-4 bg-wa-bg-hover rounded"></div>
				</div>
			</template>
		</div>

		<!-- Template Grid -->
		<div x-show="!loading" x-cloak class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" style="display: none;">
			<template x-for="tpl in templates" :key="tpl.id">
				<a
					:href="`/templates/detail?id=${tpl.id}`"
					class="block bg-wa-bg-panel border border-wa-border rounded-xl p-6 relative group hover:border-wa-green/30 transition-all duration-300"
				>
					<div class="flex justify-between items-start mb-4">
						<span class="text-[10px] text-purple-400 bg-purple-500/10 px-2 py-0.5 rounded-md">TEMPLATE</span>
						<svg class="w-4 h-4 text-wa-text-secondary group-hover:text-wa-green transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
						</svg>
					</div>

					<h3 class="text-lg font-bold tracking-tight mb-1 group-hover:text-wa-green transition-colors" x-text="tpl.name"></h3>
					<p class="text-xs text-wa-text-secondary truncate mb-4" x-text="tpl.description || '—'"></p>

					<!-- Stats -->
					<div class="pt-4 border-t border-wa-border flex items-center gap-4 text-[10px] text-wa-text-secondary">
						<span>
							<span x-text="tpl._count?.bots ?? 0"></span> bots
						</span>
						<span>
							<span x-text="tpl._count?.flows ?? 0"></span> flows
						</span>
						<span>
							<span x-text="tpl._count?.tools ?? 0"></span> tools
						</span>
					</div>
				</a>
			</template>

			<!-- Empty State -->
			<div
				x-show="templates.length === 0"
				class="col-span-full p-12 border border-dashed border-wa-border rounded-xl text-center text-wa-text-secondary bg-wa-bg-panel/20"
			>
				<svg class="w-12 h-12 mx-auto mb-4 text-wa-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path>
				</svg>
				<p class="text-sm mb-4" x-text="$t('no_templates')">No templates created</p>
				<button
					@click="$dispatch('open-create-template')"
					class="px-6 py-2 bg-wa-green text-white hover:bg-wa-green-hover transition-colors text-sm rounded-lg"
				>
					+ <span x-text="$t('create_template')">Create Template</span>
				</button>
			</div>
		</div>
	</main>

	<!-- Create Template Modal -->
	<div
		x-data="createTemplateModal"
		x-show="visible"
		x-cloak
		@open-create-template.window="open()"
		class="fixed inset-0 z-50 flex items-center justify-center p-4"
		style="display: none;"
	>
		<div class="absolute inset-0 bg-black/70" @click="close()"></div>
		<div class="relative bg-wa-bg-panel border border-wa-border rounded-xl p-4 sm:p-8 w-full max-w-md">
			<h2 class="text-xl font-bold tracking-tight mb-6" x-text="$t('create_template')">Create Template</h2>
			<form @submit.prevent="submit()" class="space-y-4">
				<div>
					<label class="block text-xs text-wa-text-secondary mb-2" x-text="$t('template_name')"></label>
					<input type="text" x-model="form.name" required class="w-full bg-wa-bg-hover border border-wa-border rounded-lg p-3 text-sm focus:border-wa-green focus:outline-none text-white" placeholder="Mi Plantilla" />
				</div>
				<div>
					<label class="block text-xs text-wa-text-secondary mb-2" x-text="$t('template_description')"></label>
					<textarea x-model="form.description" rows="2" class="w-full bg-wa-bg-hover border border-wa-border rounded-lg p-3 text-sm focus:border-wa-green focus:outline-none text-white resize-none" placeholder="Descripción opcional..."></textarea>
				</div>
				<div class="flex gap-4 pt-4">
					<button type="button" @click="close()" class="flex-1 px-4 py-3 border border-wa-border text-wa-text-secondary text-sm rounded-lg hover:bg-wa-bg-hover" x-text="$t('cancel')">Cancel</button>
					<button type="submit" :disabled="loading" class="flex-1 px-4 py-3 bg-wa-green text-white text-sm rounded-lg hover:bg-wa-green-hover disabled:opacity-50" x-text="loading ? $t('loading') : $t('create_template')">Create</button>
				</div>
			</form>
		</div>
	</div>
</Layout>

<script>
	declare const Alpine: any;
	import { ApiClient } from "../../lib/api";

	document.addEventListener("alpine:init", () => {
		Alpine.data("templateList", () => ({
			templates: [] as any[],
			loading: true,

			init() {
				this.fetchTemplates();
			},

			async fetchTemplates() {
				try {
					this.templates = await ApiClient.get("/templates");
				} catch (e: unknown) {
					console.error("Failed to fetch templates:", e);
				} finally {
					this.loading = false;
				}
			},
		}));

		Alpine.data("createTemplateModal", () => ({
			visible: false,
			loading: false,
			form: { name: "", description: "" },

			open() {
				this.visible = true;
				this.form = { name: "", description: "" };
			},

			close() {
				this.visible = false;
			},

			async submit() {
				if (!this.form.name) return;
				this.loading = true;
				try {
					await ApiClient.post("/templates", this.form);
					window.location.reload();
				} catch (e: unknown) {
					alert((e as Error).message || "Failed to create template");
				} finally {
					this.loading = false;
				}
			},
		}));
	});
</script>
