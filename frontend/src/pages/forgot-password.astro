---
import "../styles/global.css";
import AuthCard from "../components/auth/AuthCard.astro";
import AuthInput from "../components/auth/AuthInput.astro";
import AuthButton from "../components/auth/AuthButton.astro";
import AuthError from "../components/auth/AuthError.astro";
import AuthLink from "../components/auth/AuthLink.astro";
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="theme-color" content="#0b141a" />
        <meta name="mobile-web-app-capable" content="yes" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <title>Restablecer Password | Agentic</title>
    </head>
    <body class="bg-wa-bg-deep min-h-screen flex items-center justify-center font-sans text-wa-text-primary antialiased relative overflow-hidden">
        <main x-data="forgotForm">
            <AuthCard title="Restablecer password" subtitle="Te enviaremos un enlace para restablecer tu password">
                <!-- Success state -->
                <div x-show="sent" x-transition class="text-center py-4">
                    <div class="w-12 h-12 rounded-full bg-wa-green/10 flex items-center justify-center mx-auto mb-4">
                        <svg class="w-6 h-6 text-wa-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <p class="text-sm text-wa-text-primary">Revisa tu bandeja de entrada</p>
                    <p class="text-xs text-wa-text-secondary mt-2">Si el email existe, recibiras un enlace para restablecer tu password.</p>
                </div>

                <!-- Form state -->
                <form x-show="!sent" @submit.prevent="submit" class="relative">
                    <AuthError />
                    <AuthInput label="Email" type="email" x-model="email" placeholder="tu@email.com" required />
                    <AuthButton loadingText="Enviando...">Enviar enlace</AuthButton>
                </form>

                <Fragment slot="footer">
                    <div class="mt-6 text-center">
                        <AuthLink href="/login">Volver al login</AuthLink>
                    </div>
                </Fragment>
            </AuthCard>
        </main>

        <script>
            import { ApiClient as api } from "../lib/api";

            document.addEventListener("alpine:init", () => {
                Alpine.data("forgotForm", () => ({
                    email: "",
                    loading: false,
                    errorMessage: "",
                    sent: false,

                    async submit() {
                        this.loading = true;
                        this.errorMessage = '';
                        try {
                            await api.post('/auth/forgot-password', { email: this.email });
                            this.sent = true;
                        } catch (err) {
                            this.errorMessage = err instanceof Error ? err.message : 'Error sending email';
                        } finally {
                            this.loading = false;
                        }
                    }
                }));
            });
        </script>
    </body>
</html>
