---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Mi Cuenta">
    <div x-data="accountPage" x-init="init()">
        <h1 class="text-2xl font-bold mb-8">Mi Cuenta</h1>

        <!-- Loading -->
        <div x-show="loading" class="text-center py-12">
            <span class="text-sm text-wa-text-secondary animate-pulse">Cargando...</span>
        </div>

        <div x-show="!loading" class="space-y-6 max-w-lg">

            <!-- Profile Section -->
            <section class="p-6 bg-wa-bg-panel border border-wa-border rounded-xl">
                <h2 class="text-sm font-semibold text-wa-green mb-5">Perfil</h2>

                <div class="space-y-4">
                    <div class="space-y-2">
                        <label class="text-xs text-wa-text-secondary">Nombre</label>
                        <div class="flex gap-2">
                            <input type="text" x-model="profile.fullName"
                                class="flex-1 bg-wa-bg-hover border border-wa-border text-white p-3 text-sm rounded-lg focus:border-wa-green/50 focus:outline-none focus:ring-1 focus:ring-wa-green/50" />
                            <button @click="saveName()"
                                class="px-4 py-2 bg-wa-green text-white text-sm rounded-lg hover:bg-wa-green-hover transition-colors disabled:opacity-50"
                                :disabled="savingName">
                                <span x-show="!savingName">Guardar</span>
                                <span x-show="savingName" class="animate-pulse">...</span>
                            </button>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs text-wa-text-secondary">Email</label>
                        <div class="flex items-center gap-2">
                            <span class="flex-1 p-3 text-sm text-wa-text-primary bg-wa-bg-hover border border-wa-border rounded-lg" x-text="profile.email"></span>
                            <span x-show="profile.emailVerified" class="text-xs text-wa-green px-2 py-1 bg-wa-green/10 rounded-full">Verificado</span>
                            <span x-show="!profile.emailVerified" class="text-xs text-amber-400 px-2 py-1 bg-amber-500/10 rounded-full">Sin verificar</span>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs text-wa-text-secondary">Proveedor</label>
                        <div class="flex items-center gap-2">
                            <span class="text-sm px-3 py-1.5 rounded-lg border border-wa-border"
                                :class="profile.provider === 'GOOGLE' ? 'bg-blue-500/10 text-blue-400 border-blue-500/20' : 'bg-wa-bg-hover text-wa-text-secondary'"
                                x-text="profile.provider === 'GOOGLE' ? 'Google' : 'Email + Password'">
                            </span>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Change Email Section -->
            <section class="p-6 bg-wa-bg-panel border border-wa-border rounded-xl">
                <h2 class="text-sm font-semibold text-wa-green mb-5">Cambiar Email</h2>
                <div x-show="emailError" class="mb-4 p-3 border border-red-500/30 bg-red-500/10 text-red-200 text-xs rounded-lg" x-text="emailError"></div>
                <div x-show="emailSuccess" class="mb-4 p-3 border border-wa-green/30 bg-wa-green/10 text-wa-green text-xs rounded-lg">Email actualizado. Revisa tu bandeja para verificar.</div>

                <div class="space-y-4">
                    <div class="space-y-2">
                        <label class="text-xs text-wa-text-secondary">Nuevo email</label>
                        <input type="email" x-model="newEmail"
                            class="w-full bg-wa-bg-hover border border-wa-border text-white p-3 text-sm rounded-lg focus:border-wa-green/50 focus:outline-none focus:ring-1 focus:ring-wa-green/50"
                            placeholder="nuevo@email.com" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs text-wa-text-secondary">Password actual (verificacion)</label>
                        <input type="password" x-model="emailPassword"
                            class="w-full bg-wa-bg-hover border border-wa-border text-white p-3 text-sm rounded-lg focus:border-wa-green/50 focus:outline-none focus:ring-1 focus:ring-wa-green/50"
                            placeholder="••••••••" />
                    </div>
                    <button @click="changeEmail()" :disabled="changingEmail"
                        class="px-5 py-2.5 bg-wa-green text-white text-sm rounded-lg hover:bg-wa-green-hover transition-colors disabled:opacity-50">
                        <span x-show="!changingEmail">Cambiar Email</span>
                        <span x-show="changingEmail" class="animate-pulse">Actualizando...</span>
                    </button>
                </div>
            </section>

            <!-- Change Password Section -->
            <section class="p-6 bg-wa-bg-panel border border-wa-border rounded-xl">
                <h2 class="text-sm font-semibold text-wa-green mb-5">Cambiar Password</h2>
                <div x-show="pwError" class="mb-4 p-3 border border-red-500/30 bg-red-500/10 text-red-200 text-xs rounded-lg" x-text="pwError"></div>
                <div x-show="pwSuccess" class="mb-4 p-3 border border-wa-green/30 bg-wa-green/10 text-wa-green text-xs rounded-lg">Password actualizada correctamente.</div>

                <div class="space-y-4">
                    <div class="space-y-2">
                        <label class="text-xs text-wa-text-secondary">Password actual</label>
                        <input type="password" x-model="currentPassword"
                            class="w-full bg-wa-bg-hover border border-wa-border text-white p-3 text-sm rounded-lg focus:border-wa-green/50 focus:outline-none focus:ring-1 focus:ring-wa-green/50"
                            placeholder="••••••••" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs text-wa-text-secondary">Nueva password</label>
                        <input type="password" x-model="newPassword"
                            class="w-full bg-wa-bg-hover border border-wa-border text-white p-3 text-sm rounded-lg focus:border-wa-green/50 focus:outline-none focus:ring-1 focus:ring-wa-green/50"
                            placeholder="Minimo 8 caracteres" />
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs text-wa-text-secondary">Confirmar nueva password</label>
                        <input type="password" x-model="confirmPassword"
                            class="w-full bg-wa-bg-hover border border-wa-border text-white p-3 text-sm rounded-lg focus:border-wa-green/50 focus:outline-none focus:ring-1 focus:ring-wa-green/50"
                            placeholder="••••••••" />
                    </div>
                    <button @click="changePassword()" :disabled="changingPassword"
                        class="px-5 py-2.5 bg-wa-green text-white text-sm rounded-lg hover:bg-wa-green-hover transition-colors disabled:opacity-50">
                        <span x-show="!changingPassword">Cambiar Password</span>
                        <span x-show="changingPassword" class="animate-pulse">Actualizando...</span>
                    </button>
                </div>
            </section>

            <!-- Google Account Section -->
            <section class="p-6 bg-wa-bg-panel border border-wa-border rounded-xl">
                <h2 class="text-sm font-semibold text-wa-green mb-5">Cuenta de Google</h2>

                <!-- Linked -->
                <div x-show="profile.provider === 'GOOGLE'" class="space-y-4">
                    <div class="flex items-center gap-3 p-3 bg-blue-500/5 border border-blue-500/20 rounded-lg">
                        <svg class="w-5 h-5 text-blue-400 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        <span class="text-sm text-blue-400">Google vinculado</span>
                    </div>
                    <p class="text-xs text-wa-text-secondary">Para desvincular Google necesitas tener una password establecida.</p>
                    <button @click="unlinkGoogle()" :disabled="unlinking"
                        class="px-4 py-2 text-sm border border-red-500/30 text-red-400 rounded-lg hover:bg-red-500/10 transition-colors disabled:opacity-50">
                        <span x-show="!unlinking">Desvincular Google</span>
                        <span x-show="unlinking" class="animate-pulse">...</span>
                    </button>
                </div>

                <!-- Not linked -->
                <div x-show="profile.provider !== 'GOOGLE'" class="space-y-4">
                    <p class="text-xs text-wa-text-secondary">Vincula tu cuenta de Google para iniciar sesion mas rapido.</p>
                    <div id="google-link-btn"></div>
                </div>
            </section>

            <!-- Danger Zone -->
            <section class="p-6 bg-wa-bg-panel border border-red-500/20 rounded-xl">
                <h2 class="text-sm font-semibold text-red-400 mb-3">Zona de peligro</h2>
                <p class="text-xs text-wa-text-secondary mb-4">La eliminacion de cuenta es permanente y no se puede deshacer.</p>
                <button disabled class="px-4 py-2 text-sm border border-red-500/30 text-red-400/50 rounded-lg cursor-not-allowed">
                    Eliminar cuenta (proximamente)
                </button>
            </section>
        </div>
    </div>

    <script>
        import { ApiClient as api } from "../../lib/api";

        document.addEventListener("alpine:init", () => {
            Alpine.data("accountPage", () => ({
                profile: {} as any,
                loading: true,
                savingName: false,

                // Email
                newEmail: '',
                emailPassword: '',
                changingEmail: false,
                emailError: '',
                emailSuccess: false,

                // Password
                currentPassword: '',
                newPassword: '',
                confirmPassword: '',
                changingPassword: false,
                pwError: '',
                pwSuccess: false,

                // Google
                unlinking: false,

                async init() {
                    try {
                        this.profile = await api.get('/auth/me');
                    } finally {
                        this.loading = false;
                    }
                    this.initGoogleButton();
                },

                async saveName() {
                    this.savingName = true;
                    try {
                        await api.put('/auth/me', { fullName: this.profile.fullName });
                        const user = JSON.parse(localStorage.getItem('user') || '{}');
                        user.fullName = this.profile.fullName;
                        localStorage.setItem('user', JSON.stringify(user));
                        (window as any).__toast?.success('Nombre actualizado');
                    } catch (err: any) {
                        (window as any).__toast?.error(err.message);
                    } finally {
                        this.savingName = false;
                    }
                },

                async changeEmail() {
                    this.changingEmail = true;
                    this.emailError = '';
                    this.emailSuccess = false;
                    try {
                        await api.put('/auth/me/email', {
                            newEmail: this.newEmail,
                            password: this.emailPassword
                        });
                        this.emailSuccess = true;
                        this.profile.email = this.newEmail;
                        this.profile.emailVerified = false;
                        this.newEmail = '';
                        this.emailPassword = '';
                    } catch (err: any) {
                        this.emailError = err.message;
                    } finally {
                        this.changingEmail = false;
                    }
                },

                async changePassword() {
                    this.changingPassword = true;
                    this.pwError = '';
                    this.pwSuccess = false;

                    if (this.newPassword !== this.confirmPassword) {
                        this.pwError = 'Las passwords no coinciden';
                        this.changingPassword = false;
                        return;
                    }
                    if (this.newPassword.length < 8) {
                        this.pwError = 'Minimo 8 caracteres';
                        this.changingPassword = false;
                        return;
                    }

                    try {
                        await api.put('/auth/me/password', {
                            currentPassword: this.currentPassword,
                            newPassword: this.newPassword
                        });
                        this.pwSuccess = true;
                        this.currentPassword = '';
                        this.newPassword = '';
                        this.confirmPassword = '';
                    } catch (err: any) {
                        this.pwError = err.message;
                    } finally {
                        this.changingPassword = false;
                    }
                },

                async unlinkGoogle() {
                    if (!confirm('Desvincular Google? Necesitaras usar email + password para entrar.')) return;
                    this.unlinking = true;
                    try {
                        await api.post('/auth/me/unlink-google');
                        this.profile.provider = 'EMAIL';
                        (window as any).__toast?.success('Google desvinculado');
                    } catch (err: any) {
                        (window as any).__toast?.error(err.message);
                    } finally {
                        this.unlinking = false;
                    }
                },

                initGoogleButton() {
                    const tryInit = () => {
                        if (!(window as any).google || this.profile.provider === 'GOOGLE') return;
                        (window as any).google.accounts.id.initialize({
                            client_id: '1089660527623-1djn0h3aok3pguj8ni097qbr34rqt1e3.apps.googleusercontent.com',
                            callback: async (response: any) => {
                                try {
                                    await api.post('/auth/me/link-google', { idToken: response.credential });
                                    this.profile.provider = 'GOOGLE';
                                    (window as any).__toast?.success('Google vinculado');
                                } catch (err: any) {
                                    (window as any).__toast?.error(err.message);
                                }
                            }
                        });
                        const btn = document.getElementById('google-link-btn');
                        if (btn) {
                            (window as any).google.accounts.id.renderButton(btn, {
                                theme: 'filled_black', size: 'large', shape: 'pill', text: 'signin_with'
                            });
                        }
                    };
                    setTimeout(tryInit, 500);
                }
            }));
        });
    </script>

    <!-- Google Identity Services -->
    <script is:inline src="https://accounts.google.com/gsi/client" async defer></script>
</Layout>
