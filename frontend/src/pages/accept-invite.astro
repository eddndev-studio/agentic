---
import "../styles/global.css";
import AuthCard from "../components/auth/AuthCard.astro";
import AuthInput from "../components/auth/AuthInput.astro";
import AuthButton from "../components/auth/AuthButton.astro";
import AuthError from "../components/auth/AuthError.astro";
import AuthLink from "../components/auth/AuthLink.astro";
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="theme-color" content="#0b141a" />
        <meta name="mobile-web-app-capable" content="yes" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <title>Aceptar Invitacion | Agentic</title>
    </head>
    <body class="bg-wa-bg-deep min-h-screen flex items-center justify-center font-sans text-wa-text-primary antialiased relative overflow-hidden">
        <main x-data="inviteForm">
            <AuthCard title="Aceptar invitacion" subtitle="Crea tu cuenta para unirte al equipo">
                <!-- Success -->
                <div x-show="done" x-transition class="text-center py-4">
                    <div class="w-12 h-12 rounded-full bg-wa-green/10 flex items-center justify-center mx-auto mb-4">
                        <svg class="w-6 h-6 text-wa-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <p class="text-sm text-wa-text-primary">Te has unido al equipo</p>
                    <a href="/login" class="inline-block mt-4 text-sm text-wa-green hover:text-wa-green-hover transition-colors">Ir al login</a>
                </div>

                <!-- Form -->
                <form x-show="!done" @submit.prevent="submit" class="relative">
                    <AuthError />
                    <AuthInput label="Nombre completo" type="text" x-model="fullName" placeholder="Tu nombre" required />
                    <div class="mt-5">
                        <AuthInput label="Email" type="email" x-model="email" placeholder="tu@email.com" required />
                    </div>
                    <div class="mt-5">
                        <AuthInput label="Password" type="password" x-model="password" placeholder="Minimo 8 caracteres" required />
                    </div>
                    <AuthButton loadingText="Creando cuenta...">Unirse al equipo</AuthButton>
                </form>

                <Fragment slot="footer">
                    <div class="mt-6 text-center">
                        <span class="text-xs text-wa-text-secondary">Ya tienes cuenta? </span>
                        <AuthLink href="/login">Inicia sesion</AuthLink>
                    </div>
                </Fragment>
            </AuthCard>
        </main>

        <script>
            import { ApiClient as api } from "../lib/api";

            document.addEventListener("alpine:init", () => {
                Alpine.data("inviteForm", () => ({
                    fullName: "",
                    email: "",
                    password: "",
                    loading: false,
                    errorMessage: "",
                    done: false,

                    async submit() {
                        this.loading = true;
                        this.errorMessage = '';
                        try {
                            const params = new URLSearchParams(window.location.search);
                            const token = params.get('token');
                            if (!token) throw new Error('Token de invitacion no encontrado');

                            const response = await api.post('/auth/accept-invite', {
                                token,
                                email: this.email,
                                password: this.password,
                                fullName: this.fullName
                            });

                            if (response.token) {
                                localStorage.setItem('token', response.token);
                                localStorage.setItem('user', JSON.stringify(response.membership));
                                window.location.href = '/';
                            } else {
                                this.done = true;
                            }
                        } catch (err) {
                            this.errorMessage = err instanceof Error ? err.message : 'Error accepting invite';
                        } finally {
                            this.loading = false;
                        }
                    }
                }));
            });
        </script>
    </body>
</html>
