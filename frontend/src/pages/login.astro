---
import "../styles/global.css";
import AuthCard from "../components/auth/AuthCard.astro";
import AuthInput from "../components/auth/AuthInput.astro";
import AuthButton from "../components/auth/AuthButton.astro";
import AuthError from "../components/auth/AuthError.astro";
import AuthLink from "../components/auth/AuthLink.astro";
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="theme-color" content="#0b141a" />
        <meta name="mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
        <meta name="apple-mobile-web-app-title" content="Agentic" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <link rel="apple-touch-icon" href="/apple-touch-icon-180x180.png" />
        <link rel="manifest" href="/manifest.webmanifest" />
        <title>Login | Agentic</title>
        <script src="/registerSW.js" is:inline></script>
    </head>
    <body class="bg-wa-bg-deep min-h-screen flex items-center justify-center font-sans text-wa-text-primary antialiased relative overflow-hidden">
        <main x-data="loginForm">
            <AuthCard title="Inicia sesion en tu cuenta">
                <form @submit.prevent="submit" class="relative">
                    <AuthError />
                    <AuthInput label="Email" type="email" x-model="email" placeholder="tu@email.com" required />
                    <div class="mt-6">
                        <AuthInput label="Password" type="password" x-model="password" placeholder="••••••••" required />
                    </div>
                    <div class="flex justify-end mt-3">
                        <AuthLink href="/forgot-password">Olvidaste tu password?</AuthLink>
                    </div>
                    <AuthButton loadingText="Verificando...">Iniciar Sesion</AuthButton>
                </form>

                <!-- Divider -->
                <div class="flex items-center gap-3 my-6">
                    <div class="flex-1 border-t border-wa-border"></div>
                    <span class="text-xs text-wa-text-secondary">o</span>
                    <div class="flex-1 border-t border-wa-border"></div>
                </div>

                <!-- Google Sign-In -->
                <div id="google-signin-btn" class="flex justify-center"></div>

                <Fragment slot="footer">
                    <div class="mt-6 text-center">
                        <span class="text-xs text-wa-text-secondary">No tienes cuenta? </span>
                        <AuthLink href="/register">Crear cuenta</AuthLink>
                    </div>
                </Fragment>
            </AuthCard>
        </main>

        <script>
            import { ApiClient as api } from "../lib/api";

            const setToken = (token: string) => localStorage.setItem('token', token);
            const setUser = (user: any) => localStorage.setItem('user', JSON.stringify(user));

            document.addEventListener("alpine:init", () => {
                Alpine.data("loginForm", () => ({
                    email: "",
                    password: "",
                    loading: false,
                    errorMessage: "",

                    async submit() {
                        this.loading = true;
                        this.errorMessage = '';
                        try {
                            const response = await api.post('/auth/login', {
                                email: this.email,
                                password: this.password
                            });
                            if (response.token) {
                                setToken(response.token);
                                setUser(response.user);
                                window.location.href = '/';
                            } else {
                                this.errorMessage = 'Login failed: No token received';
                            }
                        } catch (err) {
                            this.errorMessage = err instanceof Error ? err.message : 'Login failed';
                        } finally {
                            this.loading = false;
                        }
                    }
                }));
            });

            // Google Sign-In
            window.handleGoogleCredential = async (response: any) => {
                try {
                    const result = await api.post('/auth/google', { idToken: response.credential });
                    if (result.token) {
                        setToken(result.token);
                        setUser(result.user);
                        window.location.href = '/';
                    }
                } catch (err) {
                    console.error('Google auth failed:', err);
                }
            };
        </script>

        <!-- Google Identity Services -->
        <script is:inline src="https://accounts.google.com/gsi/client" async defer></script>
        <script is:inline>
            window.addEventListener('load', () => {
                if (window.google) {
                    google.accounts.id.initialize({
                        client_id: '1089660527623-1djn0h3aok3pguj8ni097qbr34rqt1e3.apps.googleusercontent.com',
                        callback: window.handleGoogleCredential
                    });
                    google.accounts.id.renderButton(
                        document.getElementById('google-signin-btn'),
                        { theme: 'filled_black', size: 'large', width: '100%', shape: 'pill', text: 'signin_with' }
                    );
                }
            });
        </script>
    </body>
</html>
