---
import "../styles/global.css";
import AuthCard from "../components/auth/AuthCard.astro";
import AuthInput from "../components/auth/AuthInput.astro";
import AuthButton from "../components/auth/AuthButton.astro";
import AuthError from "../components/auth/AuthError.astro";
import AuthLink from "../components/auth/AuthLink.astro";
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="theme-color" content="#0b141a" />
        <meta name="mobile-web-app-capable" content="yes" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <title>Nueva Password | Agentic</title>
    </head>
    <body class="bg-wa-bg-deep min-h-screen flex items-center justify-center font-sans text-wa-text-primary antialiased relative overflow-hidden">
        <main x-data="resetForm">
            <AuthCard title="Crea tu nueva password">
                <!-- Success -->
                <div x-show="done" x-transition class="text-center py-4">
                    <div class="w-12 h-12 rounded-full bg-wa-green/10 flex items-center justify-center mx-auto mb-4">
                        <svg class="w-6 h-6 text-wa-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <p class="text-sm text-wa-text-primary">Password actualizada</p>
                    <a href="/login" class="inline-block mt-4 text-sm text-wa-green hover:text-wa-green-hover transition-colors">Ir al login</a>
                </div>

                <!-- Form -->
                <form x-show="!done" @submit.prevent="submit" class="relative">
                    <AuthError />
                    <AuthInput label="Nueva password" type="password" x-model="password" placeholder="Minimo 8 caracteres" required />
                    <div class="mt-5">
                        <AuthInput label="Confirmar password" type="password" x-model="confirmPassword" placeholder="Repite tu password" required />
                    </div>
                    <AuthButton loadingText="Actualizando...">Actualizar Password</AuthButton>
                </form>

                <Fragment slot="footer">
                    <div class="mt-6 text-center">
                        <AuthLink href="/login">Volver al login</AuthLink>
                    </div>
                </Fragment>
            </AuthCard>
        </main>

        <script>
            import { ApiClient as api } from "../lib/api";

            document.addEventListener("alpine:init", () => {
                Alpine.data("resetForm", () => ({
                    password: "",
                    confirmPassword: "",
                    loading: false,
                    errorMessage: "",
                    done: false,

                    async submit() {
                        if (this.password !== this.confirmPassword) {
                            this.errorMessage = 'Las passwords no coinciden';
                            return;
                        }
                        if (this.password.length < 8) {
                            this.errorMessage = 'La password debe tener al menos 8 caracteres';
                            return;
                        }

                        this.loading = true;
                        this.errorMessage = '';
                        try {
                            const params = new URLSearchParams(window.location.search);
                            const token = params.get('token');
                            if (!token) throw new Error('Token no encontrado en la URL');

                            await api.post('/auth/reset-password', { token, password: this.password });
                            this.done = true;
                        } catch (err) {
                            this.errorMessage = err instanceof Error ? err.message : 'Error resetting password';
                        } finally {
                            this.loading = false;
                        }
                    }
                }));
            });
        </script>
    </body>
</html>
