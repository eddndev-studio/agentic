---
import "../styles/global.css";
---

<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="theme-color" content="#0b141a" />
        <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
        <title>Sin conexion | Agentic</title>
    </head>
    <body class="bg-wa-bg-deep min-h-screen flex items-center justify-center font-sans text-wa-text-primary antialiased">
        <div class="text-center p-8 max-w-sm">
            <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-wa-bg-panel border border-wa-border flex items-center justify-center">
                <svg class="w-8 h-8 text-wa-text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636a9 9 0 010 12.728m-2.829-2.829a5 5 0 000-7.07m-4.243 9.9a9 9 0 01-6.364-2.637m2.829-2.828a5 5 0 017.07 0"></path>
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-white mb-2">Sin conexion</h1>
            <p class="text-sm text-wa-text-secondary mb-8">
                Verifica tu conexion a internet e intenta de nuevo.
            </p>
            <button
                onclick="window.location.reload()"
                class="px-6 py-3 bg-wa-green text-white text-sm font-semibold rounded-lg hover:bg-wa-green-hover transition-all"
            >
                Reintentar
            </button>
        </div>
    </body>
</html>
