---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import Sidebar from "../components/Sidebar.astro";

interface Props {
	title: string;
	fullWidth?: boolean;
}

const { title, fullWidth = false } = Astro.props;
---

<script>
	import Alpine from "alpinejs";
	import { i18nPlugin } from "../i18n";
	import storePlugin from "../lib/store";
	import { ApiClient } from "../lib/api";
	import "../lib/toast"; // Initialize toast globally

	let storesInitialized = false;

	document.addEventListener("alpine:init", () => {
		if (storesInitialized) return;
		storesInitialized = true;

		i18nPlugin(Alpine);
		storePlugin(Alpine);

		// Auth Store
		Alpine.store("auth", {
			user: null,
			loading: true,
			init() {
				this.checkSession();
			},
			async checkSession() {
				console.log("[Auth] Checking session...");
				try {
					const response = await ApiClient.get("/auth/me");
					console.log("[Auth] Session valid:", response);
					this.user = response;
					this.loading = false;
				} catch (e) {
					console.error("[Auth] Session check failed:", e);
					if (window.location.pathname !== "/login") {
						console.log("[Auth] Redirecting to login");
						window.location.href = "/login";
					} else {
						this.loading = false;
					}
				}
			},
			async logout() {
				try {
					await ApiClient.post("/auth/logout", {});
					window.location.href = "/login";
				} catch (e) {
					console.error("Logout failed", e);
				}
			},
		});

		// Alpine auto-calls init() on stores — no explicit call needed
	});

	// ── ViewTransitions + Alpine lifecycle ──────────────────────────
	// Pause Alpine's MutationObserver during DOM swap to prevent
	// processing elements before page scripts register their data.
	document.addEventListener("astro:before-swap", () => {
		Alpine.deferMutations();
	});

	// After swap + scripts executed: re-trigger alpine:init so page
	// scripts register their Alpine.data() factories, then init the
	// new DOM tree.
	document.addEventListener("astro:page-load", () => {
		Alpine.flushAndStopDeferringMutations();
		document.dispatchEvent(new CustomEvent("alpine:init"));
		Alpine.initTree(document.body);
	});
</script>

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Agentic Bot Orchestrator" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Agentic</title>
		<ViewTransitions />
	</head>
	<body
		class="selection:bg-wa-green selection:text-white relative bg-wa-bg-deep min-h-screen text-wa-text-primary font-sans antialiased overflow-x-hidden"
		x-data
		x-cloak
		style="display: none !important;"
		x-show="!$store.auth.loading"
		x-init="$el.style.display = ''"
	>
		<!-- Main Content (animated on navigation) -->
		<main class:list={[
			fullWidth
				? "md:px-2 md:pt-2 min-h-screen"
				: "px-4 pt-4 md:px-8 md:pt-8 pb-20 max-w-7xl mx-auto min-h-screen"
		]} transition:animate="fade">
			<slot />
		</main>

		<!-- Bottom Navigation (hidden on fullWidth pages) -->
		{!fullWidth && (
			<div transition:persist="bottomnav">
				<Sidebar />
			</div>
		)}
	</body>
</html>
