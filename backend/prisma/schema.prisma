generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════════
// Auth & Multi-Tenant
// ═══════════════════════════════════════════════════════════════════════════════

model User {
  id            String       @id @default(uuid())
  email         String       @unique
  passwordHash  String?
  fullName      String?
  avatarUrl     String?
  provider      AuthProvider @default(EMAIL)
  emailVerified Boolean      @default(false)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  memberships Membership[]
  workers     Worker[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships    Membership[]
  invitations    Invitation[]
  bots           Bot[]
  templates      Template[]
  workers        Worker[]
  bankAccounts   BankAccount[]
  periods        FinancialPeriod[]
  fbConnections  FacebookConnection[]
}

model Membership {
  id        String   @id @default(uuid())
  userId    String
  orgId     String
  role      Role
  createdAt DateTime @default(now())

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  workerBots WorkerBot[]

  @@unique([userId, orgId])
}

model WorkerBot {
  id           String @id @default(uuid())
  membershipId String
  botId        String

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  bot        Bot        @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([membershipId, botId])
}

model Invitation {
  id         String    @id @default(uuid())
  orgId      String
  email      String
  role       Role
  token      String    @unique @default(uuid())
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([email])
}

enum Role {
  OWNER
  ADMIN
  SUPERVISOR
  WORKER
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

model Bot {
  id                    String       @id @default(uuid())
  orgId                 String
  name                  String
  platform              Platform
  identifier            String       @unique
  credentials           Json?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  ipv6Address           String?
  aiEnabled             Boolean      @default(false)
  defaultSessionAi      Boolean      @default(false)
  aiModel               String       @default("gemini-2.5-flash")
  aiProvider            AIProvider   @default(GEMINI)
  systemPrompt          String?
  temperature           Float        @default(0.7)
  thinkingLevel         String?      @default("LOW")
  paused                Boolean      @default(false)
  messageDelay          Int          @default(0)
  contextMessages       Int          @default(20)
  autoReadReceipts      Boolean      @default(true)
  clients               Client[]
  flows                 Flow[]
  excludeGroups         Boolean      @default(false)
  ignoredLabels         String[]     @default([])
  labels                Label[]
  sessions              Session[]
  tools                 Tool[]
  triggers              Trigger[]
  automations           Automation[]
  notificationChannels  Json?        @default("[]")
  templateId            String?
  template              Template?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  botVariables          Json?        @default("{}")
  connectTokens         ConnectToken[]
  workerBots            WorkerBot[]
  org                   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Template {
  id            String       @id @default(uuid())
  orgId         String
  name          String
  description   String?
  aiEnabled     Boolean      @default(true)
  defaultSessionAi Boolean   @default(false)
  aiModel       String       @default("gemini-2.5-flash")
  aiProvider    AIProvider   @default(GEMINI)
  systemPrompt  String?
  temperature   Float        @default(0.7)
  thinkingLevel String?      @default("LOW")
  messageDelay      Int          @default(0)
  contextMessages   Int          @default(20)
  autoReadReceipts  Boolean      @default(true)
  excludeGroups Boolean      @default(false)
  ignoredLabels String[]     @default([])
  variables     Json?        @default("[]")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  bots          Bot[]
  flows         Flow[]
  tools         Tool[]
  triggers      Trigger[]
  automations   Automation[]
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model Session {
  id               String            @id @default(uuid())
  platform         Platform
  identifier       String
  botId            String
  name             String?
  notes            String?
  status           SessionStatus     @default(DISCONNECTED)
  authData         Json?
  aiEnabled        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  conversationLogs ConversationLog[]
  executions       Execution[]
  labels           SessionLabel[]
  messages         Message[]
  bot              Bot               @relation(fields: [botId], references: [id], onDelete: Cascade)
  triggers         Trigger[]

  @@unique([botId, identifier])
}

model Trigger {
  id          String       @id @default(uuid())
  botId       String?
  templateId  String?
  sessionId   String?
  keyword     String       @default("")
  matchType   MatchType    @default(CONTAINS)
  isActive    Boolean      @default(true)
  flowId      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  scope       TriggerScope @default(INCOMING)
  triggerType TriggerType  @default(TEXT)
  labelName   String?
  labelAction LabelAction?
  bot         Bot?         @relation(fields: [botId], references: [id], onDelete: Cascade)
  template    Template?    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  flow        Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  session     Session?     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Flow {
  id            String      @id @default(uuid())
  botId         String?
  templateId    String?
  name          String
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  cooldownMs    Int         @default(0)
  usageLimit    Int         @default(0)
  excludesFlows String[]    @default([])
  executions    Execution[]
  bot           Bot?        @relation(fields: [botId], references: [id], onDelete: Cascade)
  template      Template?   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  steps         Step[]
  tools         Tool[]
  triggers      Trigger[]
}

model Step {
  id        String   @id @default(uuid())
  flowId    String
  type      StepType
  content   String?
  mediaUrl  String?
  metadata  Json?
  delayMs   Int      @default(1000)
  jitterPct Int      @default(10)
  order     Int
  aiOnly    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId, order])
}

model Execution {
  id              String    @id @default(uuid())
  sessionId       String
  flowId          String
  platformUserId  String
  status          String    @default("RUNNING")
  currentStep     Int       @default(0)
  variableContext Json?
  startedAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?
  error           String?
  trigger         String?
  flow            Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  session         Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, platformUserId])
  @@index([status])
}

model Message {
  id          String   @id @default(uuid())
  externalId  String   @unique
  sessionId   String
  sender      String
  content     String?
  type        String
  metadata    Json?
  isProcessed Boolean  @default(false)
  createdAt   DateTime @default(now())
  fromMe      Boolean  @default(false)
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([externalId])
  @@index([sessionId])
}

model CommandLog {
  id        String   @id @default(uuid())
  name      String
  user      String
  status    String
  result    String?
  createdAt DateTime @default(now())
}

model Client {
  id                String       @id @default(uuid())
  email             String       @unique
  phoneNumber       String
  encryptedPassword String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  botId             String
  status            ClientStatus @default(REGISTRO_PENDIENTE)
  curp              String?      @unique
  bot               Bot          @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([phoneNumber])
  @@index([curp])
  @@index([botId])
}

model Tool {
  id           String     @id @default(uuid())
  botId        String?
  templateId   String?
  name         String
  description  String
  parameters   Json?
  actionType   String
  actionConfig Json?
  status       ToolStatus @default(ACTIVE)
  flowId       String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  bot          Bot?       @relation(fields: [botId], references: [id], onDelete: Cascade)
  template     Template?  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  flow         Flow?      @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@unique([botId, name])
  @@unique([templateId, name])
  @@index([botId])
  @@index([templateId])
}

model ConversationLog {
  id         String   @id @default(uuid())
  sessionId  String
  role       String
  content    String?
  toolName   String?
  toolArgs   Json?
  toolResult Json?
  tokenCount Int?
  model      String?
  createdAt  DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, createdAt])
}

model Label {
  id           String         @id @default(uuid())
  botId        String
  waLabelId    String
  name         String
  color        Int
  position     Int            @default(0)
  deleted      Boolean        @default(false)
  predefinedId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  bot          Bot            @relation(fields: [botId], references: [id], onDelete: Cascade)
  sessions     SessionLabel[]

  @@unique([botId, waLabelId])
  @@index([botId])
}

model SessionLabel {
  id         String   @id @default(uuid())
  sessionId  String
  labelId    String
  assignedAt DateTime @default(now())
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  label      Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([sessionId, labelId])
  @@index([sessionId])
  @@index([labelId])
}

enum Platform {
  WHATSAPP
  WHATSAPP_CLOUD
  TELEGRAM
}

enum SessionStatus {
  CONNECTED
  DISCONNECTED
  AUTHENTICATING
  FAILED
}

enum MatchType {
  EXACT
  CONTAINS
  REGEX
}

enum StepType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  PTT
  CONDITIONAL_TIME
  TOOL
}

enum TriggerScope {
  INCOMING
  OUTGOING
  BOTH
}

enum TriggerType {
  TEXT
  LABEL
}

enum LabelAction {
  ADD
  REMOVE
}

enum AIProvider {
  OPENAI
  GEMINI
}

enum ToolStatus {
  ACTIVE
  DISABLED
}

enum ClientStatus {
  REGISTRO_PENDIENTE
  PAGO_GOBIERNO_PENDIENTE
  PAGO_GOBIERNO_REALIZADO
  EXAMEN_EN_PROCESO
  LICENCIA_LISTA
  COMPLETADO
}

model Automation {
  id          String          @id @default(uuid())
  botId       String?
  templateId  String?
  name        String
  description String?
  enabled     Boolean         @default(true)
  event       AutomationEvent
  labelName   String?
  timeoutMs   Int
  prompt      String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  bot         Bot?            @relation(fields: [botId], references: [id], onDelete: Cascade)
  template    Template?       @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([botId])
  @@index([templateId])
}

enum AutomationEvent {
  INACTIVITY
}

model ConnectToken {
  id        String    @id @default(uuid())
  token     String    @unique
  botId     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  bot       Bot       @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([botId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// Financial Management + Facebook Ads Tracking
// ═══════════════════════════════════════════════════════════════════════════════

enum PeriodType {
  WEEKLY
  MONTHLY
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum FbSyncStatus {
  OK
  TOKEN_EXPIRING
  TOKEN_EXPIRED
  ERROR
}

enum AdInsightLevel {
  CAMPAIGN
  ADSET
  AD
}

// ─── Finance Core ────────────────────────────────────────────────────────────

model Worker {
  id               String         @id @default(uuid())
  orgId            String
  userId           String?
  name             String
  baseSalary       Float
  bonusPercent     Float          @default(0)
  bonusMinLicenses Int            @default(0)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  incomes          Income[]
  workerPeriods    WorkerPeriod[]
  adAccount        AdAccount?
  org              Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user             User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([userId])
}

model BankAccount {
  id         String       @id @default(uuid())
  orgId      String
  name       String
  bankName   String
  identifier String
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  incomes    Income[]
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model FinancialPeriod {
  id            String         @id @default(uuid())
  orgId         String
  type          PeriodType
  startDate     DateTime
  endDate       DateTime
  status        PeriodStatus   @default(OPEN)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  incomes       Income[]
  expenses      Expense[]
  workerPeriods WorkerPeriod[]
  org           Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([startDate, endDate])
  @@index([status])
}

model Income {
  id            String          @id @default(uuid())
  amount        Float
  bankAccountId String
  workerId      String
  periodId      String
  date          DateTime
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  bankAccount   BankAccount     @relation(fields: [bankAccountId], references: [id])
  worker        Worker          @relation(fields: [workerId], references: [id])
  period        FinancialPeriod @relation(fields: [periodId], references: [id])

  @@index([periodId])
  @@index([workerId])
  @@index([bankAccountId])
  @@index([date])
}

model Expense {
  id          String          @id @default(uuid())
  description String
  amount      Float
  periodId    String
  date        DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  period      FinancialPeriod @relation(fields: [periodId], references: [id])

  @@index([periodId])
}

model WorkerPeriod {
  id            String          @id @default(uuid())
  workerId      String
  periodId      String
  licenseSales  Int             @default(0)
  debtCarryOver Float           @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  worker        Worker          @relation(fields: [workerId], references: [id])
  period        FinancialPeriod @relation(fields: [periodId], references: [id])

  @@unique([workerId, periodId])
  @@index([periodId])
  @@index([workerId])
}

// ─── Facebook Ads ────────────────────────────────────────────────────────────

model FacebookConnection {
  id            String       @id @default(uuid())
  orgId         String
  accessToken   String
  tokenExpiry   DateTime
  fbUserId      String       @unique
  fbUserName    String
  syncStatus    FbSyncStatus @default(OK)
  lastSyncAt    DateTime?
  lastSyncError String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  adAccounts    AdAccount[]
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model AdAccount {
  id            String             @id @default(uuid())
  fbAccountId   String             @unique
  name          String
  accountStatus Int                @default(1)
  workerId      String?            @unique
  connectionId  String
  lastSyncAt    DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  worker        Worker?            @relation(fields: [workerId], references: [id], onDelete: SetNull)
  connection    FacebookConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  campaigns     Campaign[]

  @@index([connectionId])
  @@index([workerId])
}

model Campaign {
  id                  String      @id @default(uuid())
  fbCampaignId        String      @unique
  name                String
  status              String
  objective           String?
  buyingType          String?
  dailyBudget         Float?
  lifetimeBudget      Float?
  specialAdCategories String[]    @default([])
  startTime           DateTime?
  endTime             DateTime?
  adAccountId         String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  adAccount           AdAccount   @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  adSets              AdSet[]
  insights            AdInsight[]

  @@index([adAccountId])
}

model AdSet {
  id                   String      @id @default(uuid())
  fbAdSetId            String      @unique
  name                 String
  status               String
  targetingDescription String?
  targeting            Json?
  dailyBudget          Float?
  lifetimeBudget       Float?
  optimizationGoal     String?
  billingEvent         String?
  bidAmount            Float?
  startTime            DateTime?
  endTime              DateTime?
  campaignId           String
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  campaign             Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  ads                  Ad[]
  insights             AdInsight[]

  @@index([campaignId])
}

model Ad {
  id         String      @id @default(uuid())
  fbAdId     String      @unique
  name       String
  status     String
  creativeId String?
  adSetId    String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  adSet      AdSet       @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  insights   AdInsight[]

  @@index([adSetId])
}

model AdInsight {
  id                String         @id @default(uuid())
  date              DateTime       @db.Date
  level             AdInsightLevel
  campaignId        String?
  adSetId           String?
  adId              String?
  spend             Float          @default(0)
  impressions       Int            @default(0)
  clicks            Int            @default(0)
  reach             Int            @default(0)
  conversions       Int            @default(0)
  costPerConversion Float          @default(0)
  rawActions        Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  campaign          Campaign?      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adSet             AdSet?         @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  ad                Ad?            @relation(fields: [adId], references: [id], onDelete: Cascade)

  @@unique([date, level, campaignId, adSetId, adId])
  @@index([date])
  @@index([campaignId])
  @@index([adSetId])
  @@index([adId])
}
